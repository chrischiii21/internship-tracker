---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import { getSession } from '../lib/auth';
import { parse } from 'cookie';

// Check if user is logged in
const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookies = parse(cookieHeader);
const user = cookies.session ? await getSession(cookies.session) : null;

// If logged in, redirect to dashboard
if (user) {
  return Astro.redirect('/dashboard');
}
---
<Layout>
  <header id="sys-header">
    <div class="header-left">
      <div class="logo-mark">
        <img src="/logo.png" alt="Logo" width="32" height="32" />
      </div>
      <div class="logo-text">
        <span class="logo-primary">InternFlow</span>
        <span class="logo-sep">/</span>
        <span class="logo-secondary">Progress Tracker</span>
      </div>
    </div>
    <div class="header-center">
      <div class="clock-wrapper">
        <span class="pulse-dot green"></span>
        <span id="live-clock" class="live-clock">--:--:-- --</span>
        <span class="clock-tz">PHT</span>
      </div>
    </div>
    <div class="header-right">
      <div class="status-pill">
        <span class="pulse-dot green"></span>
        <span class="status-on">System Online</span>
        <span class="sdiv">|</span>
        <span class="status-api">Clockify API Connected</span>
      </div>
    </div>
  </header>

  <div id="portal-body">
    <!-- SIDEBAR (Locked Preview) -->
    <Sidebar isLocked={true} activeTab="dashboard" />

    <!-- MAIN STAGE -->
    <main id="portal-main">
      <div class="bg-grid" aria-hidden="true"></div>
      <div class="bg-glow" aria-hidden="true"></div>

      <div id="stage" class="content-center">
        <!-- TOP METRICS -->
        <div class="metrics-row">
          <div class="metric-card locked">
            <div class="metric-label">Active Rate</div>
            <div class="metric-value">₱60.00<span class="metric-unit"> / hr</span></div>
            <div class="metric-sub">Current multiplier</div>
            <div class="lock-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="10" rx="2" stroke="var(--ntv-orange)" stroke-opacity="0.5" stroke-width="2"/><path d="M8 11V7a4 4 0 1 1 8 0v4" stroke="var(--ntv-orange)" stroke-opacity="0.5" stroke-width="2" stroke-linecap="round"/></svg></div>
          </div>
          <div class="metric-card locked">
            <div class="metric-label">Target Date</div>
            <div class="metric-value" id="countdown-val">--</div>
            <div class="metric-sub">May 12, 2026 · days left</div>
            <div class="lock-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="10" rx="2" stroke="var(--ntv-orange)" stroke-opacity="0.5" stroke-width="2"/><path d="M8 11V7a4 4 0 1 1 8 0v4" stroke="var(--ntv-orange)" stroke-opacity="0.5" stroke-width="2" stroke-linecap="round"/></svg></div>
          </div>
        </div>

        <!-- COMMAND CARD -->
        <div id="command-card">
          <div class="card-eyebrow"><span class="eyebrow-dot"></span><span>Secure Portal Access</span></div>
          <h1 class="card-title">Log in to view your<br/><span class="card-accent">Internship Progress</span></h1>
          <p class="card-sub">Your professional dashboard for tracking hours and internship requirements in real-time.</p>
          <a href="/api/auth/google" id="google-btn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="20" height="20"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.35-8.16 2.35-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
            <span>Continue with Google</span>
          </a>
          <div class="divider"><span class="dline"></span><span class="dtext">secured by</span><span class="dline"></span></div>
          <div class="sec-badge">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 2L3 7V12C3 16.55 6.84 20.74 12 22C17.16 20.74 21 16.55 21 12V7L12 2Z" stroke="var(--ntv-orange)" stroke-opacity="0.8" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 12L11 14L15 10" stroke="var(--ntv-orange)" stroke-opacity="0.8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Authenticated via Official <strong>InternFlow</strong> Workspace Portal</span>
          </div>
        </div>

        <!-- BOTTOM METRICS -->
        <div class="metrics-row">
          <div class="metric-card locked">
            <div class="metric-label">Total Program</div>
            <div class="metric-value">--- <span class="metric-unit">/ --- hrs</span></div>
            <div class="metric-sub">Login to view your data</div>
            <div class="lock-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="10" rx="2" stroke="var(--ntv-orange)" stroke-opacity="0.5" stroke-width="2"/><path d="M8 11V7a4 4 0 1 1 8 0v4" stroke="var(--ntv-orange)" stroke-opacity="0.5" stroke-width="2" stroke-linecap="round"/></svg></div>
          </div>
          <div class="metric-card locked">
            <div class="metric-label">Team Status</div>
            <div class="metric-value">3<span class="metric-unit"> active</span></div>
            <div class="metric-sub">Developers online now</div>
            <div class="lock-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="10" rx="2" stroke="var(--ntv-orange)" stroke-opacity="0.5" stroke-width="2"/><path d="M8 11V7a4 4 0 1 1 8 0v4" stroke="var(--ntv-orange)" stroke-opacity="0.5" stroke-width="2" stroke-linecap="round"/></svg></div>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  function tick() {
    const pht = new Date(new Date().toLocaleString('en-US', { timeZone: 'Asia/Manila' }));
    const h = pht.getHours(), m = String(pht.getMinutes()).padStart(2,'0'), s = String(pht.getSeconds()).padStart(2,'0');
    const ampm = h >= 12 ? 'PM' : 'AM';
    const el = document.getElementById('live-clock');
    if (el) el.textContent = `${String(h%12||12).padStart(2,'0')}:${m}:${s} ${ampm}`;
  }
  tick(); setInterval(tick, 1000);

  const target = new Date('2026-05-12T00:00:00+08:00');
  const days = Math.max(0, Math.ceil((target.getTime() - Date.now()) / 86400000));
  const cv = document.getElementById('countdown-val');
  if (cv) cv.textContent = days + ' days';

  // Toasts
  const params = new URLSearchParams(window.location.search);
  const successVal = params.get('success');
  if (successVal) {
    const msg = successVal === 'true' ? 'Welcome!' : successVal;
    window.showToast(msg, 'success');
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }
  if (params.get('error')) {
    window.showToast(decodeURIComponent(params.get('error')), 'error');
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }
</script>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  /* HEADER */
  #sys-header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 24px; height: 56px;
    background: rgba(5,11,22,0.88); backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(237,102,33,0.15);
  }
  .header-left { display: flex; align-items: center; gap: 10px; }
  .logo-mark {
    display: flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; background: rgba(237,102,33,0.12);
    border: 1px solid rgba(237,102,33,0.3); border-radius: 8px;
  }
  .logo-text { display: flex; align-items: center; gap: 6px; font-size: 14px; font-weight: 600; }
  .logo-primary { color: var(--ntv-orange); font-weight: 700; letter-spacing: .08em; }
  .logo-sep { color: rgba(255,255,255,.22); font-weight: 300; }
  .logo-secondary { color: rgba(255,255,255,.5); font-weight: 400; }
  
  .clock-wrapper {
    display: flex; align-items: center; gap: 8px;
    background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08);
    border-radius: 20px; padding: 5px 14px;
  }
  .live-clock { font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 500; color: #ffffff; letter-spacing: .06em; }
  .clock-tz { font-size: 10px; font-weight: 600; color: var(--ntv-orange); letter-spacing: .1em; background: rgba(237,102,33,.15); padding: 2px 6px; border-radius: 4px; }
  
  .status-pill { display: flex; align-items: center; gap: 7px; background: rgba(52,211,153,.08); border: 1px solid rgba(52,211,153,.2); border-radius: 20px; padding: 5px 14px; font-size: 12px; }
  .pulse-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; animation: pdot 2s ease-in-out infinite; }
  .green { background: #34d399; box-shadow: 0 0 7px #34d399; }
  @keyframes pdot { 0%,100%{opacity:1} 50%{opacity:.35} }
  .status-on { font-weight: 600; color: #34d399; }
  .sdiv { color: rgba(255,255,255,.2); }
  .status-api { color: rgba(255,255,255,.45); font-size: 11px; }

  /* MAIN */
  #portal-main { margin-left: 220px; flex: 1; display: flex; align-items: center; justify-content: center; min-height: calc(100vh - 56px); position: relative; padding: 32px 24px; }
  .bg-grid { position: fixed; inset: 0; background-image: linear-gradient(rgba(237,102,33,.03) 1px, transparent 1px), linear-gradient(90deg, rgba(237,102,33,.03) 1px, transparent 1px); background-size: 40px 40px; pointer-events: none; }
  .bg-glow { position: fixed; top: 30%; left: 55%; transform: translateX(-50%); width: 560px; height: 360px; background: radial-gradient(ellipse, rgba(237,102,33,.08) 0%, transparent 70%); pointer-events: none; }

  #stage { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; gap: 16px; width: 100%; max-width: 820px; }
  .metrics-row { display: flex; gap: 16px; width: 100%; justify-content: center; }

  /* CARDS */
  .metric-card { flex: 1; max-width: 240px; min-width: 180px; background: rgba(13,20,33,.75); border: 1px solid var(--border-subtle); border-radius: 14px; padding: 18px 20px; position: relative; overflow: hidden; filter: blur(1.5px); opacity: .55; user-select: none; pointer-events: none; }
  .metric-label { font-size: 11px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 8px; }
  .metric-value { font-size: 26px; font-weight: 700; color: #ffffff; letter-spacing: -.02em; line-height: 1; }
  .metric-unit { font-size: 13px; font-weight: 400; color: var(--text-secondary); }
  .metric-sub { font-size: 11px; color: var(--text-secondary); margin-top: 6px; }
  .lock-icon { position: absolute; top: 10px; right: 12px; opacity: .8; }

  #command-card {
    width: 100%; max-width: 440px; background: rgba(13,20,33,.92);
    border: 1px solid rgba(237,102,33,.2); border-radius: 20px;
    padding: 36px 32px; backdrop-filter: blur(24px);
    box-shadow: 0 0 0 1px rgba(255,255,255,.04) inset, 0 24px 80px rgba(0,0,0,.55), 0 0 60px rgba(237,102,33,.05);
    animation: cin .6s cubic-bezier(.16,1,.3,1) both;
  }
  .card-eyebrow { display: flex; align-items: center; gap: 7px; font-size: 10px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--ntv-orange); opacity: 0.7; margin-bottom: 18px; }
  .eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--ntv-orange); box-shadow: 0 0 6px var(--ntv-orange); }
  .card-title { font-size: 24px; font-weight: 700; line-height: 1.3; color: #ffffff; margin-bottom: 10px; font-family: 'Outfit', sans-serif; }
  .card-accent { background: var(--ntv-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .card-sub { font-size: 13px; color: var(--text-secondary); line-height: 1.6; margin-bottom: 28px; }

  #google-btn {
    width: 100%; display: flex; align-items: center; justify-content: center; gap: 12px;
    padding: 13px 20px; background: #fff; color: #050b16;
    border: none; border-radius: 11px; font-size: 14px; font-weight: 700; cursor: pointer; transition: all .2s;
    box-shadow: 0 4px 20px rgba(0,0,0,.4); text-decoration: none; font-family: 'Outfit', sans-serif;
  }
  #google-btn:hover { background: #f1f5f9; transform: translateY(-1px); box-shadow: 0 6px 28px rgba(0,0,0,.5); }

  .divider { display: flex; align-items: center; gap: 10px; margin: 22px 0 18px; }
  .dline { flex: 1; height: 1px; background: rgba(255,255,255,.07); }
  .dtext { font-size: 10px; color: rgba(255,255,255,.2); letter-spacing: .07em; text-transform: uppercase; }

  .sec-badge {
    display: flex; align-items: flex-start; gap: 8px; padding: 11px 13px;
    background: rgba(237,102,33,.05); border: 1px solid rgba(237,102,33,.12);
    border-radius: 9px; font-size: 11.5px; color: var(--text-secondary); line-height: 1.5;
  }
  .sec-badge strong { color: var(--ntv-orange); font-weight: 600; }

  @media (max-width: 900px) {
    #sidebar { display: none; }
    #portal-main { 
      margin-left: 0; 
      padding: 16px; 
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }
    .header-center, .header-right { display: none; }
    .logo-secondary, .logo-sep { display: none; }
    #sys-header { justify-content: center; padding: 0 16px; }
    .metrics-row { flex-direction: column; align-items: center; width: 100%; }
    .metric-card { max-width: 100%; width: 100%; min-width: unset; }
  }

  @media (max-width: 600px) {
    .metrics-row { display: none; }
    #command-card { padding: 32px 20px; border-radius: 16px; }
    .card-title { font-size: 20px; }
  }
</style>
