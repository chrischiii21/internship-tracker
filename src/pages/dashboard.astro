---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import { getSession } from '../lib/auth';
import { parse } from 'cookie';
import { getAppSettings, DEFAULT_SETTINGS } from '../lib/settings';
import { getManualEntries, getActiveTimer, startTimer, stopTimer, updateTimerStart } from '../lib/entries';
import { getClockifyUser, getRenderedHours, getStudentProgress } from '../lib/clockify';
import { formatHMS, formatHours } from '../lib/utils';
import { groupEntries } from '../lib/grouping';
import { getPayoutAdjustments } from '../lib/payouts';

const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookies = parse(cookieHeader);
const user = cookies.session ? await getSession(cookies.session) : null;

if (!user) {
  return Astro.redirect('/');
}

const settings = await getAppSettings(user.id);

// Role-based redirect
if (settings.role === 'coordinator') {
  return Astro.redirect('/coordinator');
}

// POST actions for main timer control on dashboard
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'start-timer') {
    const desc = formData.get('description') as string;
    await startTimer(user.id, desc);
    return Astro.redirect('/dashboard?success=Timer started');
  }

  if (action === 'update-start') {
    const newStart = formData.get('startTime') as string;
    await updateTimerStart(user.id, newStart);
    return Astro.redirect('/dashboard?success=Start time updated');
  }

  if (action === 'stop-timer') {
    const desc = formData.get('description') as string;
    try {
      await stopTimer(user.id, desc);
      const { addSyncLog } = await import('../lib/logs');
      await addSyncLog({ userId: user.id, type: 'Sync', status: 'Success', details: `Timer stopped: ${desc || 'No description'}` });
      return Astro.redirect('/dashboard?success=Activity log saved');
    } catch (e) {
      return Astro.redirect(`/dashboard?error=${encodeURIComponent(e.message)}`);
    }
  }
}

const activeTimer = await getActiveTimer(user.id);

// Calculate Total Progress using the Unified Sync Engine
const renderedHours = await getStudentProgress(user.id, user.email, settings.startDate);

// Fetch detailed entry breakdown for the chart/list
let allRawEntries: { date: string, durationSeconds: number }[] = [];
try {
  if (settings.clockifyEnabled !== false) {
    const clockifyUser = await getClockifyUser(user.email);
    if (clockifyUser) {
      const clockifyData = await getRenderedHours(clockifyUser.id, settings.startDate);
      allRawEntries = [...clockifyData.entries];
    }
  }
} catch (e) {}

// Always add manual entries to the breakdown
const manualEntries = await getManualEntries(user.id);
allRawEntries = [
  ...allRawEntries,
  ...manualEntries
    .filter(e => new Date(e.date) >= new Date(settings.startDate))
    .map(e => ({ date: e.date, durationSeconds: e.durationSeconds }))
];

const grouped = groupEntries(allRawEntries, settings.hasAllowance ? settings.paySchedule : 'monthly');
const adjustments = await getPayoutAdjustments(user.id);

let runningCarryOver = 0;
const monthlyDataRaw = grouped.map(item => {
  const calculatedEarnings = (item.totalSeconds / 3600) * settings.hourlyRate;
  const totalExpected = calculatedEarnings + runningCarryOver;
  
  // If user hasn't set an adjustment, we assume they received the full amount (expected)
  // unless it's the current period (which we might want to keep as 'pending')
  const isSet = adjustments[item.label] !== undefined;
  const actualReceived = isSet ? adjustments[item.label] : totalExpected;
  const carryOver = totalExpected - actualReceived;
  
  const entry = {
    label: item.label,
    rendered: item.totalSeconds / 3600,
    calculated: calculatedEarnings,
    totalExpected,
    actualReceived,
    carryOverIn: runningCarryOver,
    carryOverOut: carryOver,
    isAdjusted: isSet
  };
  
  runningCarryOver = carryOver;
  return entry;
});

const monthlyData = [...monthlyDataRaw].reverse();

const totalEarnings = renderedHours * settings.hourlyRate;
const progressPercent = Math.min(100, (renderedHours / (settings.targetHours || 1)) * 100);

// Calculate Estimated Finish Date
const remainingHours = Math.max(0, settings.targetHours - renderedHours);
let avgHoursPerDay = 8; // Default

if (allRawEntries.length > 0) {
  // Calculate average from last 7 unique days of logs
  const dailyTotals: Record<string, number> = {};
  allRawEntries.forEach(e => {
    dailyTotals[e.date] = (dailyTotals[e.date] || 0) + (e.durationSeconds / 3600);
  });
  const recentDays = Object.values(dailyTotals).slice(-7);
  if (recentDays.length > 0) {
    avgHoursPerDay = recentDays.reduce((a, b) => a + b, 0) / recentDays.length;
    if (avgHoursPerDay < 1) avgHoursPerDay = 8; // Fallback if average is too low
  }
}

const workDaysRemaining = Math.ceil(remainingHours / avgHoursPerDay);
let estimatedFinishDate = new Date();
let daysAdded = 0;
while (daysAdded < workDaysRemaining) {
  estimatedFinishDate.setDate(estimatedFinishDate.getDate() + 1);
  // Skip weekends (0 is Sunday, 6 is Saturday)
  if (estimatedFinishDate.getDay() !== 0 && estimatedFinishDate.getDay() !== 6) {
    daysAdded++;
  }
}

const finishDateStr = estimatedFinishDate.toLocaleDateString('en-US', { 
  month: 'short', 
  day: 'numeric', 
  year: 'numeric' 
});
---

<Layout title="Dashboard">
  <!-- How It Works Modal (Student) -->
  <div id="how-it-works-modal" class="modal-overlay" style="display: none;">
    <div class="modal-content info-modal-content">
      <div class="modal-header-info">
        <div class="info-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
        </div>
        <h3>How OJT Portal Works</h3>
      </div>
      <p class="modal-subtitle">Welcome! Here is a quick guide on how to track your hours and verify your progress.</p>
      
      <div class="guide-steps">
        <div class="guide-step">
          <span class="step-num">1</span>
          <div class="step-details">
            <h4>Connect with Coordinator (Optional)</h4>
            <p>Linking with a coordinator is optional. If your coordinator reaches out, you can easily connect later in <strong>Settings</strong> using their invite code.</p>
          </div>
        </div>
        <div class="guide-step">
          <span class="step-num">2</span>
          <div class="step-details">
            <h4>Track OJT Hours</h4>
            <p>Use the live <strong>Timer</strong> on the dashboard to track real-time activities, or log manual entries in the <strong>Tracker</strong> tab.</p>
          </div>
        </div>
        <div class="guide-step">
          <span class="step-num">3</span>
          <div class="step-details">
            <h4>Upload Documentation</h4>
            <p>Always upload image proof (screenshots of work or activity photos) when adding/editing manual entries to ensure coordinator approval.</p>
          </div>
        </div>
        <div class="guide-step">
          <span class="step-num">4</span>
          <div class="step-details">
            <h4>Monitor Allowances (Optional)</h4>
            <p>If your internship includes a stipend, you can enable and track your pending earnings and payouts in the <strong>Settings</strong> panel.</p>
          </div>
        </div>
      </div>
      
      <div class="modal-actions-single">
        <button type="button" class="btn-onboarding" onclick="document.getElementById('how-it-works-modal').style.display='none'">Got it, let's start!</button>
      </div>
    </div>
  </div>

  <Header user={user} />
  
  <div id="portal-body">
    <Sidebar user={user} activeTab="dashboard" role={settings.role} />
    
    <main id="portal-main">
      <div class="bg-grid" aria-hidden="true"></div>

      {settings.setupComplete === false && (
        <div id="setup-wizard-overlay" class="modal-overlay">
          <div class="setup-card">
            <div class="setup-header">
              <h2>Welcome to <span class="accent">InternFlow</span></h2>
              <p>Let's get your profile set up to start tracking your progress.</p>
            </div>
            
            <form action="/api/settings" method="POST" class="setup-form">
              <input type="hidden" name="setupComplete" value="true" />
              <input type="hidden" name="redirect" value="/dashboard" />
              <input type="hidden" name="inviteCode" id="generated-invite" value="" />
              
              <div class="role-selector">
                <label class="role-option">
                  <input type="radio" name="role" value="student" checked />
                  <div class="role-content">
                    <span class="role-title">I am a Student</span>
                    <span class="role-desc">Track OJT hours and manage allowance.</span>
                  </div>
                </label>
                <label class="role-option">
                  <input type="radio" name="role" value="coordinator" />
                  <div class="role-content">
                    <span class="role-title">I am a Coordinator</span>
                    <span class="role-desc">Manage students and monitor their progress.</span>
                  </div>
                </label>
              </div>

              <div id="student-fields" class="setup-grid">
                <div class="setup-row">
                  <div class="form-group">
                    <label>Coordinator Invite Code (Optional)</label>
                    <input type="text" name="coordinatorInvite" placeholder="Enter 6-char code" class="setup-input" />
                  </div>
                  <div class="form-group">
                    <label>Cooperating Agency / Company</label>
                    <input type="text" name="hostCompany" placeholder="Company Name" class="setup-input" />
                  </div>
                </div>

                <div class="setup-row">
                  <div class="form-group">
                    <label>Internship Program</label>
                    <input type="text" name="program" placeholder="e.g. BS Information Technology" class="setup-input" />
                  </div>
                  <div class="form-group">
                    <label>Supervisor Name</label>
                    <input type="text" name="supervisor" placeholder="Full Name" class="setup-input" />
                  </div>
                </div>

                <div class="setup-row">
                  <div class="form-group">
                    <label>Start Date</label>
                    <input type="date" name="startDate" value={settings.startDate} required />
                  </div>
                  <div class="form-group">
                    <label>Target Hours</label>
                    <input type="number" name="targetHours" value={settings.targetHours} required />
                  </div>
                </div>

                <div class="allowance-section-setup">
                  <div class="form-group mb-0">
                    <label class="check-label-setup">
                      <input type="checkbox" name="hasAllowance" value="true" checked id="allowance-toggle-setup" />
                      <span class="toggle-text">Enable Allowance Tracking</span>
                    </label>
                  </div>
                  
                  <div id="allowance-fields-setup" class="allowance-fields-grid">
                    <div class="setup-row">
                      <div class="form-group">
                        <label>Pay Model</label>
                        <select name="payType" class="setup-select">
                          <option value="hourly">Hourly Rate</option>
                          <option value="daily">Fixed Daily Rate</option>
                        </select>
                      </div>
                      <div class="form-group">
                        <label>Rate (₱)</label>
                        <input type="number" name="hourlyRate" value={settings.hourlyRate} />
                      </div>
                    </div>
                    <div class="form-group">
                      <label>Pay Schedule</label>
                      <select name="paySchedule" class="setup-select">
                        <option value="weekly">Weekly</option>
                        <option value="semi-monthly">Semi-monthly (15/30)</option>
                        <option value="monthly" selected>Monthly</option>
                      </select>
                    </div>
                  </div>
                </div>
              </div>

              <div id="coordinator-fields" style="display: none;">
                <div class="info-note">
                  <p>As a coordinator, you'll manage your students via a custom dashboard and unique invite code.</p>
                </div>
              </div>
              
              <button type="submit" class="btn-setup">Save & Initialize Dashboard</button>
            </form>

            <script is:inline>
              const roleRadios = document.querySelectorAll('input[name="role"]');
              const studentFields = document.getElementById('student-fields');
              const coordinatorFields = document.getElementById('coordinator-fields');
              const inviteInput = document.getElementById('generated-invite');
              const allowanceToggle = document.getElementById('allowance-toggle-setup');
              const allowanceFields = document.getElementById('allowance-fields-setup');

              allowanceToggle?.addEventListener('change', (e) => {
                if (allowanceFields) allowanceFields.style.display = e.target.checked ? 'block' : 'none';
              });

              roleRadios.forEach(radio => {
                radio.addEventListener('change', (e) => {
                  if (e.target.value === 'coordinator') {
                    studentFields.style.display = 'none';
                    coordinatorFields.style.display = 'block';
                    if (!inviteInput.value) {
                      inviteInput.value = Math.random().toString(36).substring(2, 8).toUpperCase();
                    }
                    studentFields.querySelectorAll('input[required]').forEach(i => i.required = false);
                  } else {
                    studentFields.style.display = 'grid';
                    coordinatorFields.style.display = 'none';
                    studentFields.querySelectorAll('input').forEach(i => {
                       if (i.name !== 'coordinatorInvite' && i.name !== 'hasAllowance' && !allowanceFields?.contains(i)) i.required = true;
                    });
                  }
                });
              });

              // Dynamically set redirect target with firstLogin flag depending on selected role
              const setupForm = document.querySelector('.setup-form');
              const redirectInput = setupForm?.querySelector('input[name="redirect"]');
              setupForm?.addEventListener('submit', () => {
                const selectedRole = document.querySelector('input[name="role"]:checked')?.value;
                if (redirectInput) {
                  if (selectedRole === 'coordinator') {
                    redirectInput.value = '/coordinator?firstLogin=true';
                  } else {
                    redirectInput.value = '/dashboard?firstLogin=true';
                  }
                }
              });
            </script>
          </div>
        </div>
      )}



      <div id="dash-content" class="content-center">
        <div class="dashboard-header">
          <div class="header-main">
            <h1>Welcome back, <span class="accent">{user.name}</span></h1>
            <p>Here's your current internship status and progress tracker.</p>
          </div>
          <div class="header-date">
            <span class="date-label">TODAY</span>
            <span class="date-value">{new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
          </div>
        </div>

        <!-- Main Timer Section -->
        <section class={`main-control ${activeTimer ? 'timer-active' : ''}`} data-start={activeTimer?.startTime}>
          <form method="POST" class="control-form" id="timer-main-form">
            <div class="task-input-wrapper">
              <label class="field-label">CURRENT TASK</label>
              <input 
                type="text" 
                name="description" 
                placeholder="Enter what you are working on..." 
                value={activeTimer?.description || ''} 
                autocomplete="off"
                class="main-task-input"
              />
            </div>
            
            <div class="time-display-wrapper">
              {activeTimer && (
                <div class="edit-start-box">
                  <label class="field-label">STARTED AT</label>
                  <input 
                    class="inline-time-input time-mask"
                    maxlength="5"
                    value={new Date(activeTimer.startTime).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', timeZone: 'Asia/Manila' })} 
                    onchange="document.getElementById('action-hidden').value='update-start'; if (typeof this.form.requestSubmit === 'function') { this.form.requestSubmit(); } else { this.form.submit(); }"
                  />
                </div>
              )}
              
              <div class="elapsed-box">
                <label class="field-label">RENDERED TIME</label>
                <span id="live-timer-val" class="live-digits">00:00:00</span>
              </div>

              <input type="hidden" name="action" id="action-hidden" value={activeTimer ? "stop-timer" : "start-timer"} />
              <input type="hidden" name="id" id="id-hidden" />

              <div class="button-box">
                {activeTimer ? (
                  <button type="submit" onclick="document.getElementById('action-hidden').value='stop-timer'" class="btn-primary stop">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="2"/></svg>
                    STOP TASK
                  </button>
                ) : (
                  <button type="submit" onclick="document.getElementById('action-hidden').value='start-timer'" class="btn-primary start">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M5 3l14 9-14 9V3z"/></svg>
                    START TIMER
                  </button>
                )}
              </div>
            </div>
          </form>
        </section>

        <div class="metrics-grid">
          <div class="metrics-column">
            <div class="metric-card">
              <div class="metric-info">
                <span class="metric-label">Hours Rendered</span>
                <div class="metric-value">{formatHours(renderedHours)} <span class="unit">/ {formatHours(settings.targetHours)}</span></div>
              </div>
              <div class="metric-progress">
                <div class="progress-track">
                  <div class={`progress-fill ${progressPercent >= 100 ? 'success' : ''}`} style={`width: ${progressPercent}%`}></div>
                </div>
                <div class="progress-status">
                  <span>{progressPercent >= 100 ? 'Completed' : 'In Progress'}</span>
                  <span class="percent-val">{progressPercent.toFixed(2)}%</span>
                </div>
              </div>
            </div>

            <div class={`metric-card highlight-card ${renderedHours > settings.targetHours ? 'overtime' : ''}`}>
              <div class="metric-info">
                <span class="metric-label">{renderedHours > settings.targetHours ? 'Excess Time' : 'Remaining Time'}</span>
                <div class="metric-value">
                  {renderedHours > settings.targetHours ? '+' : ''}
                  {formatHMS(Math.abs((settings.targetHours * 3600) - (renderedHours * 3600)))}
                </div>
                <span class="metric-subtext">
                  {renderedHours >= settings.targetHours 
                    ? 'Goal reached! Every hour now is extra credit.' 
                    : `Est. Finish: ${finishDateStr}`}
                </span>
              </div>
            </div>
          </div>

          <div class="metric-card company-summary">
            <div class="company-header-mini">
              <div class="company-info-mini">
                <span class="metric-label">Internship Configuration</span>
                <div class="metric-value-mini text-truncate">{settings.hostCompany || 'Not set'}</div>
              </div>
            </div>
            <div class="company-quick-details">
              <div class="quick-row">
                <span class="q-label">Program:</span>
                <span class="q-value">{settings.program || 'Not set'}</span>
              </div>
              <div class="quick-row">
                <span class="q-label">Allowance:</span>
                <span class="q-value">{settings.hasAllowance ? 'Enabled' : 'Disabled'}</span>
              </div>
              {settings.hasAllowance && (
                <>
                  <div class="quick-row">
                    <span class="q-label">Pay Model:</span>
                    <span class="q-value">{settings.payType === 'hourly' ? 'Hourly' : 'Daily'}</span>
                  </div>
                  <div class="quick-row">
                    <span class="q-label">Rate:</span>
                    <span class="q-value">₱{settings.hourlyRate}/{settings.payType === 'hourly' ? 'hr' : 'day'}</span>
                  </div>
                  <div class="quick-row">
                    <span class="q-label">Schedule:</span>
                    <span class="q-value">{settings.paySchedule}</span>
                  </div>
                </>
              )}
            </div>
          </div>
        </div>

        <div class="full-grid">
          <section class="earnings-breakdown">
            <div class="section-header">
              <h2>{settings.hasAllowance ? 'Earnings' : 'Hours'} <span class="accent">Breakdown</span></h2>
              <div class="total-earnings-summary">
                <span class="summary-label">{settings.hasAllowance ? 'Total Estimated:' : 'Total Rendered:'}</span>
                <span class="summary-value">
                  {settings.hasAllowance 
                    ? `₱ ${totalEarnings.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`
                    : `${formatHours(renderedHours)}`}
                </span>
              </div>
            </div>
            <div class="breakdown-list">
              {monthlyData.map(item => (
  <div class="breakdown-item-wrapper">
    <div class="breakdown-item">
      <div class="item-main">
        <span class="item-label">{item.label}</span>
        <div class="item-meta">
          {settings.hasAllowance ? (
            <>
              <span class="item-hours">{formatHours(item.rendered)} rendered</span>
              {item.carryOverIn !== 0 && (
                <span class={`carry-tag ${item.carryOverIn > 0 ? 'plus' : 'minus'}`}>
                  {item.carryOverIn > 0 ? '+' : ''}₱{item.carryOverIn.toLocaleString()} carry-over
                </span>
              )}
            </>
          ) : (
            <span class="item-hours">Internship Hours Logged</span>
          )}
        </div>
      </div>
      {settings.hasAllowance ? (
        <div class="item-values">
          {item.isAdjusted ? (
            <div class="payout-status set">
              <div class="value-group">
                <span class="v-label">Received</span>
                <span class="v-amount accent">₱ {item.actualReceived.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>
              </div>
              <button class="btn-edit-payout" data-label={item.label} data-amount={item.actualReceived.toFixed(2)}>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4L18.5 2.5z"></path></svg>
              </button>
            </div>
          ) : (
            <div class="payout-status pending">
               <div class="value-group">
                <span class="v-label">Expected</span>
                <span class="v-amount">₱ {item.totalExpected.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>
              </div>
              <div class="status-actions">
                <form action="/api/payouts" method="POST" class="inline-form">
                  <input type="hidden" name="periodLabel" value={item.label} />
                  <input type="hidden" name="amountReceived" value={item.totalExpected.toFixed(2)} />
                  <button type="submit" class="btn-received">Received</button>
                </form>
                <button class="btn-edit-payout secondary" data-label={item.label} data-amount={item.totalExpected.toFixed(2)}>Edit</button>
              </div>
            </div>
          )}

          <form action="/api/payouts" method="POST" class="payout-edit-form" style="display: none;">
            <input type="hidden" name="periodLabel" value={item.label} />
            <div class="compact-input-group">
              <span class="v-currency">₱</span>
              <input 
                type="number" 
                name="amountReceived" 
                value={item.actualReceived.toFixed(2)} 
                step="0.01" 
                class="v-amount-input"
              />
              <button type="submit" class="btn-save-inline">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </button>
            </div>
          </form>
        </div>
      ) : (
        <div class="item-values">
          <div class="value-group">
            <span class="v-label">Rendered</span>
            <span class="v-amount">{formatHours(item.rendered)}</span>
          </div>
        </div>
      )}
    </div>
    {settings.hasAllowance && item.carryOverOut !== 0 && (
      <div class="carry-over-line">
        <span class="line-text">
          {item.carryOverOut > 0 ? 'Excess' : 'Shortage'} of ₱{Math.abs(item.carryOverOut).toLocaleString()} added to next period
        </span>
      </div>
    )}
  </div>
))}
              {monthlyData.length === 0 && (
                <div class="empty-breakdown">No logs recorded for the current program period.</div>
              )}
            </div>
          </section>
        </div>
      </div>
      </div>
    </main>
  </div>
</Layout>

<script is:inline>
  const params = new URLSearchParams(window.location.search);
  
  // Show How It Works modal if firstLogin param is true and not seen yet
  const isFirstLogin = params.get('firstLogin') === 'true';
  const hasSeenOnboarding = localStorage.getItem('has_seen_onboarding_student');
  const worksModal = document.getElementById('how-it-works-modal');
  
  if (isFirstLogin && !hasSeenOnboarding) {
    if (worksModal) worksModal.style.display = 'flex';
  }

  // Bind close buttons to dismiss and mark as seen
  const closeBtn = worksModal?.querySelector('.btn-onboarding');
  closeBtn?.addEventListener('click', () => {
    localStorage.setItem('has_seen_onboarding_student', 'true');
    worksModal.style.display = 'none';
  });

  // Clear query parameters
  if (isFirstLogin) {
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }

  const successVal = params.get('success');
  if (successVal) {
    const msg = successVal === 'true' ? 'Dashboard updated' : successVal;
    window.showToast(msg, 'success');
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }
  if (params.get('error')) {
    window.showToast(decodeURIComponent(params.get('error')), 'error');
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }

  // Payout Edit Toggle
  document.querySelectorAll('.btn-edit-payout').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const wrapper = btn.closest('.item-values');
      const statusDiv = wrapper.querySelector('.payout-status');
      const editForm = wrapper.querySelector('.payout-edit-form');
      
      if (statusDiv && editForm) {
        statusDiv.style.display = 'none';
        editForm.style.display = 'flex';
        const input = editForm.querySelector('input[type="number"]');
        input.focus();
        input.select();
      }
    });
  });

  // Live Timer Setup
  let timerInterval = null;
  function initLiveTimer() {
    if (timerInterval) {
      clearInterval(timerInterval);
      timerInterval = null;
    }
    const timerSection = document.querySelector('.main-control');
    const timerVal = document.getElementById('live-timer-val');
    if (timerSection && timerSection.classList.contains('timer-active')) {
      const startTime = new Date(timerSection.dataset.start || '').getTime();
      if (startTime) {
        const tick = () => {
          const diff = Math.max(0, new Date().getTime() - startTime);
          const h = Math.floor(diff / 3600000);
          const m = Math.floor((diff % 3600000) / 60000);
          const s = Math.floor((diff % 60000) / 1000);
          if (timerVal) {
            timerVal.textContent = `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
          }
        };
        tick();
        timerInterval = setInterval(tick, 1000);
      }
    } else if (timerVal) {
      timerVal.textContent = "00:00:00";
    }
  }

  // Initialize timer on load
  initLiveTimer();

  // Handle visual loading state on form submissions
  document.addEventListener('submit', (e) => {
    const form = e.target;
    if (form.dataset.submitting === 'true') return;
    
    const btn = e.submitter || form.querySelector('button[type="submit"]');
    if (!btn) return;
    
    btn.disabled = true;
    btn.style.opacity = '0.7';
    
    let loadingText = 'Loading...';
    if (btn.classList.contains('stop')) {
      loadingText = 'STOPPING TASK...';
    } else if (btn.classList.contains('start')) {
      loadingText = 'STARTING TIMER...';
    } else if (btn.classList.contains('btn-received')) {
      loadingText = 'UPDATING...';
    } else if (btn.classList.contains('btn-save-inline')) {
      loadingText = 'SAVING...';
    } else if (form.classList.contains('setup-form')) {
      loadingText = 'SETTING UP...';
    } else {
      const text = btn.innerText.trim().toUpperCase();
      if (text) {
        loadingText = text + '...';
      }
    }
    
    btn.innerHTML = `
      <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" style="display:inline-block; vertical-align:middle; width:16px; height:16px; animation: spin 1s linear infinite; margin-right: 8px;">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" style="opacity: 0.25;"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" style="opacity: 0.75;"></path>
      </svg>
      ${loadingText}
    `;
    
    if (window.showLoadingSpinner) {
      window.showLoadingSpinner(loadingText);
    }
    
    form.dataset.submitting = 'true';
  });

  // Time Masking Logic
  document.addEventListener('input', (e) => {
    if (e.target.classList.contains('time-mask')) {
      let val = e.target.value.replace(/\D/g, '');
      if (val.length > 4) val = val.slice(0, 4);
      
      // Auto-colon only for 4 digits as you type
      if (val.length === 4) {
        e.target.value = val.slice(0, 2) + ':' + val.slice(2);
      } else {
        e.target.value = val;
      }
    }
  });

  function formatTimeInput(target) {
    let val = target.value.replace(/\D/g, '');
    if (!val) return;
    
    const is24hr = !target.closest('.time-12hr-wrapper');
    
    if (val.length === 1) {
      const num = parseInt(val, 10);
      if (num >= 1 && num <= 9) {
        target.value = '0' + val + ':00';
      } else if (num === 0) {
        target.value = is24hr ? '00:00' : '12:00';
      }
    } else if (val.length === 2) {
      const num = parseInt(val, 10);
      const maxHour = is24hr ? 23 : 12;
      if (num >= 1 && num <= maxHour) {
        target.value = val + ':00';
      } else if (num === 0) {
        target.value = is24hr ? '00:00' : '12:00';
      } else {
        const h = parseInt(val[0], 10);
        let m = parseInt(val[1], 10);
        if (m > 5) m = 5;
        target.value = '0' + h + ':' + m + '0';
      }
    } else if (val.length === 3) {
      target.value = '0' + val[0] + ':' + val.slice(1);
    } else if (val.length === 4) {
      target.value = val.slice(0, 2) + ':' + val.slice(2);
    }
  }

  document.addEventListener('change', (e) => {
    if (e.target.classList.contains('time-mask')) {
      formatTimeInput(e.target);
    }
  }, true);

  document.addEventListener('blur', (e) => {
    if (e.target.classList.contains('time-mask')) {
      formatTimeInput(e.target);
    }
  }, true);

  // Handle backspace
  document.addEventListener('keydown', (e) => {
    if (e.target.classList.contains('time-mask') && e.key === 'Backspace') {
      if (e.target.value.includes(':') && e.target.value.length === 5) {
         // Let normal backspace work
      }
    }
  });
</script>

