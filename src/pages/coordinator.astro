  }
  .section-card:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.1);
  }
  .section-card.highlight {
    border-color: rgba(237, 102, 33, 0.3);
    background: rgba(237, 102, 33, 0.02);
  }
  .section-card.add-card {
    border-style: dashed;
    border-width: 2px;
    background: transparent;
  }
  .section-card h3 {
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 8px 0;
  }
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }
  .card-desc {
    font-size: 12px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
    flex-grow: 1;
  }
  .badge {
    font-size: 10px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 20px;
    background: rgba(237, 102, 33, 0.1);
    color: var(--ntv-orange);
    border: 1px solid rgba(237, 102, 33, 0.2);
    white-space: nowrap;
  }
  .badge.student-count {
    background: rgba(96, 165, 250, 0.1);
    color: #60a5fa;
    border-color: rgba(96, 165, 250, 0.2);
  }
  .copy-invite-btn {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-secondary);
    padding: 6px 8px;
    border-radius: 6px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }
  .copy-invite-btn:hover {
    background: rgba(237, 102, 33, 0.15);
    border-color: rgba(237, 102, 33, 0.4);
    color: var(--ntv-orange);
    transform: scale(1.1);
  }
  
  @media (max-width: 480px) {
    .modal-content { padding: 24px; }
  }
</style>

<script>
  document.querySelectorAll('.copy-invite-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const code = btn.dataset.code || '';
      const message = `Hi! I am your OJT Coordinator. To link with me and let me track your internship progress, please:

1. Go to internship-tracker-self.vercel.app and sign up / log in.
2. Open Settings → paste this invite code: ${code}
3. That's it — I can now monitor your hours and progress.

See you there!`;
      navigator.clipboard.writeText(message)
        .then(() => window.showToast?.('Invite message copied!'))
        .catch(() => window.showToast?.('Copy failed — please copy the code manually.', 'error'));
    });
  });
</script>
