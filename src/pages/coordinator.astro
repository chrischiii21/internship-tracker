  }
  .btn-onboarding:hover {
    transform: translateY(-2px);
    filter: brightness(1.1);
  }

  /* Section grid & card styles */
  .sections-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    margin-top: 16px;
  }
