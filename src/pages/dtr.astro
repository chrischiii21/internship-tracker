---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import { getSession } from "../lib/auth";
import { parse } from "cookie";
import { getClockifyUser, getDailyDTR } from "../lib/clockify";
import { getAppSettings } from "../lib/settings";
import { getManualEntries } from "../lib/entries";
import { supabase } from "../lib/supabase";
import { getStudentProgress } from "../lib/clockify";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const cookies = parse(cookieHeader);
const user = cookies.session ? await getSession(cookies.session) : null;

if (!user) return Astro.redirect("/");

const mySettings = await getAppSettings(user.id);
const targetStudentId = Astro.url.searchParams.get("studentId");
let viewUserId = user.id;

// Coordinator Logic
let students = [];
let sections = [];
let filteredStudents = [];
const selectedSection = Astro.url.searchParams.get("section") || "all";

if (mySettings.role === "coordinator") {
  // Fetch coordinator sections
  const { data: mySections } = await supabase
    .from("coordinator_sections")
    .select("*")
    .eq("coordinator_id", user.id)
    .order("section_name", { ascending: true });
  sections = mySections || [];

  // Fetch all students under coordinator, including section_id
  const { data: myStudents } = await supabase
    .from("student_settings")
    .select("user_id, user_name, section_id")
    .eq("coordinator_id", user.id);
  students = myStudents || [];

  // Apply section filtering
  filteredStudents = students;
  if (selectedSection !== "all") {
    filteredStudents = students.filter(s => s.section_id === selectedSection);
  }

  // Determine current viewUserId based on filtered student list
  if (targetStudentId && students.some((s) => s.user_id === targetStudentId)) {
    const isStudentInFiltered = selectedSection === 'all' || 
      (students.find(s => s.user_id === targetStudentId)?.section_id === selectedSection);

    if (isStudentInFiltered) {
      viewUserId = targetStudentId;
    } else if (filteredStudents.length > 0) {
      viewUserId = filteredStudents[0].user_id;
    }
  } else if (filteredStudents.length > 0) {
    viewUserId = filteredStudents[0].user_id;
  }
}

const settings = await getAppSettings(viewUserId);
const now = new Date();
const currentMonth = now.getMonth() + 1;
const currentYear = now.getFullYear();

const month = parseInt(
  Astro.url.searchParams.get("month") || currentMonth.toString(),
);
const year = parseInt(
  Astro.url.searchParams.get("year") || currentYear.toString(),
);

const isClockifySet = !!(
  import.meta.env.CLOCKIFY_API_KEY && import.meta.env.CLOCKIFY_WORKSPACE_ID
);

let dtrData: any = {};
let totalMonthSeconds = 0;

// Unified Logic: Combined Manual + Clockify
const manual = await getManualEntries(viewUserId);
const manualFiltered = manual.filter((e) => {
  const d = new Date(e.startFull || `${e.date}T${e.startTime}+08:00`);
  return d.getMonth() + 1 === month && d.getFullYear() === year;
});

let clockifyId = "";
if (isClockifySet && settings.clockifyEnabled !== false) {
  try {
    const clockifyUser = await getClockifyUser(settings.userEmail || "");
    if (clockifyUser) clockifyId = clockifyUser.id;
  } catch (e) {}
}

const result = await getDailyDTR(clockifyId, month, year, manualFiltered);
dtrData = result.days.reduce((acc, d) => {
  acc[d.day] = d;
  return acc;
}, {} as any);
totalMonthSeconds = result.totalMonthlyHours * 3600;

// Calculate overall progress for the percentage display
const overallRenderedHours = settings.isEmployee ? 0 : await getStudentProgress(viewUserId, settings.userEmail || "", settings.startDate);
const progressPercent = settings.isEmployee ? "0" : Math.min(100, (overallRenderedHours / (settings.targetHours || 1)) * 100).toFixed(1);

const formatDuration = (seconds: number) => {
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  return `${String(h).padStart(2, "0")}:${String(m).padStart(2, "0")}`;
};

const monthName = new Date(year, month - 1)
  .toLocaleDateString("en-US", { month: "long", timeZone: "Asia/Manila" })
  .toUpperCase();

const needsUpdate = settings.isEmployee 
  ? (!settings.hostCompany || settings.hostCompany.includes("Enter"))
  : ((settings.program?.includes("Enter") ?? true) ||
     (settings.hostCompany?.includes("Enter") ?? true) ||
     (settings.supervisor?.includes("Enter") ?? true));
---

<Layout title="DTR Sheet">
  <Header user={user} />

  <div id="portal-body">
    <Sidebar user={user} activeTab="dtr" role={mySettings.role} />

    <main id="portal-main">
      <div class="bg-grid" aria-hidden="true"></div>

      {
        needsUpdate && (
          <div class="no-print settings-alert">
            <div class="alert-content">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0zM12 9v4M12 17h.01" />
              </svg>
              <span>
                Your DTR details are incomplete. Please update them in the
                settings.
              </span>
            </div>
            <a href="/settings" class="alert-link">
              Go to Settings
            </a>
          </div>
        )
      }

      <div class="no-print actions-bar">
        <div class="month-selector">
          {
            mySettings.role === "coordinator" && (
              <>
                <select
                  id="section-selector"
                  class="dtr-select"
                >
                  <option value="all" selected={selectedSection === 'all'}>All Sections</option>
                  {sections.map((sec) => (
                    <option value={sec.id} selected={sec.id === selectedSection}>
                      {sec.section_name}
                    </option>
                  ))}
                </select>

                <select
                  id="student-selector"
                  class="dtr-select"
                  disabled={filteredStudents.length === 0}
                >
                  {filteredStudents.length > 0 ? (
                    filteredStudents.map((s) => (
                      <option value={s.user_id} selected={s.user_id === viewUserId}>
                        {s.user_name}
                      </option>
                    ))
                  ) : (
                    <option value="">No students in section</option>
                  )}
                </select>
              </>
            )
          }
          <select id="month-selector" class="dtr-select">
            {
              Array.from({ length: 12 }).map((_, i) => (
                <option value={i + 1} selected={month === i + 1}>
                  {new Date(0, i).toLocaleString("en-US", { month: "long" })}
                </option>
              ))
            }
          </select>
          <select id="year-selector" class="dtr-select">
            {
              [2024, 2025, 2026].map((y) => (
                <option value={y} selected={year === y}>
                  {y}
                </option>
              ))
            }
          </select>
        </div>
        <div class="actions-group">
          <button onclick="window.print()" class="print-btn">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path
                d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"
              ></path><rect x="6" y="14" width="12" height="8"></rect>
            </svg>
            Print DTR
          </button>
          <button
            id="download-pdf-btn"
            class="download-btn"
            data-filename={`DTR_${settings.userName?.replace(/\s+/g, "_") || (settings.isEmployee ? "Employee" : "Student")}_${monthName}_${year}.pdf`}
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"></path>
            </svg>
            Download PDF
          </button>
        </div>
      </div>

      <div class="dtr-scroll-wrapper content-center">
        <div class="dtr-container" id="dtr-sheet">
          <header class="dtr-header">
            <div class="dtr-title">{settings.isEmployee ? "DAILY TIME RECORD" : "OJT DAILY TIME RECORD"}</div>

            <div class="dtr-info-grid">
              <div class="info-item">
                <span class="label">{settings.isEmployee ? "Employee Name:" : "OJT Student:"}</span>
                <span class="value underline">{settings.userName}</span>
              </div>
              {!settings.isEmployee && (
                <div class="info-item">
                  <span class="label">Program:</span>
                  <span class="value underline">{settings.program}</span>
                </div>
              )}
              <div class="info-item">
                <span class="label">{settings.isEmployee ? "Employer / Company:" : "Company:"}</span>
                <span class="value underline">{settings.hostCompany}</span>
              </div>
              <div class="info-item">
                <span class="label">Period:</span>
                <span class="value underline">{monthName} {year}</span>
              </div>
              {!settings.isEmployee && (
                <div class="info-item">
                  <span class="label">Supervisor:</span>
                  <span class="value underline">{settings.supervisor}</span>
                </div>
              )}
              <div class="info-item highlight">
                <span class="label">Total Hours:</span>
                <span class="value">{formatDuration(totalMonthSeconds)}</span>
              </div>
            </div>
          </header>

          <table class="dtr-table">
            <thead>
              <tr>
                <th rowspan="2">Date</th>
                <th colspan="2">AM</th>
                <th colspan="2">PM</th>
                <th rowspan="2">Total Hrs</th>
              </tr>
              <tr>
                <th>In</th>
                <th>Out</th>
                <th>In</th>
                <th>Out</th>
              </tr>
            </thead>
            <tbody>
              {
                Object.entries(dtrData).map(([day, data]: [string, any]) => (
                  <tr class={data.totalSeconds === 0 ? "weekend-row" : ""}>
                    <td class="date-col">{day}</td>
                    <td>{data.amIn}</td>
                    <td>{data.amOut}</td>
                    <td>{data.pmIn}</td>
                    <td>{data.pmOut}</td>
                    <td class="total-col">
                      {data.totalSeconds > 0
                        ? formatDuration(data.totalSeconds)
                        : ""}
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>

          <footer class="dtr-footer">
            <div class="certification">
              {settings.isEmployee ? "Employee Certification:" : "Student Certification:"} I certify that I rendered the above
              service.
            </div>
            <div class="sig-lines">
              <div class="sig-group">
                <span class="sig-label">Signature:</span>
                <div class="sig-underline"></div>
              </div>
              <div class="sig-group">
                <span class="sig-label">Date:</span>
                <div class="sig-underline"></div>
              </div>
            </div>

            <div class="approval">VERIFIED & APPROVED:</div>
            <div class="sig-lines">
              <div class="sig-group {settings.isEmployee ? '' : 'full'}">
                <span class="sig-label">{settings.isEmployee ? "Supervisor / Manager Signature:" : "Supervisor Signature:"}</span>
                <div class="sig-underline"></div>
              </div>
              <div class="sig-group">
                <span class="sig-label">Date:</span>
                <div class="sig-underline"></div>
              </div>
              {!settings.isEmployee && (
                <div class="sig-group">
                  <span class="sig-label">Position:</span>
                  <span class="value">{settings.supervisorPosition}</span>
                </div>
              )}
            </div>
          </footer>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  import html2pdf from 'html2pdf.js/dist/html2pdf.min.js';

  const secSel = document.getElementById("section-selector");
  const sSel = document.getElementById("student-selector");
  const mSel = document.getElementById("month-selector");
  const ySel = document.getElementById("year-selector");

  const update = (e) => {
    let url = `/dtr?month=${mSel.value}&year=${ySel.value}`;
    if (secSel?.value) url += `&section=${secSel.value}`;
    
    // Only pass studentId if the change didn't trigger from the section selector itself
    if (e?.target !== secSel && sSel?.value) {
      url += `&studentId=${sSel.value}`;
    }
    window.location.href = url;
  };

  secSel?.addEventListener("change", update);
  sSel?.addEventListener("change", update);
  mSel?.addEventListener("change", update);
  ySel?.addEventListener("change", update);

  const params = new URLSearchParams(window.location.search);
  const successVal = params.get('success');
  if (successVal) {
    const msg = successVal === 'true' ? 'DTR updated successfully' : successVal;
    window.showToast(msg, 'success');
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }
  if (params.get('error')) {
    window.showToast(decodeURIComponent(params.get('error')), 'error');
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }

  // PDF Download Handling
  const downloadBtn = document.getElementById("download-pdf-btn");
  downloadBtn?.addEventListener("click", () => {
    if (window.showToast) {
      window.showToast("Generating PDF, please wait...", "info");
    }

    const element = document.getElementById("dtr-sheet");
    const filename = downloadBtn.getAttribute("data-filename") || "DTR_Sheet.pdf";

    const opt = {
      margin:       0,
      filename:     filename,
      image:        { type: 'jpeg', quality: 0.98 },
      html2canvas:  { scale: 2, useCORS: true, logging: false },
      jsPDF:        { unit: 'in', format: 'letter', orientation: 'portrait' }
    };

    if (html2pdf) {
      html2pdf()
        .set(opt)
        .from(element)
        .save()
        .then(() => {
          if (window.showToast) {
            window.showToast("PDF downloaded successfully!", "success");
          }
        })
        .catch((err) => {
          console.error("PDF generation failed:", err);
          if (window.showToast) {
            window.showToast("Failed to generate PDF. Please try again.", "error");
          }
        });
    } else {
      if (window.showToast) {
        window.showToast("PDF generator library is not loaded. Please try again.", "error");
      }
    }
  });
</script>

<style>
  #portal-body {
    display: flex;
    min-height: 100vh;
    padding-top: 56px;
  }
  #portal-main {
    margin-left: 220px;
    flex: 1;
    padding: 40px;
    position: relative;
  }
  .bg-grid {
    position: fixed;
    inset: 0;
    background-image: linear-gradient(
        rgba(237, 102, 33, 0.04) 1px,
        transparent 1px
      ),
      linear-gradient(90deg, rgba(237, 102, 33, 0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }

  .settings-alert {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(251, 191, 36, 0.1);
    border: 1px solid rgba(251, 191, 36, 0.3);
    border-radius: 10px;
    padding: 12px 20px;
    margin-bottom: 24px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }
  .alert-content {
    display: flex;
    align-items: center;
    gap: 12px;
    color: #fbbf24;
    font-size: 14px;
    font-weight: 500;
  }
  .alert-link {
    color: #fbbf24;
    text-decoration: underline;
    font-size: 13px;
    font-weight: 700;
    transition: all 0.2s;
  }
  .alert-link:hover {
    color: white;
  }

  .actions-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 28px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-subtle);
    padding: 12px 16px;
    border-radius: 14px;
  }
  .month-selector {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: nowrap;
    flex: 1;
    min-width: 0;
  }
  .dtr-select {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    padding: 8px 10px;
    border-radius: 8px;
    outline: none;
    font-size: 13px;
    font-weight: 500;
    transition: 0.2s;
    cursor: pointer;
    min-width: 0;
    flex-shrink: 1;
  }
  .dtr-select:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(237, 102, 33, 0.3);
  }
  .dtr-select option {
    background: #111827;
    color: white;
  }
  .actions-group {
    display: flex;
    gap: 12px;
  }
  .print-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    padding: 10px 18px;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: 0.2s;
  }
  .print-btn:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-1px);
  }
  .download-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--ntv-gradient);
    color: white;
    border: none;
    padding: 10px 18px;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: 0.2s;
  }
  .download-btn:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  .dtr-scroll-wrapper {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    padding: 40px 20px;
    background: rgba(0, 0, 0, 0.2);
    display: flex;
    justify-content: flex-start;
  }
  @media (min-width: 860px) {
    .dtr-scroll-wrapper {
      justify-content: center;
    }
  }

  .dtr-container {
    background: white;
    color: black;
    padding: 0.1in 0.4in;
    width: 8.5in;
    height: 11in;
    margin: 0 auto;
    font-family: Arial, sans-serif;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    border-radius: 2px;
    display: flex;
    flex-direction: column;
  }

  .dtr-title {
    text-align: center;
    font-size: 18px;
    font-weight: 700;
    background: #d1d5db;
    padding: 8px;
    border: 3px solid #9ca3af;
    border-bottom: none;
  }
  .dtr-info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 3px solid #9ca3af;
    border-top: none;
    background: #f3f4f6;
  }
  .info-item {
    padding: 6px 12px;
    border-right: 1px solid #9ca3af;
    border-bottom: 2px solid #9ca3af;
    font-size: 12px;
    display: flex;
    gap: 6px;
  }
  .info-item:nth-child(even) {
    border-right: none;
  }
  .info-item.highlight {
    background: #e5e7eb;
    font-weight: 700;
  }
  .label {
    font-weight: 600;
    width: 100px;
  }
  .underline {
    text-decoration: underline;
  }

  .dtr-table {
    width: 100%;
    border-collapse: collapse;
    border: 3px solid #9ca3af;
    margin-top: -3px;
    flex-grow: 1;
  }
  .dtr-table th {
    background: #d1d5db;
    border: 2px solid #9ca3af;
    padding: 6px;
    font-size: 11px;
    font-weight: 700;
    text-align: center;
  }
  .dtr-table td {
    border: 1px solid #9ca3af;
    padding: 2px 8px;
    font-size: 11px;
    height: 17px;
    text-align: center;
  }
  .date-col {
    font-weight: 700;
    background: #f9fafb;
    width: 50px;
  }
  .total-col {
    font-weight: 700;
    background: #f9fafb;
  }
  .weekend-row {
    background: #fef2f2;
  }

  .dtr-footer {
    margin-top: auto;
    padding-top: 15px;
    font-size: 11px;
  }
  .certification {
    font-weight: 700;
    margin-bottom: 10px;
    font-size: 12px;
  }
  .sig-lines {
    display: flex;
    gap: 30px;
    align-items: flex-end;
    margin-bottom: 10px;
  }
  .sig-group {
    display: flex;
    align-items: flex-end;
    gap: 8px;
  }
  .sig-group.full {
    flex: 1;
  }
  .sig-underline {
    border-bottom: 2px solid black;
    min-width: 140px;
    height: 16px;
  }
  .sig-label {
    font-weight: 700;
    white-space: nowrap;
  }
  .approval {
    font-weight: 700;
    margin-top: 15px;
    margin-bottom: 10px;
    font-size: 12px;
  }

  @media print {
    @page {
      margin: 0;
      size: letter portrait;
    }

    body { 
      margin: 0; 
      padding: 0; 
      background: white !important;
      display: flex !important;
      justify-content: center;
      align-items: flex-start;
    }
    
    #header,
    #sidebar,
    .no-print,
    .bg-grid {
      display: none !important;
    }

    #portal-body, #portal-main, .dtr-scroll-wrapper {
      display: block !important;
      margin: 0 !important;
      padding: 0 !important;
      width: 100% !important;
      background: white !important;
    }
    
    .dtr-container {
      margin: 0 auto !important;
      width: 8.5in !important;
      height: 11in !important;
      box-shadow: none !important;
      border: none !important;
      padding: 0.1in 0.4in !important;
    }

    .dtr-title {
      padding: 8px;
      font-size: 18px;
      border-width: 3px;
    }
    .dtr-info-grid {
      border-width: 3px;
    }
    .info-item {
      padding: 6px 12px;
      font-size: 11px;
      border-bottom-width: 2px;
    }

    .dtr-table {
      border-width: 3px;
      margin-top: -3px;
      flex-grow: 1;
    }
    .dtr-table th {
      padding: 4px;
      font-size: 10px;
      border-width: 2px;
    }
    .dtr-table td {
    }

    .dtr-footer {
      margin-top: auto;
      padding-top: 15px;
      font-size: 11px;
    }
    .certification {
      margin-bottom: 10px;
      font-size: 12px;
    }
    .sig-lines {
      gap: 30px;
      margin-bottom: 10px;
    }
    .sig-underline {
      min-width: 140px;
      height: 16px;
      border-bottom: 2px solid #000;
    }
    .approval {
      margin-top: 15px;
      margin-bottom: 10px;
      font-size: 12px;
    }
  }

  @media (max-width: 768px) {
    .actions-bar {
      flex-direction: column !important;
      align-items: stretch !important;
      gap: 12px !important;
      padding: 12px !important;
    }
    .month-selector {
      flex-direction: column !important;
      align-items: stretch !important;
      width: 100% !important;
      gap: 8px !important;
    }
    .month-selector .dtr-select {
      width: 100% !important;
