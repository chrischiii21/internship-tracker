---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import { getSession } from '../lib/auth';
import { parse } from 'cookie';
import { getAppSettings } from '../lib/settings';
import { formatHours } from '../lib/utils';

const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookies = parse(cookieHeader);
const user = cookies.session ? await getSession(cookies.session) : null;

if (!user) {
  return Astro.redirect('/');
}

const settings = await getAppSettings(user.id);
const isClockifySet = !!(import.meta.env.CLOCKIFY_API_KEY && import.meta.env.CLOCKIFY_WORKSPACE_ID);
const success = Astro.url.searchParams.get('success') === 'true';

// Fetch coordinator name if linked
let coordinatorName = '';
if (settings.coordinatorId) {
  const { supabase } = await import('../lib/supabase');
  const { data: coord } = await supabase
    .from('coordinator_settings')
    .select('user_name')
    .eq('user_id', settings.coordinatorId)
    .single();
  if (coord) coordinatorName = coord.user_name;
}

const isLinked = settings.role === 'student' && !!settings.coordinatorId;
---
<Layout>
  <Header user={user} />

  <div id="portal-body">
    <Sidebar user={user} activeTab="settings" role={settings.role} />

    <main id="portal-main">
      <div class="bg-grid" aria-hidden="true"></div>
      <div class="bg-glow" aria-hidden="true"></div>

      <div id="settings-content" class="content-center">
        <div class="page-header">
          <h1>Settings</h1>
          <p>Manage your account preferences and integration settings.</p>
        </div>

        <div class="settings-sections">
          <!-- Student Specific Sections -->
          {settings.role === 'student' && (
            <>
              <section class="settings-card">
                <h2 class="card-title">Internship Configuration</h2>
                <form action="/api/settings" method="POST" class="settings-form">
                  <input type="hidden" name="setupComplete" value="true" />
                  <input type="hidden" name="redirect" value="/settings" />
                  
                  <div class="form-row">
                    <div class="form-group">
                      <label for="program">Program / Course</label>
                      <input type="text" id="program" name="program" value={settings.program} placeholder="Enter your program" required />
                    </div>
                  </div>
                  <div class="form-row">
                    <div class="form-group">
                      <label for="hostCompany">Host Training Establishment (Company)</label>
                      <input type="text" id="hostCompany" name="hostCompany" value={settings.hostCompany} placeholder="Enter company name" required />
                    </div>
                  </div>
                  <div class="form-row split">
                    <div class="form-group">
                      <label for="supervisor">Supervisor Name</label>
                      <input type="text" id="supervisor" name="supervisor" value={settings.supervisor} placeholder="Enter supervisor name" required />
                    </div>
                    <div class="form-group">
                      <label for="supervisorPosition">Supervisor Position</label>
                      <input type="text" id="supervisorPosition" name="supervisorPosition" value={settings.supervisorPosition} placeholder="Enter position" required />
                    </div>
                  </div>

                  <div class="form-row split">
                    <div class="form-group">
                      <label for="startDate">Program Start Date</label>
                      <input type="date" id="startDate" name="startDate" value={settings.startDate} required />
                    </div>
                    <div class="form-group">
                      <label for="targetHours">Target Hours</label>
                      <div class="input-wrapper">
                        <input type="number" id="targetHours" name="targetHours" value={settings.targetHours} step="0.5" required />
                        <span class="input-suffix">hrs</span>
                      </div>
                    </div>
                  </div>

                  <div class="allowance-header">
                    <label class="check-label">
                      <input type="checkbox" name="hasAllowance" value="true" checked={settings.hasAllowance} id="allowance-toggle-settings" />
                      <span class="toggle-text">Enable Allowance Tracking</span>
                    </label>
                  </div>

                  <div id="allowance-fields-settings" style={settings.hasAllowance ? "" : "display: none;"}>
                    <div class="form-row split">
                      <div class="form-group">
                        <label for="payType">Pay Model</label>
                        <select name="payType" id="payType" class="settings-select">
                          <option value="hourly" selected={settings.payType === 'hourly'}>Hourly Rate</option>
                          <option value="daily" selected={settings.payType === 'daily'}>Fixed Daily Rate</option>
                        </select>
                      </div>
                      <div class="form-group">
                        <label for="hourlyRate">Rate (₱)</label>
                        <div class="input-wrapper">
                          <span class="input-prefix">₱</span>
                          <input type="number" id="hourlyRate" name="hourlyRate" value={settings.hourlyRate} step="0.5" required />
                        </div>
                      </div>
                    </div>

                    <div class="form-row">
                      <div class="form-group">
                        <label for="paySchedule">Pay Schedule</label>
                        <select name="paySchedule" id="paySchedule" class="settings-select">
                          <option value="weekly" selected={settings.paySchedule === 'weekly'}>Every Week</option>
                          <option value="semi-monthly" selected={settings.paySchedule === 'semi-monthly'}>Semi-monthly (15th/30th)</option>
                          <option value="monthly" selected={settings.paySchedule === 'monthly'}>Monthly</option>
                        </select>
                      </div>
                    </div>
                  </div>

                  <button type="submit" class="save-btn">Update Configuration</button>
                </form>

                <script is:inline>
                  document.getElementById('allowance-toggle-settings')?.addEventListener('change', (e) => {
                    const fields = document.getElementById('allowance-fields-settings');
                    if (fields) fields.style.display = e.target.checked ? 'block' : 'none';
                  });
                </script>
              </section>

              <section class="settings-card">
                <h2 class="card-title">Coordinator Connection</h2>
                
                {settings.coordinatorId ? (
                  <form action="/api/settings" method="POST" class="settings-form">
                    <input type="hidden" name="unlink" value="true" />
                    <input type="hidden" name="redirect" value="/settings" />
                    
                    <div class="linked-info">
                      <div class="link-status">
                        <div class="status-dot pulse"></div>
                        <span>Linked to <strong>{coordinatorName}</strong></span>
                      </div>
                      <p class="hint">Your coordinator can now view your progress and DTR logs.</p>
                      
                      <button type="button" id="open-coordinator-unlink-modal" class="unlink-btn mt-16">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg>
                        Unlink from Coordinator
                      </button>
                    </div>
                  </form>
                ) : (
                  <form action="/api/settings" method="POST" class="settings-form">
                    <input type="hidden" name="setupComplete" value="true" />
                    <input type="hidden" name="redirect" value="/settings" />
                    
                    <div class="unlinked-info">
                      <div class="link-status unlinked">
                        <div class="status-dot gray"></div>
                        <span>Not linked to a coordinator</span>
                      </div>
                    </div>

                    <div class="form-group mt-16">
                      <label for="coordinatorInvite">Link via Invite Code</label>
                      <div class="input-with-btn">
                        <input type="text" id="coordinatorInvite" name="coordinatorInvite" placeholder="Enter 6-digit code" required />
                        <button type="submit" class="apply-btn">Link</button>
                      </div>
                      <p class="form-hint">Paste the code given by your OJT Coordinator to sync your progress.</p>
                    </div>
                  </form>
                )}
              </section>
            </>
          )}

          <!-- Common Sections -->
          <section class="settings-card">
            <h2 class="card-title">Profile Information</h2>
            <div class="profile-preview">
              {user.picture && <img src={user.picture} alt="" class="profile-img" />}
              <div class="profile-details">
                <div class="detail-group">
                  <label>Full Name</label>
                  <div class="read-only-box">{user.name}</div>
                </div>
                <div class="detail-group">
                  <label>Email Address</label>
                  <div class="read-only-box">{user.email}</div>
                </div>
              </div>
            </div>
          </section>

          <!-- Coordinator Invite Code (Only for Coordinators) -->
          {settings.role === 'coordinator' && (
            <section class="settings-card">
              <h2 class="card-title">Coordinator Settings</h2>
              <div class="detail-group">
                <label>Your Invite Code</label>
                <div class="read-only-box" style="font-family: 'JetBrains Mono', monospace; font-size: 20px; font-weight: 700; color: var(--ntv-orange);">
                  {settings.inviteCode}
                </div>
                <p class="form-hint mt-8">Students can join your roster using this code during their setup.</p>
              </div>
            </section>
          )}

          <!-- Integration Section (Students Only) -->
          {settings.role === 'student' && (
            <section class="settings-card">
              <h2 class="card-title">Clockify Integration</h2>
              <div class="integration-status">
                <div class={`status-badge ${isClockifySet && settings.clockifyEnabled ? 'connected' : 'disconnected'}`}>
                  {isClockifySet && settings.clockifyEnabled ? 'Connected' : (settings.clockifyEnabled ? 'Missing Credentials' : 'Disabled / Unlinked')}
                </div>
                <p class="status-desc">
                  {isClockifySet && settings.clockifyEnabled
                    ? 'Your system is currently syncing with Clockify using the environment variables provided.' 
                    : (settings.clockifyEnabled 
                        ? 'Update your .env file with CLOCKIFY_API_KEY and CLOCKIFY_WORKSPACE_ID to enable syncing.'
                        : 'Clockify integration is disabled. Your records will be based on manual logs.')}
                </p>
              </div>
              
              {isClockifySet && settings.clockifyEnabled ? (
                <button type="button" id="open-clockify-modal" class="unlink-btn">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg>
                  Unlink Clockify
                </button>
              ) : (
                isClockifySet && (
                  <form action="/api/settings" method="POST">
                    <input type="hidden" name="linkClockify" value="true" />
                    <input type="hidden" name="redirect" value="/settings" />
                    <button type="submit" class="save-btn">Re-link Clockify</button>
                  </form>
                )
              )}

              <div class="config-help mt-16">
                <div class="help-item">
                  <span class="help-label">Sync Status</span>
                  <span class="help-value">{settings.clockifyEnabled ? 'Active' : 'Paused'}</span>
                </div>
                <div class="help-item">
                  <span class="help-label">Target Hours</span>
                  <span class="help-value">{formatHours(settings.targetHours)}</span>
                </div>
              </div>
            </section>
          )}

          <!-- Danger Zone -->
          <section class="settings-card danger">
            <h2 class="card-title">Danger Zone</h2>
            <div class="danger-item">
              <div class="danger-info">
                <h3>Sign Out Everywhere</h3>
                <p>Log out of all devices and end your current session.</p>
              </div>
              <button type="button" id="settings-logout-btn" class="danger-btn outline">Sign Out</button>
            </div>

            <div class="danger-item mt-24">
              <div class="danger-info">
                <h3>Delete Account</h3>
                <p>Permanently remove your profile and all your data. This action is irreversible.</p>
              </div>
              <button type="button" id="open-delete-modal" class="danger-btn solid">Delete My Account</button>
            </div>
          </section>
        </div>
      </div>
      
      <!-- CLOCKIFY UNLINK MODAL -->
      <div id="clockify-modal" class="modal-overlay">
        <div class="modal-content">
          <div class="modal-header-danger">
            <div class="warning-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0zM12 9v4M12 17h.01"/></svg>
            </div>
            <h2>Unlink Clockify?</h2>
          </div>
          <p class="modal-desc">Are you sure you want to disconnect Clockify? Future logs will rely entirely on manual entries. Your existing synced logs will remain visible but will no longer update from Clockify.</p>
          <div class="modal-actions">
            <form action="/api/settings" method="POST">
              <input type="hidden" name="unlinkClockify" value="true" />
              <input type="hidden" name="redirect" value="/settings" />
              <button type="submit" class="btn-confirm-delete">Yes, Unlink Now</button>
            </form>
            <button type="button" id="close-clockify-modal" class="btn-cancel">Cancel</button>
          </div>
        </div>
      </div>

      <!-- COORDINATOR UNLINK MODAL -->
      <div id="coordinator-unlink-modal" class="modal-overlay">
        <div class="modal-content">
          <div class="modal-header-danger">
            <div class="warning-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0zM12 9v4M12 17h.01"/></svg>
            </div>
            <h2>Unlink Coordinator?</h2>
          </div>
          <p class="modal-desc">Are you sure you want to unlink from **{coordinatorName}**? They will no longer be able to view your progress or verify your logs.</p>
          <div class="modal-actions">
            <form action="/api/settings" method="POST">
              <input type="hidden" name="unlink" value="true" />
              <input type="hidden" name="redirect" value="/settings" />
              <button type="submit" class="btn-confirm-delete">Yes, Unlink Now</button>
            </form>
            <button type="button" id="close-coordinator-unlink-modal" class="btn-cancel">Cancel</button>
          </div>
        </div>
      </div>

      <!-- DELETE MODAL -->
      <div id="delete-modal" class="modal-overlay">
        <div class="modal-content">
          <div class="modal-header-danger">
            <div class="warning-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0zM12 9v4M12 17h.01"/></svg>
            </div>
            <h2>Delete your account?</h2>
          </div>
          <p class="modal-desc">This will permanently delete your profile, all settings, and **ALL your records**. This action cannot be undone.</p>
          <div class="modal-actions">
            <button type="button" id="close-delete-modal" class="btn-cancel">Cancel, Keep Data</button>
            <form action="/api/auth/delete-account" method="POST">
              <button type="submit" class="btn-confirm-delete">Yes, Delete Everything</button>
            </form>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script define:vars={{ isLinked }}>
  const deleteModal = document.getElementById('delete-modal');
  const openBtn = document.getElementById('open-delete-modal');
  const closeBtn = document.getElementById('close-delete-modal');

  openBtn?.addEventListener('click', () => {
    if (isLinked) {
      window.showToast('You must unlink from your coordinator first before deleting your account.', 'error');
      return;
    }
    deleteModal?.classList.add('active');
    document.body.style.overflow = 'hidden';
  });

  const closeModal = () => {
    deleteModal?.classList.remove('active');
    document.body.style.overflow = '';
  };

  closeBtn?.addEventListener('click', closeModal);
  deleteModal?.addEventListener('click', (e) => {
    if (e.target === deleteModal) closeModal();
  });

  // Clockify Unlink Modal
  const clockifyModal = document.getElementById('clockify-modal');
  const openClockifyBtn = document.getElementById('open-clockify-modal');
  const closeClockifyBtn = document.getElementById('close-clockify-modal');

  openClockifyBtn?.addEventListener('click', () => {
    clockifyModal?.classList.add('active');
    document.body.style.overflow = 'hidden';
  });

  const closeClockify = () => {
    clockifyModal?.classList.remove('active');
    document.body.style.overflow = '';
  };

  closeClockifyBtn?.addEventListener('click', closeClockify);
  clockifyModal?.addEventListener('click', (e) => {
    if (e.target === clockifyModal) closeClockify();
  });

  // Coordinator Unlink Modal
  const coordModal = document.getElementById('coordinator-unlink-modal');
  const openCoordBtn = document.getElementById('open-coordinator-unlink-modal');
  const closeCoordBtn = document.getElementById('close-coordinator-unlink-modal');

  openCoordBtn?.addEventListener('click', () => {
    coordModal?.classList.add('active');
    document.body.style.overflow = 'hidden';
  });

  const closeCoord = () => {
    coordModal?.classList.remove('active');
    document.body.style.overflow = '';
  };

  closeCoordBtn?.addEventListener('click', closeCoord);
  coordModal?.addEventListener('click', (e) => {
    if (e.target === coordModal) closeCoord();
  });

  // Link settings logout button to the shared modal in Header
  document.getElementById('settings-logout-btn')?.addEventListener('click', () => {
    const logoutModal = document.getElementById('logout-modal');
    if (logoutModal) {
      logoutModal.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
  });

  // Check for success or error in URL
  const params = new URLSearchParams(window.location.search);
  const successVal = params.get('success');
  if (successVal) {
    const msg = successVal === 'true' ? 'Settings updated successfully!' : successVal;
    window.showToast(msg, 'success');
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }
  if (params.get('error')) {
    window.showToast(decodeURIComponent(params.get('error')), 'error');
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }
</script>

<style>
  #portal-body { display: flex; min-height: 100vh; padding-top: 56px; }
  #portal-main { margin-left: 220px; flex: 1; min-height: calc(100vh - 56px); position: relative; padding: 40px 40px; }
  .bg-grid { position: fixed; inset: 0; background-image: linear-gradient(rgba(237, 102, 33, .04) 1px, transparent 1px), linear-gradient(90deg, rgba(237, 102, 33, .04) 1px, transparent 1px); background-size: 40px 40px; pointer-events: none; z-index: 0; }
  .bg-glow { position: fixed; top: 10%; left: 80%; transform: translateX(-50%); width: 400px; height: 400px; background: radial-gradient(ellipse, rgba(237, 102, 33, 0.05) 0%, transparent 70%); pointer-events: none; z-index: 0; }
  
  #settings-content { position: relative; z-index: 1; max-width: 800px; animation: cin .5s cubic-bezier(.16,1,.3,1) both; }
  @keyframes cin { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }

  .page-header { margin-bottom: 32px; }
  .page-header h1 { font-size: 28px; font-weight: 700; color: var(--text-primary); margin-bottom: 6px; }
  .page-header p { font-size: 14px; color: var(--text-secondary); }

  .settings-sections { display: flex; flex-direction: column; gap: 24px; }
  .settings-card { 
    background: var(--card-bg); 
    border: 1px solid var(--border-subtle); 
    border-radius: 16px; 
    padding: 28px;
  }
  .card-title { font-size: 16px; font-weight: 600; color: var(--ntv-orange); margin-bottom: 24px; }

  .profile-preview { display: flex; gap: 24px; align-items: flex-start; }
  .profile-img { width: 80px; height: 80px; border-radius: 50%; border: 3px solid rgba(237, 102, 33, 0.3); }
  .profile-details { flex: 1; display: flex; flex-direction: column; gap: 16px; }
  
  .detail-group label { display: block; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--text-secondary); margin-bottom: 6px; }
  .read-only-box { 
    padding: 12px 16px; background: rgba(255,255,255,.04); border: 1px solid var(--border-subtle); 
    border-radius: 8px; color: var(--text-primary); font-size: 14px; 
  }

  .status-badge { display: inline-flex; padding: 6px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; margin-bottom: 12px; }
  .status-badge.connected { background: rgba(52,211,153,.15); color: #34d399; border: 1px solid rgba(52,211,153,.3); }
  .status-badge.disconnected { background: rgba(239,68,68,.15); color: #f87171; border: 1px solid rgba(239,68,68,.3); }
  .status-desc { font-size: 14px; color: var(--text-secondary); line-height: 1.6; margin-bottom: 24px; }

  .config-help { display: flex; gap: 32px; border-top: 1px solid var(--border-subtle); padding-top: 20px; }
  .help-item { display: flex; flex-direction: column; gap: 4px; }
  .help-label { font-size: 10px; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; }
  .help-value { font-size: 13px; color: var(--text-primary); font-weight: 500; }

  .settings-card.danger { border-color: rgba(230, 30, 42, 0.2); background: rgba(230, 30, 42, 0.02); }
  .danger-item { display: flex; justify-content: space-between; align-items: center; gap: 24px; }
  .mt-24 { margin-top: 24px; padding-top: 24px; border-top: 1px solid rgba(230, 30, 42, 0.1); }
  .danger-info h3 { font-size: 15px; font-weight: 600; color: #fff; margin-bottom: 4px; }
  .danger-info p { font-size: 13px; color: var(--text-secondary); line-height: 1.5; }
  
  .danger-btn { 
    display: inline-flex; padding: 10px 20px; border-radius: 8px;
    font-size: 13px; font-weight: 700; text-decoration: none; transition: all .2s;
    cursor: pointer; border: none; font-family: 'Outfit', sans-serif;
  }
  .danger-btn.outline { background: rgba(230, 30, 42, 0.1); color: #f87171; border: 1px solid rgba(230, 30, 42, 0.3); }
  .danger-btn.solid { background: #e61e2a; color: white; }
  .danger-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(230, 30, 42, 0.2); filter: brightness(1.1); }

  .modal-overlay {
    position: fixed; inset: 0; background: rgba(5, 11, 22, 0.85);
    backdrop-filter: blur(8px); z-index: 2000; display: flex;
    align-items: center; justify-content: center; padding: 20px;
    opacity: 0; pointer-events: none; transition: opacity 0.3s;
  }
  .modal-overlay.active { opacity: 1; pointer-events: auto; }
  .modal-content {
    background: #0d1421; border: 1px solid rgba(230, 30, 42, 0.4);
    border-radius: 20px; width: 100%; max-width: 440px; padding: 32px;
    transform: scale(0.95) translateY(10px); transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .modal-overlay.active .modal-content { transform: scale(1) translateY(0); }
  .modal-header-danger { text-align: center; margin-bottom: 20px; }
  .warning-icon { 
    display: inline-flex; align-items: center; justify-content: center;
    width: 56px; height: 56px; background: rgba(230, 30, 42, 0.1);
    color: #e61e2a; border-radius: 50%; margin-bottom: 16px;
    border: 1px solid rgba(230, 30, 42, 0.2);
  }
  .modal-header-danger h2 { font-size: 22px; font-weight: 700; color: #fff; }
  .modal-desc { font-size: 14px; color: var(--text-secondary); text-align: center; line-height: 1.6; margin-bottom: 32px; }
  .modal-actions { display: flex; flex-direction: column; gap: 12px; }
  .btn-confirm-delete { width: 100%; padding: 14px; background: #e61e2a; color: #fff; border: none; border-radius: 12px; font-size: 14px; font-weight: 700; cursor: pointer; }
  .btn-cancel { width: 100%; padding: 14px; background: rgba(255, 255, 255, 0.05); color: var(--text-primary); border: 1px solid var(--border-subtle); border-radius: 12px; font-size: 14px; font-weight: 600; cursor: pointer; }

  .settings-form { display: flex; flex-direction: column; gap: 20px; }
  .form-row.split { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .form-group { display: flex; flex-direction: column; gap: 8px; }
  .form-group label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--text-secondary); }
  .form-hint { font-size: 11px; color: var(--text-secondary); margin-top: 2px; opacity: 0.6; }
  .mt-8 { margin-top: 8px; }
  .mt-16 { margin-top: 16px; }

