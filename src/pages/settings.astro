</Layout>

<script define:vars={{ isLinked }}>
  const deleteModal = document.getElementById('delete-modal');
  const openBtn = document.getElementById('open-delete-modal');
  const closeBtn = document.getElementById('close-delete-modal');

  openBtn?.addEventListener('click', () => {
    if (isLinked) {
      window.showToast('You must unlink from your coordinator first before deleting your account.', 'error');
      return;
    }
    deleteModal?.classList.add('active');
    document.body.style.overflow = 'hidden';
  });

  const closeModal = () => {
    deleteModal?.classList.remove('active');
    document.body.style.overflow = '';
  };

  closeBtn?.addEventListener('click', closeModal);
  deleteModal?.addEventListener('click', (e) => {
    if (e.target === deleteModal) closeModal();
  });

  // Clockify Unlink Modal
  const clockifyModal = document.getElementById('clockify-modal');
  const openClockifyBtn = document.getElementById('open-clockify-modal');
  const closeClockifyBtn = document.getElementById('close-clockify-modal');

  openClockifyBtn?.addEventListener('click', () => {
    clockifyModal?.classList.add('active');
    document.body.style.overflow = 'hidden';
  });

  const closeClockify = () => {
    clockifyModal?.classList.remove('active');
    document.body.style.overflow = '';
  };

  closeClockifyBtn?.addEventListener('click', closeClockify);
  clockifyModal?.addEventListener('click', (e) => {
    if (e.target === clockifyModal) closeClockify();
  });

  // Coordinator Unlink Modal
  const coordModal = document.getElementById('coordinator-unlink-modal');
  const openCoordBtn = document.getElementById('open-coordinator-unlink-modal');
  const closeCoordBtn = document.getElementById('close-coordinator-unlink-modal');

  openCoordBtn?.addEventListener('click', () => {
    coordModal?.classList.add('active');
    document.body.style.overflow = 'hidden';
  });

  const closeCoord = () => {
    coordModal?.classList.remove('active');
    document.body.style.overflow = '';
  };

  closeCoordBtn?.addEventListener('click', closeCoord);
  coordModal?.addEventListener('click', (e) => {
    if (e.target === coordModal) closeCoord();
  });

  // Link settings logout button to the shared modal in Header
  document.getElementById('settings-logout-btn')?.addEventListener('click', () => {
    const logoutModal = document.getElementById('logout-modal');
    if (logoutModal) {
      logoutModal.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
  });

  // How It Works Modal open/close trigger
  const worksModal = document.getElementById('how-it-works-modal');
  const closeWorksBtn = document.getElementById('close-how-it-works-btn');

  // Open via the settings page "View Guide" button
  document.getElementById('open-how-it-works-btn')?.addEventListener('click', () => {
    if (worksModal) {
      worksModal.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
  });

  // Also bind legacy .btn-guide class (backward compat)
  document.querySelectorAll('.btn-guide').forEach(btn => {
    btn.addEventListener('click', () => {
      if (worksModal) {
        worksModal.classList.add('active');
        document.body.style.overflow = 'hidden';
      }
    });
  });

  const closeWorks = () => {
    if (worksModal) {
      worksModal.classList.remove('active');
      document.body.style.overflow = '';
    }
  };

  closeWorksBtn?.addEventListener('click', closeWorks);
  worksModal?.addEventListener('click', (e) => {
    if (e.target === worksModal) closeWorks();
  });

  // Check for success or error in URL
  const params = new URLSearchParams(window.location.search);
  const successVal = params.get('success');
  if (successVal) {
    const msg = successVal === 'true' ? 'Settings updated successfully!' : successVal;
    window.showToast(msg, 'success');
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }
  if (params.get('error')) {
    window.showToast(decodeURIComponent(params.get('error')), 'error');
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }

  // Handle visual loading state on form submissions
  document.addEventListener('submit', (e) => {
    const form = e.target;
    if (form.dataset.submitting === 'true') return;
    
    const btn = e.submitter || form.querySelector('button[type="submit"]');
    if (!btn) return;
    
    btn.disabled = true;
    btn.style.opacity = '0.7';
    
    let loadingText = 'Loading...';
    if (btn.classList.contains('save-btn')) {
      loadingText = 'SAVING CONFIGURATION...';
    } else if (btn.classList.contains('apply-btn')) {
      loadingText = 'LINKING...';
    } else if (btn.classList.contains('btn-confirm-delete')) {
      if (form.action.includes('delete-account')) {
        loadingText = 'DELETING ACCOUNT...';
      } else {
        loadingText = 'UNLINKING...';
      }
    } else {
      const text = btn.innerText.trim().toUpperCase();
      if (text) {
        loadingText = text + '...';
      }
    }
    
    btn.innerHTML = `
      <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" style="display:inline-block; vertical-align:middle; width:16px; height:16px; animation: spin 1s linear infinite; margin-right: 8px;">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" style="opacity: 0.25;"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" style="opacity: 0.75;"></path>
      </svg>
      ${loadingText}
    `;
    
    if (window.showLoadingSpinner) {
      window.showLoadingSpinner(loadingText);
    }
    
    form.dataset.submitting = 'true';
  });
</script>

