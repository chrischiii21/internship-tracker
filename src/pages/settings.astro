---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import { getSession } from '../lib/auth';
import { parse } from 'cookie';
import { getAppSettings } from '../lib/settings';
import { formatHours } from '../lib/utils';

const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookies = parse(cookieHeader);
const user = cookies.session ? await getSession(cookies.session) : null;

if (!user) {
  return Astro.redirect('/');
}

const settings = await getAppSettings(user.id);
const isClockifySet = !!(import.meta.env.CLOCKIFY_API_KEY && import.meta.env.CLOCKIFY_WORKSPACE_ID);
const success = Astro.url.searchParams.get('success') === 'true';

// Fetch coordinator name if linked
let coordinatorName = '';
if (settings.coordinatorId) {
  const { supabase } = await import('../lib/supabase');
  const { data: coord } = await supabase
    .from('coordinator_settings')
    .select('user_name')
    .eq('user_id', settings.coordinatorId)
    .single();
  if (coord) coordinatorName = coord.user_name;
}

const isLinked = settings.role === 'student' && !!settings.coordinatorId;

const displayStartDate = settings.isEmployee ? (settings.employeeStartDate || settings.startDate) : settings.startDate;
const displayHostCompany = settings.isEmployee ? (settings.employerCompany || settings.hostCompany) : settings.hostCompany;
const displayPaySchedule = settings.isEmployee ? (settings.employeePaySchedule || 'monthly') : settings.paySchedule;
---
<Layout>
  <Header user={user} />

  <div id="portal-body">
    <Sidebar user={user} activeTab="settings" role={settings.role} />

    <main id="portal-main">
      <div class="bg-grid" aria-hidden="true"></div>
      <div class="bg-glow" aria-hidden="true"></div>

      <div id="settings-content" class="content-center">
        <div class="page-header">
          <div>
            <h1>Settings</h1>
            <p>Manage your account preferences and integration settings.</p>
          </div>
          <button type="button" class="btn-guide" id="open-how-it-works-btn">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
            View Guide
          </button>
        </div>

        <div class="settings-sections">
          <!-- Student Specific Sections -->
          {settings.role === 'student' && (
            <>
              <section class="settings-card">
                <h2 class="card-title">{settings.isEmployee ? "Employment & Tracker Configuration" : "Internship Configuration"}</h2>
                <form action="/api/settings" method="POST" class="settings-form">
                  <input type="hidden" name="setupComplete" value="true" />
                  <input type="hidden" name="redirect" value="/settings" />
                  
                  <div class="allowance-header" style="margin-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.06); padding-bottom: 16px;">
                    <label class="check-label">
                      <input type="checkbox" name="isEmployee" value="true" checked={settings.isEmployee} id="employee-toggle-settings" />
                      <span class="toggle-text" style="font-weight: 700; color: var(--ntv-orange);">Now an Employee Mode</span>
                    </label>
                    <p class="form-hint" style="margin-left: 28px; margin-top: 4px;">Enabling Employee Mode changes the tracking layout to a personal Clockify-style portal, resets target hours, and switches pay to a monthly salary rate.</p>
                  </div>

                  <div class="form-row">
                    <div class="form-group">
                      <label for="hostCompany" id="company-label">{settings.isEmployee ? "Employer / Company Name" : "Host Training Establishment (Company)"}</label>
                      <input 
                        type="text" 
                        id="hostCompany" 
                        name="hostCompany" 
                        value={displayHostCompany} 
                        data-ojt-value={settings.hostCompany || ''} 
                        data-emp-value={settings.employerCompany || ''} 
                        placeholder="Enter company name" 
                        required 
                      />
                    </div>
                  </div>

                  <div class="form-row">
                    <div class="form-group">
                      <label for="startDate" id="startDate-label">{settings.isEmployee ? "Employment Start Date" : "Program Start Date"}</label>
                      <input 
                        type="date" 
                        id="startDate" 
                        name="startDate" 
                        value={displayStartDate} 
                        data-ojt-value={settings.startDate || ''} 
                        data-emp-value={settings.employeeStartDate || ''} 
                        required 
                        style="width: 100%; max-width: 100%;" 
                      />
                    </div>
                  </div>

                  <!-- OJT Specific Fields -->
                  <div id="ojt-fields-settings" style={settings.isEmployee ? "display: none;" : ""}>
                    <div class="form-row">
                      <div class="form-group">
                        <label for="program">Program / Course</label>
                        <input type="text" id="program" name="program" value={settings.program} placeholder="Enter your program" required={!settings.isEmployee} />
                      </div>
                    </div>
                    <div class="form-row split">
                      <div class="form-group">
                        <label for="supervisor">Supervisor Name</label>
                        <input type="text" id="supervisor" name="supervisor" value={settings.supervisor} placeholder="Enter supervisor name" required={!settings.isEmployee} />
                      </div>
                      <div class="form-group">
                        <label for="supervisorPosition">Supervisor Position</label>
                        <input type="text" id="supervisorPosition" name="supervisorPosition" value={settings.supervisorPosition} placeholder="Enter position" required={!settings.isEmployee} />
                      </div>
                    </div>

                    <div class="form-row">
                      <div class="form-group">
                        <label for="targetHours">Target Hours</label>
                        <div class="input-wrapper">
                          <input type="number" id="targetHours" name="targetHours" value={settings.targetHours} step="0.5" required={!settings.isEmployee} />
                          <span class="input-suffix">hrs</span>
                        </div>
                      </div>
                    </div>

                    <div class="allowance-header" style="margin-top: 20px;">
                      <label class="check-label">
                        <input type="checkbox" name="hasAllowance" value="true" checked={settings.hasAllowance} id="allowance-toggle-settings" />
                        <span class="toggle-text">Enable Allowance Tracking</span>
                      </label>
                    </div>

                    <div id="allowance-fields-settings" style={settings.hasAllowance ? "" : "display: none;"}>
                      <div class="form-row split">
                        <div class="form-group">
                          <label for="payType">Pay Model</label>
                          <select name="payType" id="payType" class="settings-select">
                            <option value="hourly" selected={settings.payType === 'hourly'}>Hourly Rate</option>
                            <option value="daily" selected={settings.payType === 'daily'}>Fixed Daily Rate</option>
                          </select>
                        </div>
                        <div class="form-group">
                          <label for="hourlyRate">Rate (₱)</label>
                          <div class="input-wrapper">
                            <span class="input-prefix">₱</span>
                            <input type="number" id="hourlyRate" name="hourlyRate" value={settings.hourlyRate} step="0.5" required={!settings.isEmployee && settings.hasAllowance} />
                          </div>
                        </div>
                      </div>

                      <div class="form-row">
                        <div class="form-group">
                          <label for="paySchedule">Pay Schedule</label>
                          <select name="paySchedule" id="paySchedule" class="settings-select">
                            <option value="weekly" selected={settings.paySchedule === 'weekly'}>Every Week</option>
                            <option value="semi-monthly" selected={settings.paySchedule === 'semi-monthly'}>Semi-monthly (15th/30th)</option>
                            <option value="monthly" selected={settings.paySchedule === 'monthly'}>Monthly</option>
                          </select>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Employee Specific Fields -->
                  <div id="employee-fields-settings" style={settings.isEmployee ? "" : "display: none;"}>
                    <div class="form-row split">
                      <div class="form-group">
                        <label for="monthlyRate">Monthly Salary Rate (₱)</label>
                        <div class="input-wrapper">
                          <span class="input-prefix">₱</span>
                          <input type="number" id="monthlyRate" name="monthlyRate" value={settings.monthlyRate} step="0.01" required={settings.isEmployee} />
                        </div>
                      </div>
                      <div class="form-group">
                        <label for="employeePaySchedule">Pay Schedule</label>
                        <select name="paySchedule" id="employeePaySchedule" class="settings-select">
                          <option value="semi-monthly" selected={displayPaySchedule === 'semi-monthly'}>Semi-monthly (Every 15 days)</option>
                          <option value="monthly" selected={displayPaySchedule === 'monthly'}>Monthly</option>
                        </select>
                      </div>
                    </div>
                  </div>

                  <button type="submit" class="save-btn" style="margin-top: 24px;">Update Configuration</button>
                </form>

                <script is:inline>
                  document.getElementById('allowance-toggle-settings')?.addEventListener('change', (e) => {
                    const fields = document.getElementById('allowance-fields-settings');
                    const rateInput = document.getElementById('hourlyRate');
                    if (fields) fields.style.display = e.target.checked ? 'block' : 'none';
                    if (rateInput) rateInput.required = e.target.checked;
                  });

                  const empToggle = document.getElementById('employee-toggle-settings');
                  const ojtContainer = document.getElementById('ojt-fields-settings');
                  const empContainer = document.getElementById('employee-fields-settings');
                  const mainCardTitle = empToggle?.closest('.settings-card')?.querySelector('.card-title');
                  const lblCompany = document.getElementById('company-label');
                  const lblStartDate = document.getElementById('startDate-label');

                  const inpCompany = document.getElementById('hostCompany');
                  const inpStartDate = document.getElementById('startDate');

                  const inpProgram = document.getElementById('program');
                  const inpSupervisor = document.getElementById('supervisor');
                  const inpSupervisorPos = document.getElementById('supervisorPosition');
                  const inpTargetHours = document.getElementById('targetHours');
                  const inpHourlyRate = document.getElementById('hourlyRate');
                  const inpMonthlyRate = document.getElementById('monthlyRate');

                  const selOjtPaySchedule = document.getElementById('paySchedule');
                  const selEmpPaySchedule = document.getElementById('employeePaySchedule');

                  function handleToggleChange() {
                    const isEmp = empToggle?.checked;
                    if (isEmp) {
                      if (ojtContainer) ojtContainer.style.display = 'none';
                      if (empContainer) empContainer.style.display = 'block';
                      if (mainCardTitle) mainCardTitle.textContent = 'Employment & Tracker Configuration';
                      if (lblCompany) lblCompany.textContent = 'Employer / Company Name';
                      if (lblStartDate) lblStartDate.textContent = 'Employment Start Date';

                      // Swap to employee values in inputs
                      if (inpCompany) inpCompany.value = inpCompany.getAttribute('data-emp-value') || '';
                      if (inpStartDate) inpStartDate.value = inpStartDate.getAttribute('data-emp-value') || '';

                      if (inpProgram) inpProgram.required = false;
                      if (inpSupervisor) inpSupervisor.required = false;
                      if (inpSupervisorPos) inpSupervisorPos.required = false;
                      if (inpTargetHours) inpTargetHours.required = false;
                      if (inpHourlyRate) inpHourlyRate.required = false;
                      if (inpMonthlyRate) inpMonthlyRate.required = true;

                      if (selOjtPaySchedule) selOjtPaySchedule.disabled = true;
                      if (selEmpPaySchedule) selEmpPaySchedule.disabled = false;

                      const inviteInp = document.getElementById('coordinatorInvite');
                      const unlinkB = document.getElementById('open-coordinator-unlink-modal');
                      const cardCoord = inviteInp?.closest('.settings-card') || unlinkB?.closest('.settings-card');
                      if (cardCoord) cardCoord.style.display = 'none';
                    } else {
                      if (ojtContainer) ojtContainer.style.display = 'block';
                      if (empContainer) empContainer.style.display = 'none';
                      if (mainCardTitle) mainCardTitle.textContent = 'Internship Configuration';
                      if (lblCompany) lblCompany.textContent = 'Host Training Establishment (Company)';
                      if (lblStartDate) lblStartDate.textContent = 'Program Start Date';

                      // Swap to OJT values in inputs
                      if (inpCompany) inpCompany.value = inpCompany.getAttribute('data-ojt-value') || '';
                      if (inpStartDate) inpStartDate.value = inpStartDate.getAttribute('data-ojt-value') || '';

                      if (inpProgram) inpProgram.required = true;
                      if (inpSupervisor) inpSupervisor.required = true;
                      if (inpSupervisorPos) inpSupervisorPos.required = true;
                      if (inpTargetHours) inpTargetHours.required = true;
                      if (inpHourlyRate) {
                        const allowanceT = document.getElementById('allowance-toggle-settings');
                        inpHourlyRate.required = allowanceT ? allowanceT.checked : false;
                      }
                      if (inpMonthlyRate) inpMonthlyRate.required = false;

                      if (selOjtPaySchedule) selOjtPaySchedule.disabled = false;
                      if (selEmpPaySchedule) selEmpPaySchedule.disabled = true;

                      const inviteInp = document.getElementById('coordinatorInvite');
                      const unlinkB = document.getElementById('open-coordinator-unlink-modal');
                      const cardCoord = inviteInp?.closest('.settings-card') || unlinkB?.closest('.settings-card');
                      if (cardCoord) cardCoord.style.display = 'block';
                    }
                  }

                  // Update temporary values when typing so edits are preserved across toggles
                  inpCompany?.addEventListener('input', (e) => {
                    const isEmp = empToggle?.checked;
                    if (isEmp) {
                      inpCompany.setAttribute('data-emp-value', e.target.value);
                    } else {
                      inpCompany.setAttribute('data-ojt-value', e.target.value);
                    }
                  });

                  inpStartDate?.addEventListener('change', (e) => {
                    const isEmp = empToggle?.checked;
                    if (isEmp) {
                      inpStartDate.setAttribute('data-emp-value', e.target.value);
                    } else {
                      inpStartDate.setAttribute('data-ojt-value', e.target.value);
                    }
                  });

                  empToggle?.addEventListener('change', handleToggleChange);
                  if (empToggle) handleToggleChange();
                </script>
              </section>

              <section class="settings-card">
                <h2 class="card-title">Coordinator Connection</h2>
                
                {settings.coordinatorId ? (
                  <form action="/api/settings" method="POST" class="settings-form">
                    <input type="hidden" name="unlink" value="true" />
                    <input type="hidden" name="redirect" value="/settings" />
                    
                    <div class="linked-info">
                      <div class="link-status">
                        <div class="status-dot pulse"></div>
                        <span>Linked to <strong>{coordinatorName}</strong>{settings.sectionName && ` (${settings.sectionName})`}</span>
                      </div>
                      <p class="hint">Your coordinator can now view your progress and DTR logs.</p>
                      
                      <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                        <button type="button" id="open-coordinator-unlink-modal" class="unlink-btn mt-16">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg>
                          Unlink from Coordinator
                        </button>
                      </div>
                    </div>
                  </form>
                ) : (
                  <form action="/api/settings" method="POST" class="settings-form">
                    <input type="hidden" name="setupComplete" value="true" />
                    <input type="hidden" name="redirect" value="/settings" />
                    
                    <div class="unlinked-info">
                      <div class="link-status unlinked">
                        <div class="status-dot gray"></div>
                        <span>Not linked to a coordinator</span>
                      </div>
                    </div>

                    <div class="form-group mt-16">
                      <label for="coordinatorInvite">Link via Invite Code</label>
                      <div class="input-with-btn">
                        <input type="text" id="coordinatorInvite" name="coordinatorInvite" placeholder="Enter 6-digit code" required />
                        <button type="submit" class="apply-btn">Link</button>
                      </div>
                      <p class="form-hint">Paste the code given by your OJT Coordinator to sync your progress.</p>
                    </div>
                  </form>
                )}
              </section>
            </>
          )}

          <!-- Common Sections -->
          <section class="settings-card">
            <h2 class="card-title">Profile Information</h2>
            <div class="profile-preview">
              {user.picture && <img src={user.picture} alt="" class="profile-img" />}
              <div class="profile-details">
                <div class="detail-group">
                  <label>Full Name</label>
                  <div class="read-only-box">{user.name}</div>
                </div>
                <div class="detail-group">
                  <label>Email Address</label>
                  <div class="read-only-box">{user.email}</div>
                </div>
              </div>
            </div>
          </section>

          <!-- Coordinator Invite Code (Only for Coordinators) -->
          {settings.role === 'coordinator' && (
            <section class="settings-card">
              <h2 class="card-title">Coordinator Settings</h2>
              <div class="detail-group">
                <label>Your General Invite Code</label>
                <div class="read-only-box" style="font-family: 'JetBrains Mono', monospace; font-size: 20px; font-weight: 700; color: var(--ntv-orange);">
                  {settings.inviteCode}
                </div>
                <p class="form-hint mt-8">
                  This is your general invite code if you do not want to track students by sections.
                  If you want to track students by section with unique codes, go to the <a href="/sections" class="hint-link">Manage Sections</a> tab.
                </p>
              </div>
            </section>
          )}

          <!-- Integration Section (Students Only) -->
          {settings.role === 'student' && (
            <section class="settings-card">
              <h2 class="card-title">Clockify Integration</h2>
              <div class="integration-status">
                <div class={`status-badge ${isClockifySet && settings.clockifyEnabled ? 'connected' : 'disconnected'}`}>
                  {isClockifySet && settings.clockifyEnabled ? 'Connected' : (settings.clockifyEnabled ? 'Missing Credentials' : 'Disabled / Unlinked')}
                </div>
                <p class="status-desc">
                  {isClockifySet && settings.clockifyEnabled
                    ? 'Your system is currently syncing with Clockify using the environment variables provided.' 
                    : (settings.clockifyEnabled 
                        ? 'Update your .env file with CLOCKIFY_API_KEY and CLOCKIFY_WORKSPACE_ID to enable syncing.'
                        : 'Clockify integration is disabled. Your records will be based on manual logs.')}
                </p>
              </div>
              
              {isClockifySet && settings.clockifyEnabled ? (
                <button type="button" id="open-clockify-modal" class="unlink-btn">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg>
                  Unlink Clockify
                </button>
              ) : (
                isClockifySet && (
                  <form action="/api/settings" method="POST">
                    <input type="hidden" name="linkClockify" value="true" />
                    <input type="hidden" name="redirect" value="/settings" />
                    <button type="submit" class="save-btn">Re-link Clockify</button>
                  </form>
                )
              )}

              <div class="config-help mt-16">
                <div class="help-item">
                  <span class="help-label">Sync Status</span>
                  <span class="help-value">{settings.clockifyEnabled ? 'Active' : 'Paused'}</span>
                </div>
                {!settings.isEmployee && (
                  <div class="help-item">
                    <span class="help-label">Target Hours</span>
                    <span class="help-value">{formatHours(settings.targetHours)}</span>
                  </div>
                )}
              </div>
            </section>
          )}

          <!-- Danger Zone -->
          <section class="settings-card danger">
            <h2 class="card-title">Danger Zone</h2>
            <div class="danger-item">
              <div class="danger-info">
                <h3>Sign Out Everywhere</h3>
                <p>Log out of all devices and end your current session.</p>
              </div>
              <button type="button" id="settings-logout-btn" class="danger-btn outline">Sign Out</button>
            </div>

            <div class="danger-item mt-24">
              <div class="danger-info">
                <h3>Delete Account</h3>
                <p>Permanently remove your profile and all your data. This action is irreversible.</p>
              </div>
              <button type="button" id="open-delete-modal" class="danger-btn solid">Delete My Account</button>
            </div>
          </section>
        </div>
      </div>
      
      <!-- CLOCKIFY UNLINK MODAL -->
      <div id="clockify-modal" class="modal-overlay">
        <div class="modal-content">
          <div class="modal-header-danger">
            <div class="warning-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0zM12 9v4M12 17h.01"/></svg>
            </div>
            <h2>Unlink Clockify?</h2>
          </div>
          <p class="modal-desc">Are you sure you want to disconnect Clockify? Future logs will rely entirely on manual entries. Your existing synced logs will remain visible but will no longer update from Clockify.</p>
          <div class="modal-actions">
            <form action="/api/settings" method="POST">
              <input type="hidden" name="unlinkClockify" value="true" />
              <input type="hidden" name="redirect" value="/settings" />
              <button type="submit" class="btn-confirm-delete">Yes, Unlink Now</button>
            </form>
            <button type="button" id="close-clockify-modal" class="btn-cancel">Cancel</button>
          </div>
        </div>
      </div>

      <!-- COORDINATOR UNLINK MODAL -->
      <div id="coordinator-unlink-modal" class="modal-overlay">
        <div class="modal-content">
          <div class="modal-header-danger">
            <div class="warning-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0zM12 9v4M12 17h.01"/></svg>
            </div>
            <h2>Unlink Coordinator?</h2>
          </div>
          <p class="modal-desc">Are you sure you want to unlink from **{coordinatorName}**? They will no longer be able to view your progress or verify your logs.</p>
          <div class="modal-actions">
            <form action="/api/settings" method="POST">
              <input type="hidden" name="unlink" value="true" />
              <input type="hidden" name="redirect" value="/settings" />
              <button type="submit" class="btn-confirm-delete">Yes, Unlink Now</button>
            </form>
            <button type="button" id="close-coordinator-unlink-modal" class="btn-cancel">Cancel</button>
          </div>
        </div>
      </div>

      <!-- DELETE MODAL -->
      <div id="delete-modal" class="modal-overlay">
        <div class="modal-content">
          <div class="modal-header-danger">
            <div class="warning-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0zM12 9v4M12 17h.01"/></svg>
            </div>
            <h2>Delete your account?</h2>
          </div>
          <p class="modal-desc">This will permanently delete your profile, all settings, and **ALL your records**. This action cannot be undone.</p>
          <div class="modal-actions">
            <button type="button" id="close-delete-modal" class="btn-cancel">Cancel, Keep Data</button>
            <form action="/api/auth/delete-account" method="POST">
              <button type="submit" class="btn-confirm-delete">Yes, Delete Everything</button>
            </form>
          </div>
        </div>
      </div>

      <!-- HOW IT WORKS MODAL -->
      {settings.role === 'coordinator' ? (
        <div id="how-it-works-modal" class="modal-overlay">
          <div class="modal-content info-modal-content">
            <div class="modal-header-info">
              <div class="info-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
              </div>
              <h3>How Coordinator Portal Works</h3>
            </div>
            <p class="modal-subtitle">Welcome! Here is a quick guide on how to manage your students and monitor their progress.</p>
            
            <div class="guide-steps">
              <div class="guide-step">
                <span class="step-num">1</span>
                <div class="step-details">
                  <h4>Invite Students & Manage Sections</h4>
                  <p>Provide your general invite code, or create distinct class sections under <strong>Sections & Invite Codes</strong> to generate unique section-specific invite codes for better student tracking.</p>
                </div>
              </div>
              <div class="guide-step">
                <span class="step-num">2</span>
                <div class="step-details">
                  <h4>Review Log Entries</h4>
                  <p>Click on any student in the dashboard table to review their detailed log list, verify working hours, and check uploaded proof/documentation.</p>
                </div>
              </div>
              <div class="guide-step">
                <span class="step-num">3</span>
                <div class="step-details">
                  <h4>Monitor Targets</h4>
                  <p>Track target hour progression, daily time records, and check if students are receiving allowances in their respective company areas.</p>
                </div>
              </div>
            </div>
            
            <div class="modal-actions-single">
              <button type="button" class="btn-onboarding" id="close-how-it-works-btn">Got it, let's start!</button>
            </div>
          </div>
        </div>
      ) : (
