---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import { getSession } from '../lib/auth';
import { parse } from 'cookie';
import { getAppSettings } from '../lib/settings';
import { supabase } from '../lib/supabase';
import { formatHours } from '../lib/utils';
import { getStudentProgress, getClockifyUser, getClockifyDetailedEntries } from '../lib/clockify';
import { getManualEntries } from '../lib/entries';

const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookies = parse(cookieHeader);
const user = cookies.session ? await getSession(cookies.session) : null;

if (!user) return Astro.redirect('/');

const settings = await getAppSettings(user.id);
if (settings.role !== 'coordinator') return Astro.redirect('/dashboard');

// POST Action handlers for sections management
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'add-section') {
    const sectionName = (formData.get('sectionName') as string || '').trim();
    if (!sectionName) {
      return Astro.redirect('/sections?error=Section name cannot be empty');
    }
    // Generate unique 6-character code
    const inviteCode = Math.random().toString(36).substring(2, 8).toUpperCase();
    
    const { error } = await supabase
      .from('coordinator_sections')
      .insert({
        coordinator_id: user.id,
        section_name: sectionName,
        invite_code: inviteCode
      });

    if (error) {
      console.error(error);
      return Astro.redirect(`/sections?error=${encodeURIComponent(error.message)}`);
    }
    return Astro.redirect('/sections?success=Section created successfully');
  }

  if (action === 'delete-section') {
    const sectionId = formData.get('sectionId') as string;
    const { error } = await supabase
      .from('coordinator_sections')
      .delete()
      .eq('id', sectionId)
      .eq('coordinator_id', user.id);

    if (error) {
      console.error(error);
      return Astro.redirect(`/sections?error=${encodeURIComponent(error.message)}`);
    }
    return Astro.redirect('/sections?success=Section deleted successfully');
  }
}

// Fetch Sections
const { data: sections } = await supabase
  .from('coordinator_sections')
  .select('*')
  .eq('coordinator_id', user.id)
  .order('section_name', { ascending: true });

// Fetch Students to count section enrollments and show list detail
const { data: students } = await supabase
  .from('student_settings')
  .select('*, coordinator_sections(section_name)')
  .eq('coordinator_id', user.id);

const studentCountList = students || [];

const viewSection = Astro.url.searchParams.get('viewSection');

let filteredStudents = [];
let sectionName = '';
let sectionInviteCode = '';
let sectionStudentsLogs = [];

if (viewSection) {
  // Sync hours and DTR progress (same logic as coordinator page)
  const studentStats = await Promise.all(studentCountList.map(async (s) => {
    const hours = await getStudentProgress(s.user_id, s.user_email, s.start_date);
    const percent = Math.min(100, (hours / s.target_hours) * 100);
    return {
      ...s,
      renderedHours: hours,
      percent: percent.toFixed(1)
    };
  }));

  filteredStudents = studentStats.filter(s => s.section_id === viewSection);
  const matchedSec = (sections || []).find(sec => sec.id === viewSection);
  sectionName = matchedSec ? matchedSec.section_name : 'Unknown Section';
  sectionInviteCode = matchedSec ? matchedSec.invite_code : '';

  // Fetch detailed logs for each student in the filtered list
  sectionStudentsLogs = await Promise.all(filteredStudents.map(async (s) => {
    // 1. Fetch manual entries
    const manual = await getManualEntries(s.user_id);
    
    // 2. Fetch Clockify entries (if enabled)
    let clockify = [];
    if (s.clockify_enabled !== false) {
      try {
        const cUser = await getClockifyUser(s.user_email);
        if (cUser) {
          clockify = await getClockifyDetailedEntries(cUser.id, s.start_date);
        }
      } catch (err) {
        console.error('Error fetching student Clockify logs in sections:', err);
      }
    }
    
    // 3. Combine and sort entries by date + start_time descending
    const combinedEntries = [
      ...manual.map(m => ({ ...m, type: 'manual' })),
      ...clockify.map(c => ({ ...c, type: 'clockify' }))
    ].sort((a, b) => {
      const dateA = new Date(`${a.date}T${a.startTime}`);
      const dateB = new Date(`${b.date}T${b.startTime}`);
      return dateB.getTime() - dateA.getTime();
    });

    return {
      userId: s.user_id,
      userName: s.user_name,
      userPicture: s.user_picture,
      program: s.program || 'N/A',
      company: s.host_company || 'N/A',
      startDate: s.start_date || 'N/A',
      supervisor: s.supervisor || 'N/A',
      supervisorPosition: s.supervisor_position || 'N/A',
      renderedHours: s.renderedHours,
      targetHours: s.target_hours,
      percent: s.percent,
      entries: combinedEntries
    };
  }));
}
---

<Layout title="Manage Sections">
  <Header user={user} />
  <div id="portal-body">
    <Sidebar user={user} activeTab="sections" role={settings.role} />
    <main id="portal-main">
      <div class="bg-grid" aria-hidden="true"></div>
      
      <div id="sections-content" class="content-center">
        <div class="page-header">
          <div class="header-main">
            <h1>Manage <span class="accent">Sections</span></h1>
            <p>Create and monitor class roster sections and active student invite codes.</p>
          </div>
        </div>

        <div class="student-section">
          {viewSection ? (
            <div class="roster-view">
              <div class="roster-header">
                <a href="/sections" class="back-link">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                  Back to Sections
                </a>
                <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
                  <h2>
                    Roster: <span class="accent">{sectionName}</span>
                  </h2>
                  {sectionInviteCode && (
                    <div class="invite-code-box" style="background: rgba(0,0,0,0.25); border: 1px solid rgba(237, 102, 33, 0.2); padding: 6px 12px; border-radius: 8px; font-size: 13px; font-weight: 600; display: inline-flex; align-items: center; gap: 8px;">
                      <span style="color: var(--text-secondary); font-size: 11px; font-weight: 700; text-transform: uppercase;">Invite Code:</span>
                      <span class="code" style="font-size: 14px; font-weight: 700; color: #fff;">{sectionInviteCode}</span>
                      <button class="copy-invite-btn" title="Copy invite message" data-code={sectionInviteCode} data-section={sectionName}>
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                      </button>
                    </div>
                  )}
                </div>
              </div>
              
              <div class="table-wrapper">
                <table class="student-table">
                  <thead>
                    <tr>
                      <th>Student Name</th>
                      <th>Agency</th>
                      <th>Hours Rendered</th>
                      <th>Progress</th>
                      <th>Status</th>
                      <th>Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    {filteredStudents.length > 0 ? filteredStudents.map((s) => (
                      <tr>
                        <td>
                          <div class="student-info-cell">
                            {s.user_picture && <img src={s.user_picture} alt="" class="row-avatar" />}
                            <span class="row-name">{s.user_name}</span>
                          </div>
                        </td>
                        <td><span class="program-tag">{s.host_company}</span></td>
                        <td class="mono">{formatHours(s.renderedHours)} / {formatHours(s.target_hours)}</td>
                        <td>
                          <div class="progress-col">
                            <span class="percent">{s.percent}%</span>
                            <div class="mini-track">
                              <div class="mini-fill" style={`width: ${s.percent}%`}></div>
                            </div>
                          </div>
                        </td>
                        <td>
                          <span class={`status-badge ${Number(s.percent) >= 100 ? 'done' : 'active'}`}>
                            {Number(s.percent) >= 100 ? 'Completed' : 'In Progress'}
                          </span>
                        </td>
                        <td>
                          <button type="button" class="view-link view-progress-btn" data-user-id={s.user_id} style="background: rgba(237, 102, 33, 0.1); border: 1px solid rgba(237, 102, 33, 0.2); border-radius: 6px; cursor: pointer; outline: none; transition: 0.2s;">
                            View Student Progress
                          </button>
                        </td>
                      </tr>
                    )) : (
                      <tr>
                        <td colspan="6" class="empty-state">No students match the criteria for this section.</td>
                      </tr>
                    )}
                  </tbody>
                </table>
              </div>
            </div>
          ) : (
            <div class="sections-grid">
              <!-- Add Section Card -->
              <div class="section-card add-card">
                <div>
                  <h3>Create New Section</h3>
                  <p class="card-desc">Create a new class section with a unique student invite code.</p>
                </div>
                <form method="POST" class="add-section-form">
                  <input type="hidden" name="action" value="add-section" />
                  <div class="form-group">
                    <input type="text" name="sectionName" placeholder="e.g. BSIT 4-A" required class="setup-input" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: #fff; padding: 10px 14px; width: 100%; font-size: 13px;" />
                  </div>
                  <button type="submit" class="btn-setup" style="width: 100%; margin-top: 12px; padding: 10px 14px;">Generate Roster Section</button>
                </form>
              </div>

              <!-- User Sections -->
              {sections?.map(sec => {
                // Count students in this section
                const studentCount = studentCountList.filter(s => s.section_id === sec.id).length;
                return (
                  <div class="section-card clickable-card" onclick={`window.location.href='/sections?viewSection=${sec.id}'`}>
                    <div>
                      <div class="card-header">
                        <h3>{sec.section_name}</h3>
                        <span class="badge student-count">{studentCount} Students</span>
                      </div>
                      <p class="card-desc">Share this invite code with students from this section.</p>
                    </div>
                    <div class="invite-code-box" style="margin-top: 16px; justify-content: space-between; background: rgba(0,0,0,0.2); padding: 8px 12px; border-radius: 8px; width: 100%;" onclick="event.stopPropagation();">
                      <span class="code" style="font-size: 16px;">{sec.invite_code}</span>
                      <div style="display: flex; gap: 8px; align-items: center;">
                        <button class="copy-invite-btn" title="Copy invite message" data-code={sec.invite_code} data-section={sec.section_name}>
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                        </button>
                        <form method="POST" style="margin: 0; display: inline;" onsubmit="event.stopPropagation(); return confirm('Are you sure you want to delete this section? Linked students will be marked as unassigned.');">
                          <input type="hidden" name="action" value="delete-section" />
                          <input type="hidden" name="sectionId" value={sec.id} />
                          <button type="submit" class="copy-btn" title="Delete section" style="color: #ef4444; background: none; border: none; padding: 4px; cursor: pointer;">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2-2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                          </button>
                        </form>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>

          )}
        </div>
      </div>
    </main>
  </div>
  <!-- STUDENT PROGRESS DETAIL MODAL -->
  <div id="student-progress-modal" class="modal-overlay">
    <div class="modal-content progress-modal-content">
      
      <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px;">
        <h3 style="font-size: 20px; font-weight: 700; color: #fff; margin: 0;">Student Progress Overview</h3>
        <button type="button" class="close-btn" id="close-progress-modal-btn" style="background: none; border: none; color: var(--text-secondary); cursor: pointer; padding: 4px; border-radius: 50%;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <!-- Student Detail Card -->
      <div class="student-detail-summary-card">
        <div style="display: flex; gap: 16px; align-items: center; margin-bottom: 16px;">
          <img id="progress-modal-avatar" src="" alt="" style="width: 44px; height: 44px; border-radius: 50%; border: 2px solid var(--ntv-orange); display: none;" />
          <div style="width: 44px; height: 44px; border-radius: 50%; background: var(--ntv-gradient); display: flex; align-items: center; justify-content: center; font-weight: 700; color: #fff; font-size: 18px;" id="progress-modal-avatar-fallback"></div>
          <div>
            <h4 id="progress-modal-name" style="font-size: 16px; font-weight: 700; color: #fff; margin: 0;">Student Name</h4>
            <p id="progress-modal-program" style="font-size: 12px; color: var(--text-secondary); margin: 2px 0 0 0;">Program</p>
          </div>
        </div>

        <div class="grid-details">
          <div>
            <span style="color: var(--text-secondary); font-size: 11px; text-transform: uppercase; font-weight: 700;">Internship Company</span>
            <div id="progress-modal-company" style="font-weight: 600; color: #fff; margin-top: 2px;">Company</div>
          </div>
          <div>
            <span style="color: var(--text-secondary); font-size: 11px; text-transform: uppercase; font-weight: 700;">Start Date</span>
            <div id="progress-modal-start" style="font-weight: 600; color: #fff; margin-top: 2px;">Start Date</div>
          </div>
          <div>
            <span style="color: var(--text-secondary); font-size: 11px; text-transform: uppercase; font-weight: 700;">Supervisor Name</span>
            <div id="progress-modal-supervisor" style="font-weight: 600; color: #fff; margin-top: 2px;">Supervisor</div>
          </div>
          <div>
            <span style="color: var(--text-secondary); font-size: 11px; text-transform: uppercase; font-weight: 700;">Supervisor Position</span>
            <div id="progress-modal-position" style="font-weight: 600; color: #fff; margin-top: 2px;">Position</div>
          </div>
        </div>

        <!-- Hours Progress -->
        <div style="border-top: 1px solid var(--border-subtle); padding-top: 14px;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; font-size: 13px;">
            <span style="color: var(--text-secondary); font-weight: 600;">Overall Progress</span>
            <span id="progress-modal-hours" style="font-family: 'JetBrains Mono', monospace; font-weight: 700; color: var(--ntv-orange);">00:00 / 00:00 (0.0%)</span>
          </div>
          <div style="height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden;">
            <div id="progress-modal-bar" style="height: 100%; background: var(--ntv-gradient); border-radius: 3px; width: 0%;"></div>
          </div>
        </div>
      </div>

      <!-- Time Logs Title -->
      <h4 style="font-size: 13px; font-weight: 700; color: #fff; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 12px 0;">Activity Log & DTR Details</h4>

      <!-- Time Logs Table container -->
      <div class="progress-table-container">
        <table class="student-table">
          <thead>
            <tr>
              <th style="padding: 10px 14px; font-size: 10px; font-weight: 700; text-transform: uppercase; color: var(--text-secondary); border-bottom: 1px solid var(--border-subtle);">Date & Time</th>
              <th style="padding: 10px 14px; font-size: 10px; font-weight: 700; text-transform: uppercase; color: var(--text-secondary); border-bottom: 1px solid var(--border-subtle);">Source</th>
              <th style="padding: 10px 14px; font-size: 10px; font-weight: 700; text-transform: uppercase; color: var(--text-secondary); border-bottom: 1px solid var(--border-subtle);">Activity Description</th>
              <th style="padding: 10px 14px; font-size: 10px; font-weight: 700; text-transform: uppercase; color: var(--text-secondary); border-bottom: 1px solid var(--border-subtle);">Documentation</th>
            </tr>
          </thead>
          <tbody id="progress-modal-logs-body">
            <!-- Populated dynamically via javascript -->
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- DOCUMENTATION VIEWER MODAL -->
  <div id="doc-viewer-modal" class="modal-overlay" style="z-index: 3000;">
    <div class="modal-content doc-viewer-modal-content">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; flex-shrink: 0;">
        <div>
          <h3 style="font-size: 16px; font-weight: 700; color: #fff; margin: 0 0 2px 0;">Documentation Proof</h3>
          <p id="doc-viewer-label" style="font-size: 12px; color: var(--text-secondary); margin: 0;"></p>
        </div>
        <button type="button" id="close-doc-viewer-btn" style="background: none; border: none; color: var(--text-secondary); cursor: pointer; padding: 4px; border-radius: 50%; flex-shrink: 0;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <!-- Gallery counter -->
      <div id="doc-viewer-counter" style="font-size: 11px; color: var(--text-secondary); margin-bottom: 12px; flex-shrink: 0; display: none;"></div>

      <!-- Main image viewer -->
      <div style="flex: 1; overflow: hidden; border-radius: 12px; background: rgba(0,0,0,0.4); border: 1px solid var(--border-subtle); display: flex; align-items: center; justify-content: center; min-height: 300px; position: relative;">
        <img id="doc-viewer-img" src="" alt="Documentation proof" style="max-width: 100%; max-height: 60vh; object-fit: contain; border-radius: 8px; display: block;" />
        <div id="doc-viewer-no-preview" style="display: none; text-align: center; padding: 40px;">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" style="margin-bottom: 12px;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <p style="color: var(--text-secondary); font-size: 13px; margin: 0 0 12px 0;">This file cannot be previewed</p>
          <a id="doc-viewer-open-link" href="#" target="_blank" rel="noopener" style="color: var(--ntv-orange); font-size: 13px; font-weight: 600;">Open in new tab →</a>
        </div>
      </div>

      <!-- Thumbnail strip (shown when multiple docs) -->
      <div id="doc-viewer-thumbs" style="display: none; gap: 8px; margin-top: 12px; overflow-x: auto; flex-shrink: 0; padding-bottom: 4px;"></div>

      <!-- Navigation -->
      <div id="doc-viewer-nav" style="display: none; justify-content: center; align-items: center; gap: 16px; margin-top: 14px; flex-shrink: 0;">
        <button id="doc-prev-btn" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); color: #fff; padding: 8px 18px; border-radius: 8px; cursor: pointer; font-size: 13px; font-weight: 600; transition: all 0.2s;">← Prev</button>
        <span id="doc-nav-label" style="font-size: 12px; color: var(--text-secondary);"></span>
        <button id="doc-next-btn" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); color: #fff; padding: 8px 18px; border-radius: 8px; cursor: pointer; font-size: 13px; font-weight: 600; transition: all 0.2s;">Next →</button>
      </div>

      <!-- Open in new tab link -->
      <div style="text-align: center; margin-top: 10px; flex-shrink: 0;">
        <a id="doc-viewer-external" href="#" target="_blank" rel="noopener" style="font-size: 11px; color: var(--text-secondary); text-decoration: underline;">Open current file in new tab</a>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  const params = new URLSearchParams(window.location.search);
  const successVal = params.get('success');
  if (successVal) {
    window.showToast(successVal, 'success');
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }
  if (params.get('error')) {
    window.showToast(decodeURIComponent(params.get('error')), 'error');
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }
</script>

<script define:vars={{ sectionStudentsLogs }}>
  // Save section log details to window
  window.sectionStudentsLogs = sectionStudentsLogs || [];

  const progressModal = document.getElementById('student-progress-modal');
  const closeBtn = document.getElementById('close-progress-modal-btn');

  // Bind close trigger
  const closeProgressModal = () => {
    if (progressModal) {
      progressModal.classList.remove('active');
      document.body.style.overflow = '';
    }
  };
  closeBtn?.addEventListener('click', closeProgressModal);
  progressModal?.addEventListener('click', (e) => {
    if (e.target === progressModal) closeProgressModal();
  });

  // Bind View Student Progress buttons
  document.querySelectorAll('.view-progress-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const userId = btn.getAttribute('data-user-id');
      const student = window.sectionStudentsLogs.find(s => s.userId === userId);
      if (!student) return;

      // Populate Modal Fields
      document.getElementById('progress-modal-name').innerText = student.userName;
      document.getElementById('progress-modal-program').innerText = student.program;
      document.getElementById('progress-modal-company').innerText = student.company;
      document.getElementById('progress-modal-start').innerText = student.startDate !== 'N/A' ? new Date(student.startDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : 'N/A';
      document.getElementById('progress-modal-supervisor').innerText = student.supervisor;
      document.getElementById('progress-modal-position').innerText = student.supervisorPosition;

      // Format Hours Rendered
      const renderedStr = formatHMS(Math.floor(student.renderedHours * 3600));
      const targetStr = formatHMS(Math.floor(student.targetHours * 3600));
      document.getElementById('progress-modal-hours').innerText = `${renderedStr} / ${targetStr} (${student.percent}%)`;
      
      // Update Progress Bar
      document.getElementById('progress-modal-bar').style.width = `${student.percent}%`;

      // Update Avatars
      const avatarImg = document.getElementById('progress-modal-avatar');
      const avatarFallback = document.getElementById('progress-modal-avatar-fallback');
      if (student.userPicture) {
        avatarImg.src = student.userPicture;
        avatarImg.style.display = 'block';
        avatarFallback.style.display = 'none';
      } else {
        avatarImg.style.display = 'none';
        avatarFallback.style.display = 'flex';
        avatarFallback.innerText = student.userName.charAt(0).toUpperCase();
      }

      // Populate Logs Table
      const logsBody = document.getElementById('progress-modal-logs-body');
      logsBody.innerHTML = '';

      if (student.entries && student.entries.length > 0) {
        student.entries.forEach(entry => {
          const row = document.createElement('tr');
          
          // Date & Time Cell
          const timeText = `${entry.startTime} - ${entry.endTime}`;
          const dateD = new Date(entry.date);
          const dateText = dateD.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
          const durationStr = formatHMS(entry.durationSeconds);
          
          const dtCell = document.createElement('td');
          dtCell.style.padding = '12px 14px';
          dtCell.style.borderBottom = '1px solid var(--border-subtle)';
          dtCell.innerHTML = `
            <div style="font-weight: 600; color: #fff; font-size: 13px;">${dateText}</div>
            <div style="font-size: 11px; color: var(--text-secondary); margin-top: 2px;">${timeText} (${durationStr})</div>
          `;
          row.appendChild(dtCell);

          // Source Cell
          const srcCell = document.createElement('td');
          srcCell.style.padding = '12px 14px';
          srcCell.style.borderBottom = '1px solid var(--border-subtle)';
          const badgeClass = entry.type === 'clockify' ? 'status-badge active' : 'status-badge';
          const badgeName = entry.type === 'clockify' ? 'Clockify' : 'Manual';
          srcCell.innerHTML = `<span class="${badgeClass}" style="font-size: 9px; padding: 2px 6px;">${badgeName}</span>`;
          row.appendChild(srcCell);

          // Description Cell
          const descCell = document.createElement('td');
          descCell.style.padding = '12px 14px';
          descCell.style.borderBottom = '1px solid var(--border-subtle)';
          descCell.style.fontSize = '13px';
          descCell.style.color = 'var(--text-primary)';
          descCell.innerText = entry.description || 'General Work';
          row.appendChild(descCell);

          // Documentation Cell
          const docCell = document.createElement('td');
          docCell.style.padding = '12px 14px';
          docCell.style.borderBottom = '1px solid var(--border-subtle)';
          if (entry.documentationUrls && entry.documentationUrls.length > 0) {
            const docBtn = document.createElement('button');
            docBtn.className = 'view-proof-btn';
            docBtn.dataset.urls = JSON.stringify(entry.documentationUrls);
            docBtn.dataset.label = entry.description || 'Activity Proof';
            const count = entry.documentationUrls.length;
            docBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg> View Proof${count > 1 ? ` (${count})` : ''}`;
            docCell.appendChild(docBtn);
          } else {
            docCell.innerHTML = `<span style="font-size: 11px; color: var(--text-secondary); font-style: italic;">No proof</span>`;
          }
          row.appendChild(docCell);

          logsBody.appendChild(row);
        });
      } else {
        const row = document.createElement('tr');
        row.innerHTML = `<td colspan="4" style="text-align: center; padding: 30px; color: var(--text-secondary); font-style: italic; font-size: 13px;">No activity logs found for this student.</td>`;
        logsBody.appendChild(row);
      }

      // Show modal
      if (progressModal) {
        progressModal.classList.add('active');
        document.body.style.overflow = 'hidden';
      }
    });
  });

  // Helper function to format seconds to HH:MM:SS
  function formatHMS(seconds) {
    const h = Math.floor(seconds / 3600);
    const m = Math.floor((seconds % 3600) / 60);
    const s = Math.floor(seconds % 60);
    return `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
  }

  // ---- Documentation Viewer Modal ----
  const docModal = document.getElementById('doc-viewer-modal');
  const closeDocBtn = document.getElementById('close-doc-viewer-btn');
  const docImg = document.getElementById('doc-viewer-img');
  const docNoPreview = document.getElementById('doc-viewer-no-preview');
  const docOpenLink = document.getElementById('doc-viewer-open-link');
  const docLabel = document.getElementById('doc-viewer-label');
  const docCounter = document.getElementById('doc-viewer-counter');
  const docThumbsEl = document.getElementById('doc-viewer-thumbs');
  const docNavEl = document.getElementById('doc-viewer-nav');
  const docNavLabel = document.getElementById('doc-nav-label');
  const docPrevBtn = document.getElementById('doc-prev-btn');
  const docNextBtn = document.getElementById('doc-next-btn');
  const docExternal = document.getElementById('doc-viewer-external');

  let docUrls = [];
  let docIndex = 0;

  const IMAGE_EXTS = ['jpg', 'jpeg', 'png', 'gif', 'webp', 'svg', 'bmp'];
  function isImage(url) {
    const ext = url.split('?')[0].split('.').pop().toLowerCase();
    return IMAGE_EXTS.includes(ext);
  }

  function loadDocAtIndex(idx) {
    docIndex = idx;
    const url = docUrls[idx];
    docExternal.href = url;
    if (isImage(url)) {
      docImg.src = url;
      docImg.style.display = 'block';
      docNoPreview.style.display = 'none';
    } else {
      docImg.style.display = 'none';
      docOpenLink.href = url;
      docNoPreview.style.display = 'flex';
      docNoPreview.style.flexDirection = 'column';
      docNoPreview.style.alignItems = 'center';
    }
    // Update nav label
    if (docUrls.length > 1) {
      docNavLabel.textContent = `${idx + 1} of ${docUrls.length}`;
      docCounter.textContent = `Showing ${idx + 1} of ${docUrls.length} files`;
      // Highlight active thumb
      docThumbsEl.querySelectorAll('.doc-thumb').forEach((t, i) => {
        t.style.borderColor = i === idx ? 'var(--ntv-orange)' : 'rgba(255,255,255,0.1)';
        t.style.opacity = i === idx ? '1' : '0.5';
      });
    }
  }

  function openDocViewer(urls, label) {
    docUrls = urls;
    docIndex = 0;
    docLabel.textContent = label;

    // Thumbnails strip
    docThumbsEl.innerHTML = '';
    if (urls.length > 1) {
      docThumbsEl.style.display = 'flex';
      docNavEl.style.display = 'flex';
      docCounter.style.display = 'block';
      urls.forEach((url, i) => {
        const thumb = document.createElement('button');
        thumb.className = 'doc-thumb';
        thumb.style.cssText = 'flex-shrink:0;width:64px;height:64px;border-radius:8px;border:2px solid rgba(255,255,255,0.1);background:rgba(0,0,0,0.3);overflow:hidden;cursor:pointer;padding:0;transition:all 0.2s;';
        if (isImage(url)) {
          const tImg = document.createElement('img');
          tImg.src = url;
          tImg.style.cssText = 'width:100%;height:100%;object-fit:cover;';
          thumb.appendChild(tImg);
        } else {
          thumb.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="1.5" style="margin:auto;display:block;margin-top:20px"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>';
        }
        thumb.addEventListener('click', () => loadDocAtIndex(i));
        docThumbsEl.appendChild(thumb);
      });
    } else {
      docThumbsEl.style.display = 'none';
      docNavEl.style.display = 'none';
      docCounter.style.display = 'none';
    }

    loadDocAtIndex(0);
    docModal.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  const closeDocViewer = () => {
    docModal.classList.remove('active');
  };

  closeDocBtn?.addEventListener('click', closeDocViewer);
  docModal?.addEventListener('click', (e) => { if (e.target === docModal) closeDocViewer(); });
  docPrevBtn?.addEventListener('click', () => { if (docIndex > 0) loadDocAtIndex(docIndex - 1); });
  docNextBtn?.addEventListener('click', () => { if (docIndex < docUrls.length - 1) loadDocAtIndex(docIndex + 1); });

  // Delegated click for dynamically-created view-proof-btn
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.view-proof-btn');
    if (!btn) return;
    e.stopPropagation();
    const urls = JSON.parse(btn.dataset.urls || '[]');
    const label = btn.dataset.label || 'Activity Proof';
    if (urls.length > 0) openDocViewer(urls, label);
  });
</script>

