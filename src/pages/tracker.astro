---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import { getSession } from '../lib/auth';
import { parse } from 'cookie';
import { getManualEntries, addManualEntry, deleteManualEntry, updateManualEntry } from '../lib/entries';
import { getClockifyUser, getClockifyDetailedEntries } from '../lib/clockify';

import { getAppSettings } from '../lib/settings';
import { formatHours, formatHMS } from '../lib/utils';

const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookies = parse(cookieHeader);
const user = cookies.session ? await getSession(cookies.session) : null;

if (!user) return Astro.redirect('/');

const settings = await getAppSettings(user.id);
if (settings.role === 'coordinator') return Astro.redirect('/coordinator');

let userInClockify = false;
let clockifyEntries: any[] = [];
if (settings.clockifyEnabled !== false) {
  try {
    if (import.meta.env.CLOCKIFY_API_KEY) {
      const clockifyUser = await getClockifyUser(user.email);
      if (clockifyUser) {
        userInClockify = true;
        clockifyEntries = await getClockifyDetailedEntries(clockifyUser.id, settings.startDate);
      }
    }
  } catch (e) {
    userInClockify = false;
  }
}

const convert12to24 = (timeStr: string, ampm: string) => {
  if (!timeStr) return '';
  const [hoursStr, minutesStr] = timeStr.split(':');
  let hours = parseInt(hoursStr, 10);
  const minutes = minutesStr || '00';
  if (ampm === 'PM' && hours < 12) {
    hours += 12;
  } else if (ampm === 'AM' && hours === 12) {
    hours = 0;
  }
  return `${String(hours).padStart(2, '0')}:${minutes}`;
};

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');



  if (action === 'add') {
    const description = formData.get('description') as string;
    const date = formData.get('date') as string;
    const startTimeRaw = formData.get('startTime') as string;
    const endTimeRaw = formData.get('endTime') as string;
    const startAmpm = formData.get('startAmpm') as string;
    const endAmpm = formData.get('endAmpm') as string;

    const documentationUrlsRaw = formData.get('documentationUrls') as string;
    const documentationUrls = documentationUrlsRaw ? JSON.parse(documentationUrlsRaw) : [];

    const startTime = convert12to24(startTimeRaw, startAmpm);
    const endTime = convert12to24(endTimeRaw, endAmpm);
    try {
      await addManualEntry({ userId: user.id, description, date, startTime, endTime, documentationUrls });
      const { addSyncLog } = await import('../lib/logs');
      await addSyncLog({ userId: user.id, type: 'Mode', status: 'Success', details: `Manual entry added: ${description || 'No description'}` });
      return Astro.redirect('/tracker?success=Manual entry added');
    } catch (e) {
      return Astro.redirect(`/tracker?error=${encodeURIComponent(e.message)}`);
    }
  }

  if (action === 'edit') {
    const id = formData.get('id') as string;
    const description = formData.get('description') as string;
    const date = formData.get('date') as string;
    const startTimeRaw = formData.get('startTime') as string;
    const endTimeRaw = formData.get('endTime') as string;
    const startAmpm = formData.get('startAmpm') as string;
    const endAmpm = formData.get('endAmpm') as string;

    const documentationUrlsRaw = formData.get('documentationUrls') as string;
    const documentationUrls = documentationUrlsRaw ? JSON.parse(documentationUrlsRaw) : [];

    const startTime = convert12to24(startTimeRaw, startAmpm);
    const endTime = convert12to24(endTimeRaw, endAmpm);
    try {
      await updateManualEntry(id, { description, date, startTime, endTime, documentationUrls });
      const { addSyncLog } = await import('../lib/logs');
      await addSyncLog({ userId: user.id, type: 'Mode', status: 'Success', details: `Entry updated: ${description || 'No description'}` });
      return Astro.redirect('/tracker?success=Activity log updated');
    } catch (e) {
      return Astro.redirect(`/tracker?error=${encodeURIComponent(e.message)}`);
    }
  }

  if (action === 'delete') {
    const id = formData.get('id') as string;
    await deleteManualEntry(id);
    const { addSyncLog } = await import('../lib/logs');
    await addSyncLog({ userId: user.id, type: 'Mode', status: 'Warning', details: 'Manual entry deleted' });
    return Astro.redirect('/tracker?success=Activity log deleted');
  }
}

const manualEntries = await getManualEntries(user.id);

const startDateParam = Astro.url.searchParams.get('startDate') || '';
const endDateParam = Astro.url.searchParams.get('endDate') || '';
const sourceParam = Astro.url.searchParams.get('source') || 'all';

// Merge manual entries and Clockify entries
const allEntries = [
  ...manualEntries.map(e => ({ ...e, type: 'manual' as const })),
  ...clockifyEntries.map(e => ({ ...e, type: 'clockify' as const }))
];

let filteredEntries = allEntries;
if (startDateParam) {
  filteredEntries = filteredEntries.filter(e => e.date >= startDateParam);
}
if (endDateParam) {
  filteredEntries = filteredEntries.filter(e => e.date <= endDateParam);
}
if (sourceParam === 'manual') {
  filteredEntries = filteredEntries.filter(e => e.type === 'manual');
} else if (sourceParam === 'clockify') {
  filteredEntries = filteredEntries.filter(e => e.type === 'clockify');
}

const totalSeconds = filteredEntries.reduce((acc, e) => acc + e.durationSeconds, 0);

// Group entries by Month and Date
const sortedEntries = [...filteredEntries].sort((a, b) => {
  const dateCompare = b.date.localeCompare(a.date);
  if (dateCompare !== 0) return dateCompare;
  return b.startTime.localeCompare(a.startTime);
});

// Pagination setup
const pageSize = 15;
const pageParam = parseInt(Astro.url.searchParams.get('page') || '1', 10);
const totalEntriesCount = sortedEntries.length;
const totalPages = Math.ceil(totalEntriesCount / pageSize);
const currentPage = Math.max(1, Math.min(pageParam, totalPages || 1));

const paginatedEntries = totalEntriesCount > 0
  ? sortedEntries.slice((currentPage - 1) * pageSize, currentPage * pageSize)
  : [];

const getWeekRangeLabel = (dateStr: string) => {
  const dateObj = new Date(dateStr + 'T00:00:00+08:00');
  const day = dateObj.getDay(); // 0 = Sunday, 1 = Monday, ... 6 = Saturday
  
  // Calculate Monday of the week
  const monday = new Date(dateObj);
  const diffToMonday = day === 0 ? -6 : 1 - day;
  monday.setDate(dateObj.getDate() + diffToMonday);
  
  // Calculate Sunday of the week
  const sunday = new Date(monday);
  sunday.setDate(monday.getDate() + 6);
  
  const options: Intl.DateTimeFormatOptions = { month: 'short', day: 'numeric', timeZone: 'Asia/Manila' };
  const startStr = monday.toLocaleDateString('en-US', options);
  const endStr = sunday.toLocaleDateString('en-US', options);
  
  const yyyy = monday.getFullYear();
  const mm = String(monday.getMonth() + 1).padStart(2, '0');
  const dd = String(monday.getDate()).padStart(2, '0');
  const key = `${yyyy}-${mm}-${dd}`;
  
  return {
    key,
    label: `Week of ${startStr} – ${endStr}, ${yyyy}`
  };
};

interface DateGroup {
  dateKey: string;
  dateDisplay: string;
  totalSeconds: number;
  entries: typeof allEntries;
}

interface WeekGroup {
  weekKey: string;
  weekDisplay: string;
  totalSeconds: number;
  dateGroups: DateGroup[];
}

interface MonthGroup {
  monthKey: string; // YYYY-MM
  monthName: string;
  totalSeconds: number;
  weekGroups: WeekGroup[];
}

const monthsMap = new Map<string, MonthGroup>();

for (const entry of paginatedEntries) {
  const monthKey = entry.date.substring(0, 7); // "YYYY-MM"
  const dateKey = entry.date; // "YYYY-MM-DD"
  const { key: weekKey, label: weekDisplay } = getWeekRangeLabel(entry.date);

  // 1. Resolve Month Group
  if (!monthsMap.has(monthKey)) {
    const [year, month] = monthKey.split('-');
    const monthNames = [
      'January', 'February', 'March', 'April', 'May', 'June',
      'July', 'August', 'September', 'October', 'November', 'December'
    ];
    const monthName = `${monthNames[parseInt(month, 10) - 1]} ${year}`;
    monthsMap.set(monthKey, {
      monthKey,
      monthName,
      totalSeconds: 0,
      weekGroups: []
    });
  }

  const monthGroup = monthsMap.get(monthKey)!;
  monthGroup.totalSeconds += entry.durationSeconds;

  // 2. Resolve Week Group within Month
  let weekGroup = monthGroup.weekGroups.find(wg => wg.weekKey === weekKey);
  if (!weekGroup) {
    weekGroup = {
      weekKey,
      weekDisplay,
      totalSeconds: 0,
      dateGroups: []
    };
    monthGroup.weekGroups.push(weekGroup);
  }
  weekGroup.totalSeconds += entry.durationSeconds;

  // 3. Resolve Date Group within Week
  let dateGroup = weekGroup.dateGroups.find(dg => dg.dateKey === dateKey);
  if (!dateGroup) {
    const dateObj = new Date(entry.date + 'T00:00:00+08:00');
    const options: Intl.DateTimeFormatOptions = { 
      weekday: 'long', 
      month: 'short', 
      day: 'numeric', 
      timeZone: 'Asia/Manila' 
    };
    const dateDisplay = dateObj.toLocaleDateString('en-US', options);

    dateGroup = {
      dateKey,
      dateDisplay,
      totalSeconds: 0,
      entries: []
    };
    weekGroup.dateGroups.push(dateGroup);
  }

  dateGroup.entries.push(entry);
  dateGroup.totalSeconds += entry.durationSeconds;
}

const groupedEntries = Array.from(monthsMap.values()).sort((a, b) => b.monthKey.localeCompare(a.monthKey));

groupedEntries.forEach(monthGroup => {
  monthGroup.weekGroups.sort((a, b) => b.weekKey.localeCompare(a.weekKey));
  monthGroup.weekGroups.forEach(weekGroup => {
    weekGroup.dateGroups.sort((a, b) => b.dateKey.localeCompare(a.dateKey));
  });
});

const formatTo24hr = (timeStr: string) => {
  if (!timeStr) return '';
  const parts = timeStr.split(':').map(Number);
  return parts.map(p => String(p).padStart(2, '0')).join(':');
};
---

<Layout>
  <Header user={user} />
  <div id="portal-body">
    <Sidebar user={user} activeTab="tracker" role={settings.role} />
    <main id="portal-main">
      <div class="bg-grid" aria-hidden="true"></div>
      <div class="bg-glow" aria-hidden="true"></div>
      
      <div id="tracker-content" class="content-center">
        <div class="page-header">
          <h1>Time <span class="accent">Tracker</span></h1>
          <p>Precision internship logging with professional progress tracking.</p>
        </div>

          <div class="tracker-layout">
            {userInClockify && (
              <div class="sync-mode-notice">
                <div class="notice-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 12a9 9 0 0 1-9 9m9-9a9 9 0 0 0-9-9m9 9H3m9 9a9 9 0 0 1-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/></svg>
                </div>
                <div class="notice-text">
                  <strong>Clockify Sync Active:</strong> Your logs are synchronized in real-time. Manual entries can still be logged locally to supplement your records.
                </div>
              </div>
            )}

            {settings.clockifyEnabled === false && (
              <div class="manual-mode-notice">
                <div class="notice-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
                </div>
                <div class="notice-text">
                  <strong>Manual Mode Active:</strong> Clockify integration is currently disabled. You are tracking time directly in this system. <a href="/settings" class="notice-link">Manage Integration</a>
                </div>
              </div>
            )}
            


            <!-- Metrics & History Grid -->
            <div class="content-grid">
              <!-- Left: History -->
              <div class="history-column">
                <div class="history-header">
                  <div class="history-header-top">
                    <h2 class="column-title">Activity Logs</h2>
                  </div>
                  
                  <div class="history-header-filters">
                    {userInClockify && (
                      <div class="source-filter-tabs">
                        <button 
                          class={`filter-tab ${sourceParam === 'all' ? 'active' : ''}`}
                          onclick="window.setSourceFilter('all')"
                        >
                          All
                        </button>
                        <button 
                          class={`filter-tab ${sourceParam === 'clockify' ? 'active' : ''}`}
                          onclick="window.setSourceFilter('clockify')"
                        >
                          Clockify
                        </button>
                        <button 
                          class={`filter-tab ${sourceParam === 'manual' ? 'active' : ''}`}
                          onclick="window.setSourceFilter('manual')"
                        >
                          Manual
                        </button>
                      </div>
                    )}
                    
                    <div class="date-filters">
                      <div class="date-input-group">
                        <label for="filter-start-date">From</label>
                        <input 
                          type="date" 
                          id="filter-start-date" 
                          value={startDateParam} 
                          class="filter-date-input"
                        />
                      </div>
                      <div class="date-input-group">
                        <label for="filter-end-date">To</label>
                        <input 
                          type="date" 
                          id="filter-end-date" 
                          value={endDateParam} 
                          class="filter-date-input"
                        />
                      </div>
                      <button type="button" class="btn-apply-filter" id="btn-apply-filters">Apply</button>
                      {(startDateParam || endDateParam) && (
                        <button type="button" class="btn-clear-filter" id="btn-reset-filters" title="Clear Filters">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                          Clear
                        </button>
                      )}
                    </div>
                  </div>
                </div>

                <div class="log-list">
                  {groupedEntries.length > 0 ? groupedEntries.map(group => (
                    <div class="month-group">
                      <div class="month-header">
                        <span class="month-name">{group.monthName}</span>
                        <div class="month-header-right">
                          <span class="month-hours">{formatHours(group.totalSeconds / 3600)}</span>
                          <button
                            type="button"
                            class="ai-summary-trigger ai-btn-monthly"
                            title="Generate Monthly AI Journal Summary"
                            data-type="month"
                            data-label={group.monthName}
                            data-entries={JSON.stringify(group.weekGroups.flatMap(wg => wg.dateGroups.flatMap(dg => dg.entries.map(e => ({ date: e.date, description: e.description, durationSeconds: e.durationSeconds })))))}
                          >
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                              <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>
                            </svg>
                            AI Summary
                          </button>
                        </div>
                      </div>
                      <div class="month-weeks">
                        {group.weekGroups.map(weekGroup => (
                          <div class="week-group">
                            <div class="week-header">
                              <span class="week-name">{weekGroup.weekDisplay}</span>
                              <div class="week-header-right">
                                <span class="week-hours">{formatHours(weekGroup.totalSeconds / 3600)}</span>
                                <button
                                  type="button"
                                  class="ai-summary-trigger ai-btn-weekly"
                                  title="Generate Weekly AI Journal Summary"
                                  data-type="week"
                                  data-label={weekGroup.weekDisplay}
                                  data-entries={JSON.stringify(weekGroup.dateGroups.flatMap(dg => dg.entries.map(e => ({ date: e.date, description: e.description, durationSeconds: e.durationSeconds }))))}
                                >
                                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>
                                  </svg>
                                  AI Summary
                                </button>
                              </div>
                            </div>
                            <div class="week-dates">
                              {weekGroup.dateGroups.map(dateGroup => (
                                <div class="date-group-card">
                                  <div class="date-group-header">
                                    <span class="date-group-title">{dateGroup.dateDisplay}</span>
                                    <div class="date-group-header-right">
                                      <span class="date-group-hours">{formatHours(dateGroup.totalSeconds / 3600)}</span>
                                      <button
                                        type="button"
                                        class="ai-summary-trigger ai-btn-daily"
                                        title="Generate Daily AI Journal Summary"
                                        data-type="day"
                                        data-label={dateGroup.dateDisplay}
                                        data-entries={JSON.stringify(dateGroup.entries.map(e => ({ date: e.date, description: e.description, durationSeconds: e.durationSeconds })))}
                                      >
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                          <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>
                                        </svg>
                                      </button>
                                    </div>
                                  </div>
                                  <div class="shift-list">
                                    {dateGroup.entries.map(entry => (
                                      <div class="shift-item">
                                        <div class="shift-info">
                                          <div class="shift-title-row">
                                            <span class="shift-title">{entry.description || 'General Work'}</span>
                                            {userInClockify && (
                                              <span class={`source-badge ${entry.type}`}>
                                                {entry.type === 'clockify' ? 'Clockify' : 'Manual'}
                                              </span>
                                            )}
                                          </div>
                                          <div class="shift-sub">
                                            <span class="time">{formatTo24hr(entry.startTime)} — {formatTo24hr(entry.endTime)}</span>
                                          </div>
                                          {entry.documentationUrls && entry.documentationUrls.length > 0 && (
                                            <div class="entry-doc-preview">
                                              {entry.documentationUrls.map(url => (
                                                <div class="doc-thumb-container">
                                                  <a href={url} target="_blank" class="doc-thumb-link" title="View documentation">
                                                    <img src={url} alt="Proof" class="doc-thumb" />
                                                  </a>
                                                  <a href={`/api/download?url=${encodeURIComponent(url)}`} class="doc-download-btn" title="Download proof">
                                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                                  </a>
                                                </div>
                                              ))}
                                            </div>
                                          )}
                                        </div>
                                        <div class="shift-actions">
                                          <span class="shift-hours">{formatHours(entry.durationSeconds / 3600)}</span>
                                          {entry.type === 'manual' ? (
                                            <div class="action-group">
                                              <button 
                                                class="edit-icon" 
                                                title="Edit Entry"
                                                onclick={`window.openEditModal('${entry.id}', '${entry.description.replace(/'/g, "\\'")}', '${entry.date}', '${entry.startTime}', '${entry.endTime}', ${JSON.stringify(entry.documentationUrls)})`}
                                              >
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                              </button>
                                              <button 
                                                type="button"
                                                class="delete-icon" 
                                                onclick={`window.openDeleteModal('${entry.id}')`}
                                              >
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                              </button>
                                            </div>
                                          ) : (
                                            <div class="action-group read-only" title="Synced from Clockify">
                                              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="sync-lock-icon">
                                                <path d="M21 12a9 9 0 0 1-9 9m9-9a9 9 0 0 0-9-9m9 9H3m9 9a9 9 0 0 1-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/>
                                              </svg>
                                            </div>
                                          )}
                                        </div>
                                      </div>
                                    ))}
                                  </div>
                                </div>
                              ))}
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  )) : (
                    <div class="empty-list">No activity logs found for the selected filter.</div>
                  )}
                </div>
                
                {totalPages > 1 && (
                  <div class="pagination-controls">
                    <button 
                      type="button"
                      class="pagination-btn"
                      disabled={currentPage <= 1}
                      onclick={`window.changePage(${currentPage - 1})`}
                      title="Previous Page"
                    >
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
                    </button>
                    
                    <span class="pagination-info">
                      Page <strong>{currentPage}</strong> of <strong>{totalPages}</strong> ({totalEntriesCount} logs)
                    </span>
                    
                    <button 
                      type="button"
                      class="pagination-btn"
                      disabled={currentPage >= totalPages}
                      onclick={`window.changePage(${currentPage + 1})`}
                      title="Next Page"
                    >
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                    </button>
                  </div>
                )}
              </div>

              <!-- Right: Sidebar Tools -->
              <div class="sidebar-column">
                <div class="stats-box">
                  <div class="stat-item">
                    <span class="field-label">TOTAL RENDERED</span>
                    <div class="stat-value">{formatHours(totalSeconds / 3600)}</div>
                  </div>
                </div>

                <div class="manual-add-box">
                  <h3 class="box-title">Manual Adjustment</h3>
                  <form method="POST" class="side-form">
                    <input type="hidden" name="action" value="add" />
                    <input type="hidden" name="documentationUrls" id="add-doc-urls" value="[]" />
                    <div class="input-group">
                      <label>Task Description</label>
                      <input type="text" name="description" placeholder="What did you do?" required />
                    </div>
                    <div class="input-group">
                      <label>Date</label>
                      <input type="date" name="date" value={new Date().toLocaleDateString('en-CA', { timeZone: 'Asia/Manila' })} required />
                    </div>
                    <div class="input-row time-12hr-row">
                      <div class="input-group">
                        <label>Start Time</label>
                        <div class="time-12hr-wrapper">
                          <input type="text" name="startTime" placeholder="08:00" pattern="(0?[1-9]|1[0-2]):[0-5][0-9]" maxlength="5" class="time-mask" required />
                          <button type="button" class="ampm-toggle-btn" data-input-name="startAmpm">AM</button>
                          <input type="hidden" name="startAmpm" value="AM" />
                        </div>
                      </div>
                      <div class="input-group">
                        <label>End Time</label>
                        <div class="time-12hr-wrapper">
                          <input type="text" name="endTime" placeholder="05:00" pattern="(0?[1-9]|1[0-2]):[0-5][0-9]" maxlength="5" class="time-mask" required />
                          <button type="button" class="ampm-toggle-btn active" data-input-name="endAmpm">PM</button>
                          <input type="hidden" name="endAmpm" value="PM" />
