---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import { getSession } from '../lib/auth';
import { parse } from 'cookie';
import { getManualEntries, addManualEntry, deleteManualEntry, updateManualEntry, getActiveTimer, startTimer, stopTimer, updateTimerStart } from '../lib/entries';
import { getClockifyUser } from '../lib/clockify';

import { getAppSettings } from '../lib/settings';
import { formatHours, formatHMS } from '../lib/utils';

const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookies = parse(cookieHeader);
const user = cookies.session ? await getSession(cookies.session) : null;

if (!user) return Astro.redirect('/');

const settings = await getAppSettings(user.id);
if (settings.role === 'coordinator') return Astro.redirect('/coordinator');

let userInClockify = false;
if (settings.clockifyEnabled !== false) {
  try {
    if (import.meta.env.CLOCKIFY_API_KEY) {
      const clockifyUser = await getClockifyUser(user.email);
      userInClockify = !!clockifyUser;
    }
  } catch (e) {
    userInClockify = false;
  }
}

const convert12to24 = (timeStr: string, ampm: string) => {
  if (!timeStr) return '';
  const [hoursStr, minutesStr] = timeStr.split(':');
  let hours = parseInt(hoursStr, 10);
  const minutes = minutesStr || '00';
  if (ampm === 'PM' && hours < 12) {
    hours += 12;
  } else if (ampm === 'AM' && hours === 12) {
    hours = 0;
  }
  return `${String(hours).padStart(2, '0')}:${minutes}`;
};

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'start-timer' && !userInClockify) {
    const desc = formData.get('description') as string;
    await startTimer(user.id, desc);
    return Astro.redirect('/tracker?success=Timer started');
  }

  if (action === 'update-start' && !userInClockify) {
    const newStart = formData.get('startTime') as string;
    await updateTimerStart(user.id, newStart);
    return Astro.redirect('/tracker?success=Start time updated');
  }

  if (action === 'stop-timer' && !userInClockify) {
    const desc = formData.get('description') as string;
    try {
      await stopTimer(user.id, desc);
      const { addSyncLog } = await import('../lib/logs');
      await addSyncLog({ userId: user.id, type: 'Sync', status: 'Success', details: `Timer stopped: ${desc || 'No description'}` });
      return Astro.redirect('/tracker?success=Activity log saved');
    } catch (e) {
      return Astro.redirect(`/tracker?error=${encodeURIComponent(e.message)}`);
    }
  }

  if (action === 'add' && !userInClockify) {
    const description = formData.get('description') as string;
    const date = formData.get('date') as string;
    const startTimeRaw = formData.get('startTime') as string;
    const endTimeRaw = formData.get('endTime') as string;
    const startAmpm = formData.get('startAmpm') as string;
    const endAmpm = formData.get('endAmpm') as string;
    const startTime = convert12to24(startTimeRaw, startAmpm);
    const endTime = convert12to24(endTimeRaw, endAmpm);
    try {
      await addManualEntry({ userId: user.id, description, date, startTime, endTime });
      const { addSyncLog } = await import('../lib/logs');
      await addSyncLog({ userId: user.id, type: 'Mode', status: 'Success', details: `Manual entry added: ${description || 'No description'}` });
      return Astro.redirect('/tracker?success=Manual entry added');
    } catch (e) {
      return Astro.redirect(`/tracker?error=${encodeURIComponent(e.message)}`);
    }
  }

  if (action === 'edit' && !userInClockify) {
    const id = formData.get('id') as string;
    const description = formData.get('description') as string;
    const date = formData.get('date') as string;
    const startTimeRaw = formData.get('startTime') as string;
    const endTimeRaw = formData.get('endTime') as string;
    const startAmpm = formData.get('startAmpm') as string;
    const endAmpm = formData.get('endAmpm') as string;
    const startTime = convert12to24(startTimeRaw, startAmpm);
    const endTime = convert12to24(endTimeRaw, endAmpm);
    try {
      await updateManualEntry(id, { description, date, startTime, endTime });
      const { addSyncLog } = await import('../lib/logs');
      await addSyncLog({ userId: user.id, type: 'Mode', status: 'Success', details: `Entry updated: ${description || 'No description'}` });
      return Astro.redirect('/tracker?success=Activity log updated');
    } catch (e) {
      return Astro.redirect(`/tracker?error=${encodeURIComponent(e.message)}`);
    }
  }

  if (action === 'delete') {
    const id = formData.get('id') as string;
    await deleteManualEntry(id);
    const { addSyncLog } = await import('../lib/logs');
    await addSyncLog({ userId: user.id, type: 'Mode', status: 'Warning', details: 'Manual entry deleted' });
    return Astro.redirect('/tracker?success=Activity log deleted');
  }
}

const entries = await getManualEntries(user.id);
const activeTimer = await getActiveTimer(user.id);
const totalSeconds = entries.reduce((acc, e) => acc + e.durationSeconds, 0);

const formatTo24hr = (timeStr: string) => {
  if (!timeStr) return '';
  const parts = timeStr.split(':').map(Number);
  return parts.map(p => String(p).padStart(2, '0')).join(':');
};
---

<Layout>
  <Header user={user} />
  <div id="portal-body">
    <Sidebar user={user} activeTab="tracker" role={settings.role} />
    <main id="portal-main">
      <div class="bg-grid" aria-hidden="true"></div>
      <div class="bg-glow" aria-hidden="true"></div>
      
      <div id="tracker-content" class="content-center">
        <div class="page-header">
          <h1>Time <span class="accent">Tracker</span></h1>
          <p>Precision internship logging with professional progress tracking.</p>
        </div>

        {userInClockify ? (
          <div class="sync-status-card">
            <div class="sync-icon-wrapper">
              <div class="sync-glow"></div>
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12a9 9 0 0 1-9 9m9-9a9 9 0 0 0-9-9m9 9H3m9 9a9 9 0 0 1-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/>
              </svg>
            </div>
            <div class="sync-content">
              <div class="sync-badge">SYSTEM CLOUD SYNC</div>
              <h3>External Workspace Active</h3>
              <p>Manual tracking is currently locked because your session is being synchronized with the official Clockify workspace. This ensures 100% data integrity for your internship records.</p>
              <div class="sync-meta">
                <span class="pulse-dot green"></span>
                <span>Real-time synchronization active</span>
              </div>
            </div>
          </div>
        ) : (
          <div class="tracker-layout">
            {settings.clockifyEnabled === false && (
              <div class="manual-mode-notice">
                <div class="notice-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
                </div>
                <div class="notice-text">
                  <strong>Manual Mode Active:</strong> Clockify integration is currently disabled. You are tracking time directly in this system. <a href="/settings" class="notice-link">Manage Integration</a>
                </div>
              </div>
            )}
            
            <!-- Main Timer Section -->
            <section class={`main-control ${activeTimer ? 'timer-active' : ''}`} data-start={activeTimer?.startTime}>
              <form method="POST" class="control-form" id="timer-main-form">
                <div class="task-input-wrapper">
                  <label class="field-label">CURRENT TASK</label>
                  <input 
                    type="text" 
                    name="description" 
                    placeholder="Enter what you are working on..." 
                    value={activeTimer?.description || ''} 
                    autocomplete="off"
                    class="main-task-input"
                  />
                </div>
                
                <div class="time-display-wrapper">
                  {activeTimer && (
                    <div class="edit-start-box">
                      <label class="field-label">STARTED AT</label>
                      <input 
                        class="inline-time-input time-mask"
                        maxlength="5"
                        value={new Date(activeTimer.startTime).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', timeZone: 'Asia/Manila' })} 
                        onchange="document.getElementById('action-hidden').value='update-start'; if (typeof this.form.requestSubmit === 'function') { this.form.requestSubmit(); } else { this.form.submit(); }"
                      />
                    </div>
                  )}
                  
                  <div class="elapsed-box">
                    <label class="field-label">RENDERED TIME</label>
                    <span id="live-timer-val" class="live-digits">00:00:00</span>
                  </div>

                  <input type="hidden" name="action" id="action-hidden" value={activeTimer ? "stop-timer" : "start-timer"} />
                  <input type="hidden" name="id" id="id-hidden" />

                  <div class="button-box">
                    {activeTimer ? (
                      <button type="submit" onclick="document.getElementById('action-hidden').value='stop-timer'" class="btn-primary stop">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="2"/></svg>
                        STOP TASK
                      </button>
                    ) : (
                      <button type="submit" onclick="document.getElementById('action-hidden').value='start-timer'" class="btn-primary start">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M5 3l14 9-14 9V3z"/></svg>
                        START TIMER
                      </button>
                    )}
                  </div>
                </div>
              </form>
            </section>

            <!-- Metrics & History Grid -->
            <div class="content-grid">
              <!-- Left: History -->
              <div class="history-column">
                <h2 class="column-title">Activity Logs</h2>
                <div class="log-list">
                  {entries.length > 0 ? entries.sort((a,b) => b.date.localeCompare(a.date)).map(entry => (
                    <div class="log-card">
                      <div class="log-info">
                        <span class="log-title">{entry.description || 'General Work'}</span>
                        <div class="log-sub">
                          <span class="date">{new Date(entry.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'Asia/Manila' })}</span>
                          <span class="dot">·</span>
                          <span class="time">{formatTo24hr(entry.startTime)} — {formatTo24hr(entry.endTime)}</span>
                        </div>
                      </div>
                      <div class="log-actions">
                        <span class="log-hours">{formatHours(entry.durationSeconds / 3600)}</span>
                        <div class="action-group">
                          <button 
                            class="edit-icon" 
                            title="Edit Entry"
                            onclick={`window.openEditModal('${entry.id}', '${entry.description}', '${entry.date}', '${entry.startTime}', '${entry.endTime}')`}
                          >
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                          </button>
                          <button 
                            type="button"
                            class="delete-icon" 
                            onclick={`window.openDeleteModal('${entry.id}')`}
                          >
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                          </button>
                        </div>
                      </div>
                    </div>
                  )) : (
                    <div class="empty-list">No manual logs recorded yet.</div>
                  )}
                </div>
              </div>

              <!-- Right: Sidebar Tools -->
              <div class="sidebar-column">
                <div class="stats-box">
                  <div class="stat-item">
                    <span class="field-label">TOTAL RENDERED</span>
                    <div class="stat-value">{formatHours(totalSeconds / 3600)}</div>
                  </div>
                </div>

                <div class="manual-add-box">
                  <h3 class="box-title">Manual Adjustment</h3>
                  <form method="POST" class="side-form">
                    <input type="hidden" name="action" value="add" />
                    <div class="input-group">
                      <label>Task Description</label>
                      <input type="text" name="description" placeholder="What did you do?" required />
                    </div>
                    <div class="input-group">
                      <label>Date</label>
                      <input type="date" name="date" value={new Date().toLocaleDateString('en-CA', { timeZone: 'Asia/Manila' })} required />
                    </div>
                    <div class="input-row time-12hr-row">
                      <div class="input-group">
                        <label>Start Time</label>
                        <div class="time-12hr-wrapper">
                          <input type="text" name="startTime" placeholder="08:00" pattern="(0?[1-9]|1[0-2]):[0-5][0-9]" maxlength="5" class="time-mask" required />
                          <select name="startAmpm" class="ampm-select">
                            <option value="AM">AM</option>
                            <option value="PM">PM</option>
                          </select>
                        </div>
                      </div>
                      <div class="input-group">
                        <label>End Time</label>
                        <div class="time-12hr-wrapper">
                          <input type="text" name="endTime" placeholder="05:00" pattern="(0?[1-9]|1[0-2]):[0-5][0-9]" maxlength="5" class="time-mask" required />
                          <select name="endAmpm" class="ampm-select">
                            <option value="AM">AM</option>
                            <option value="PM" selected>PM</option>
                          </select>
                        </div>
                      </div>
                    </div>
                    <p class="input-hint">Use 12-hour format (e.g., 08:00 AM to 05:00 PM)</p>
                    <button type="submit" class="btn-outline">Add Entry</button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        )}
      </div>

      <!-- Edit Entry Modal -->
      <div id="edit-modal" class="modal-overlay" style="display: none;">
        <div class="modal-content">
          <div class="modal-header">
            <h3>Edit Activity Log</h3>
            <button class="close-btn" onclick="document.getElementById('edit-modal').style.display='none'">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </button>
          </div>
          <form method="POST" class="edit-form">
            <input type="hidden" name="action" value="edit" />
            <input type="hidden" name="id" id="edit-id" />
            
            <div class="form-group">
              <label>Task Description</label>
              <input type="text" name="description" id="edit-desc" required />
            </div>
            <div class="form-group">
              <label>Date</label>
              <input type="date" name="date" id="edit-date" required />
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Start Time</label>
                <div class="time-12hr-wrapper">
                  <input type="text" name="startTime" id="edit-start" placeholder="08:00" pattern="(0?[1-9]|1[0-2]):[0-5][0-9]" maxlength="5" class="time-mask" required />
                  <select name="startAmpm" id="edit-start-ampm" class="ampm-select">
                    <option value="AM">AM</option>
                    <option value="PM">PM</option>
                  </select>
                </div>
              </div>
              <div class="form-group">
                <label>End Time</label>
                <div class="time-12hr-wrapper">
                  <input type="text" name="endTime" id="edit-end" placeholder="05:00" pattern="(0?[1-9]|1[0-2]):[0-5][0-9]" maxlength="5" class="time-mask" required />
                  <select name="endAmpm" id="edit-end-ampm" class="ampm-select">
                    <option value="AM">AM</option>
                    <option value="PM">PM</option>
                  </select>
                </div>
              </div>
            </div>
            <p class="input-hint mt-8">Use 12-hour format (e.g., 08:00 AM to 05:00 PM)</p>
            
            <div class="modal-actions">
              <button type="button" class="btn-cancel" onclick="document.getElementById('edit-modal').style.display='none'">Cancel</button>
              <button type="submit" class="btn-save">Save Changes</button>
            </div>
          </form>
        </div>
      </div>
      <!-- Delete Confirmation Modal -->
      <div id="delete-log-modal" class="modal-overlay" style="display: none;">
        <div class="modal-content">
          <div class="modal-header-danger">
            <div class="warning-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0zM12 9v4M12 17h.01"/></svg>
            </div>
            <h3>Delete log entry?</h3>
          </div>
          <p class="modal-desc">Are you sure you want to delete this record? This action cannot be undone.</p>
          <div class="modal-actions-stacked">
            <button type="button" class="btn-confirm-delete" onclick="window.confirmDelete()">Yes, Delete Log</button>
            <button type="button" class="btn-cancel" onclick="document.getElementById('delete-log-modal').style.display='none'">Cancel</button>
          </div>
        </div>
      </div>
  </div>
</Layout>

<script is:inline>
  const params = new URLSearchParams(window.location.search);
  const successVal = params.get('success');
  if (successVal) {
    const msg = successVal === 'true' ? 'Activity updated successfully' : successVal;
    window.showToast(msg, 'success');
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }
  if (params.get('error')) {
    window.showToast(decodeURIComponent(params.get('error')), 'error');
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }

  // Live Timer Setup
  let timerInterval = null;
  function initLiveTimer() {
    if (timerInterval) {
      clearInterval(timerInterval);
      timerInterval = null;
    }
    const timerSection = document.querySelector('.main-control');
    const timerVal = document.getElementById('live-timer-val');
    if (timerSection && timerSection.classList.contains('timer-active')) {
      const startTime = new Date(timerSection.dataset.start || '').getTime();
      if (startTime) {
        const tick = () => {
          const diff = Math.max(0, new Date().getTime() - startTime);
          const h = Math.floor(diff / 3600000);
          const m = Math.floor((diff % 3600000) / 60000);
          const s = Math.floor((diff % 60000) / 1000);
          if (timerVal) {
            timerVal.textContent = `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
          }
        };
        tick();
        timerInterval = setInterval(tick, 1000);
      }
    } else if (timerVal) {
      timerVal.textContent = "00:00:00";
    }
  }

  // Initialize timer on load
  initLiveTimer();

  function convert24to12(timeStr) {
    if (!timeStr) return { time: '', ampm: 'AM' };
    const parts = timeStr.split(':');
    let hours = parseInt(parts[0], 10);
    const minutes = parts[1] || '00';
    let ampm = 'AM';
    if (hours >= 12) {
      ampm = 'PM';
      if (hours > 12) hours -= 12;
    } else if (hours === 0) {
      hours = 12;
    }
    return {
      time: `${String(hours).padStart(2, '0')}:${minutes}`,
      ampm: ampm
    };
  }

  window.openEditModal = function(id, desc, date, start, end) {
    document.getElementById('edit-id').value = id;
    document.getElementById('edit-desc').value = desc;
    document.getElementById('edit-date').value = date;
    
    const start12 = convert24to12(start);
    document.getElementById('edit-start').value = start12.time;
    document.getElementById('edit-start-ampm').value = start12.ampm;
    
    const end12 = convert24to12(end);
    document.getElementById('edit-end').value = end12.time;
    document.getElementById('edit-end-ampm').value = end12.ampm;
    
    document.getElementById('edit-modal').style.display = 'flex';
  }

  let deleteTargetId = null;
  window.openDeleteModal = function(id) {
    deleteTargetId = id;
    document.getElementById('delete-log-modal').style.display = 'flex';
  }

  window.confirmDelete = function() {
    if (!deleteTargetId) return;
    document.getElementById('action-hidden').value = 'delete';
    document.getElementById('id-hidden').value = deleteTargetId;
    const form = document.getElementById('timer-main-form');
    if (form) {
      if (typeof form.requestSubmit === 'function') {
        form.requestSubmit();
      } else {
        form.submit();
      }
    }
  }

  // Intercept all POST form submissions on this page for AJAX swapping
  document.addEventListener('submit', async (e) => {
    const form = e.target;
    if (form && form.method.toUpperCase() === 'POST') {
      const actionAttr = form.getAttribute('action');
      if (actionAttr && actionAttr.startsWith('/api/')) {
        // Let standard API post requests happen normally (they redirect anyway)
        return;
      }
      
      e.preventDefault();
      await handleFormSubmit(form, e);
    }
  });

  async function handleFormSubmit(form, event) {
    const btn = form.querySelector('button[type="submit"]');
    
    if (btn) {
      btn.disabled = true;
      btn.style.opacity = '0.7';
    }

    try {
      const formData = new FormData(form);
      
      // If a specific submit button triggered the submission, append its action values
      if (event && event.submitter) {
        const submitter = event.submitter;
        if (submitter.name) {
          formData.append(submitter.name, submitter.value);
        }
      }

      const response = await fetch(window.location.pathname, {
        method: 'POST',
        body: formData
      });

      if (!response.ok) {
        throw new Error('Network response was not ok');
      }

      // Check if we were redirected to a completely different path (e.g., login page)
      const finalUrl = new URL(response.url);
      if (finalUrl.pathname !== window.location.pathname) {
        window.location.href = response.url;
        return;
      }

      const html = await response.text();
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, 'text/html');

      // 1. Swap main control (timer UI)
      const newMainControl = doc.querySelector('.main-control');
      const oldMainControl = document.querySelector('.main-control');
      if (newMainControl && oldMainControl) {
        oldMainControl.replaceWith(newMainControl);
      }

      // 2. Swap activity logs list
      const newLogList = doc.querySelector('.log-list');
      const oldLogList = document.querySelector('.log-list');
      if (newLogList && oldLogList) {
        oldLogList.replaceWith(newLogList);
      }

      // 3. Swap stats box
      const newStatsBox = doc.querySelector('.stats-box');
      const oldStatsBox = document.querySelector('.stats-box');
      if (newStatsBox && oldStatsBox) {
        oldStatsBox.replaceWith(newStatsBox);
      }

      // 4. Reset manual add form (if this was the one submitted)
      if (form.classList.contains('side-form')) {
        form.reset();
        const dateInput = form.querySelector('input[type="date"]');
        if (dateInput) {
          dateInput.value = new Date().toLocaleDateString('en-CA', { timeZone: 'Asia/Manila' });
        }
      }

      // 5. Close modals if they were open
      const editModal = document.getElementById('edit-modal');
      if (editModal) editModal.style.display = 'none';
      const deleteModal = document.getElementById('delete-log-modal');
      if (deleteModal) deleteModal.style.display = 'none';

      // Re-initialize live timer
      initLiveTimer();

      // Show toast if success/error parameter is in the redirect URL
      const successMsg = finalUrl.searchParams.get('success');
      const errorMsg = finalUrl.searchParams.get('error');
      if (successMsg) {
        window.showToast(decodeURIComponent(successMsg), 'success');
      } else if (errorMsg) {
        window.showToast(decodeURIComponent(errorMsg), 'error');
      }

    } catch (err) {
      console.error(err);
      window.showToast('An error occurred. Please try again.', 'error');
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.style.opacity = '';
      }
    }
  }

  // Time Masking Logic
  document.addEventListener('input', (e) => {
    if (e.target.classList.contains('time-mask')) {
      let val = e.target.value.replace(/\D/g, '');
      if (val.length > 4) val = val.slice(0, 4);
      
      // Auto-colon only for 4 digits as you type
      if (val.length === 4) {
        e.target.value = val.slice(0, 2) + ':' + val.slice(2);
      } else {
        e.target.value = val;
      }
    }
  });

  document.addEventListener('blur', (e) => {
    if (e.target.classList.contains('time-mask')) {
      let val = e.target.value.replace(/\D/g, '');
      if (val.length === 3) {
        // 800 -> 08:00
        e.target.value = '0' + val[0] + ':' + val.slice(1);
      } else if (val.length === 4) {
        // 1200 -> 12:00
        e.target.value = val.slice(0, 2) + ':' + val.slice(2);
      }
    }
  }, true);

  // Handle backspace
  document.addEventListener('keydown', (e) => {
    if (e.target.classList.contains('time-mask') && e.key === 'Backspace') {
      if (e.target.value.includes(':') && e.target.value.length === 5) {
         // Let normal backspace work
      }
    }
  });
</script>

