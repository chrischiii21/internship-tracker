              </div>
              <div class="form-group">
                <label>End Time</label>
                <div class="time-12hr-wrapper">
                  <input type="text" name="endTime" id="edit-end" placeholder="05:00" pattern="(0?[1-9]|1[0-2]):[0-5][0-9]" maxlength="5" class="time-mask" required />
                  <button type="button" class="ampm-toggle-btn" id="edit-end-ampm-btn" data-input-name="endAmpm">AM</button>
                  <input type="hidden" name="endAmpm" id="edit-end-ampm" value="AM" />
                </div>
              </div>
            </div>
            <p class="input-hint mt-8">Use 12-hour format (e.g., 08:00 to 05:00). Click the AM/PM badge next to the field to toggle AM/PM.</p>
            
            <div class="form-group">
              <label>Documentation / Proof (Images)</label>
              <div class="file-upload-zone" id="edit-upload-zone">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="upload-icon"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                <span>Click to upload or drag images</span>
                <input type="file" id="edit-file-input" multiple accept="image/*" class="hidden-file-input" />
              </div>
              <div class="preview-grid mt-8" id="edit-preview-grid"></div>
            </div>

            <div class="modal-actions">
