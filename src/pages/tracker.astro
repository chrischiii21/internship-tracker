            <button type="button" class="btn-cancel" onclick="document.getElementById('ai-summary-modal').style.display='none'">Close</button>
            <button type="button" id="btn-copy-ai-summary" class="btn-save" style="display: none;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              Copy Suggestion
            </button>
          </div>
        </div>
      </div>
  </div>
</Layout>

<script is:inline>
  const params = new URLSearchParams(window.location.search);

  window.setSourceFilter = (source) => {
    const p = new URLSearchParams(window.location.search);
    if (source === 'all') {
      p.delete('source');
    } else {
      p.set('source', source);
    }
    p.set('page', '1');
    window.location.search = p.toString();
  };

  window.changePage = (page) => {
    const p = new URLSearchParams(window.location.search);
    p.set('page', page.toString());
    window.location.search = p.toString();
  };
  const successVal = params.get('success');
  if (successVal) {
    const msg = successVal === 'true' ? 'Activity updated successfully' : successVal;
    window.showToast(msg, 'success');
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }
  if (params.get('error')) {
    window.showToast(decodeURIComponent(params.get('error')), 'error');
    const newUrl = window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }



  // Date Filters Event Listeners
  const filterStart = document.getElementById('filter-start-date');
  const filterEnd = document.getElementById('filter-end-date');
  const btnReset = document.getElementById('btn-reset-filters');

  function updateFilters() {
    const params = new URLSearchParams(window.location.search);
    if (filterStart && filterStart.value) {
      params.set('startDate', filterStart.value);
    } else {
      params.delete('startDate');
    }
    if (filterEnd && filterEnd.value) {
      params.set('endDate', filterEnd.value);
    } else {
      params.delete('endDate');
    }
    params.set('page', '1');
    window.location.search = params.toString();
  }

  const btnApply = document.getElementById('btn-apply-filters');
  if (btnApply) {
    btnApply.addEventListener('click', updateFilters);
  }
  if (btnReset) {
    btnReset.addEventListener('click', () => {
      const params = new URLSearchParams(window.location.search);
      params.delete('startDate');
      params.delete('endDate');
      params.delete('page');
      window.location.search = params.toString();
    });
  }

  let addSelectedFiles = [];
  let editSelectedFiles = [];
  let editExistingUrls = [];

  function setupUploadZone(zoneId, inputId, previewGridId, isEdit) {
    const zone = document.getElementById(zoneId);
    const input = document.getElementById(inputId);
    if (!zone || !input) return;

    // Remove existing event listeners to avoid duplicates
    const newZone = zone.cloneNode(true);
    zone.parentNode.replaceChild(newZone, zone);
    
    const newInput = input.cloneNode(true);
    input.parentNode.replaceChild(newInput, input);

    newZone.addEventListener('click', () => newInput.click());

    newZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      newZone.classList.add('dragover');
    });

    newZone.addEventListener('dragleave', () => {
      newZone.classList.remove('dragover');
    });

    newZone.addEventListener('drop', (e) => {
      e.preventDefault();
      newZone.classList.remove('dragover');
      if (e.dataTransfer.files) {
        handleFiles(e.dataTransfer.files, isEdit, previewGridId);
      }
    });

    newInput.addEventListener('change', () => {
      if (newInput.files) {
        handleFiles(newInput.files, isEdit, previewGridId);
      }
    });
  }

  function handleFiles(files, isEdit, previewGridId) {
    const arr = isEdit ? editSelectedFiles : addSelectedFiles;
    for (let i = 0; i < files.length; i++) {
      if (files[i].type.startsWith('image/')) {
        arr.push(files[i]);
      } else {
        window.showToast('Only image files are allowed.', 'error');
      }
    }
    renderAllPreviews(isEdit, previewGridId);
  }

  function renderAllPreviews(isEdit, previewGridId) {
    const grid = document.getElementById(previewGridId);
    if (!grid) return;
    grid.innerHTML = '';

    const existingUrls = isEdit ? editExistingUrls : [];
    const localFiles = isEdit ? editSelectedFiles : addSelectedFiles;

    existingUrls.forEach((url, idx) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'preview-thumb-wrapper';
      
      const img = document.createElement('img');
      img.src = url;
      img.className = 'preview-thumb';
      wrapper.appendChild(img);

      const delBtn = document.createElement('button');
      delBtn.type = 'button';
      delBtn.className = 'preview-del-btn';
      delBtn.innerHTML = '&times;';
      delBtn.onclick = () => {
        existingUrls.splice(idx, 1);
        document.getElementById(isEdit ? 'edit-doc-urls' : 'add-doc-urls').value = JSON.stringify(existingUrls);
        renderAllPreviews(isEdit, previewGridId);
      };
      wrapper.appendChild(delBtn);
      grid.appendChild(wrapper);
    });

    localFiles.forEach((file, idx) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'preview-thumb-wrapper local';
      
      const img = document.createElement('img');
      img.src = URL.createObjectURL(file);
      img.className = 'preview-thumb';
      wrapper.appendChild(img);

      const badge = document.createElement('span');
      badge.className = 'preview-badge';
      badge.textContent = 'PENDING';
      wrapper.appendChild(badge);

      const delBtn = document.createElement('button');
      delBtn.type = 'button';
      delBtn.className = 'preview-del-btn';
      delBtn.innerHTML = '&times;';
      delBtn.onclick = () => {
        localFiles.splice(idx, 1);
        renderAllPreviews(isEdit, previewGridId);
      };
      wrapper.appendChild(delBtn);
      grid.appendChild(wrapper);
    });
  }

  // Initialize upload zones
  document.addEventListener('DOMContentLoaded', () => {
    setupUploadZone('add-upload-zone', 'add-file-input', 'add-preview-grid', false);
  });
  // Also hook immediately for direct page access
  setTimeout(() => {
    setupUploadZone('add-upload-zone', 'add-file-input', 'add-preview-grid', false);
  }, 100);

  function convert24to12(timeStr) {
    if (!timeStr) return { time: '', ampm: 'AM' };
    const parts = timeStr.split(':');
    let hours = parseInt(parts[0], 10);
    const minutes = parts[1] || '00';
    let ampm = 'AM';
    if (hours >= 12) {
      ampm = 'PM';
      if (hours > 12) hours -= 12;
    } else if (hours === 0) {
      hours = 12;
    }
    return {
      time: `${String(hours).padStart(2, '0')}:${minutes}`,
      ampm: ampm
    };
  }

  window.openEditModal = function(id, desc, date, start, end, docUrls) {
    document.getElementById('edit-id').value = id;
    document.getElementById('edit-desc').value = desc;
    document.getElementById('edit-date').value = date;
    
    let urls = [];
    if (docUrls) {
      urls = Array.isArray(docUrls) ? docUrls : JSON.parse(docUrls);
    }
    editExistingUrls = [...urls];
    editSelectedFiles = [];
    document.getElementById('edit-doc-urls').value = JSON.stringify(editExistingUrls);
    renderAllPreviews(true, 'edit-preview-grid');
    
    // Set up the edit upload zone dynamically when modal opens
    setupUploadZone('edit-upload-zone', 'edit-file-input', 'edit-preview-grid', true);

    const start12 = convert24to12(start);
    document.getElementById('edit-start').value = start12.time;
    document.getElementById('edit-start-ampm').value = start12.ampm;
    const startBtn = document.getElementById('edit-start-ampm-btn');
    if (startBtn) {
      startBtn.textContent = start12.ampm;
      if (start12.ampm === 'PM') {
        startBtn.classList.add('active');
      } else {
        startBtn.classList.remove('active');
      }
    }
    
    const end12 = convert24to12(end);
    document.getElementById('edit-end').value = end12.time;
    document.getElementById('edit-end-ampm').value = end12.ampm;
    const endBtn = document.getElementById('edit-end-ampm-btn');
    if (endBtn) {
      endBtn.textContent = end12.ampm;
      if (end12.ampm === 'PM') {
        endBtn.classList.add('active');
      } else {
        endBtn.classList.remove('active');
      }
    }
    
    document.getElementById('edit-modal').style.display = 'flex';
  }

  let deleteTargetId = null;
  window.openDeleteModal = function(id) {
    deleteTargetId = id;
    document.getElementById('delete-log-modal').style.display = 'flex';
  }

  window.confirmDelete = function() {
    if (!deleteTargetId) return;
    document.getElementById('action-hidden').value = 'delete';
    document.getElementById('id-hidden').value = deleteTargetId;
    const form = document.getElementById('timer-main-form');
    if (form) {
      if (typeof form.requestSubmit === 'function') {
        form.requestSubmit();
      } else {
        form.submit();
      }
    }
  }

  // Intercept all POST form submissions on this page for AJAX swapping
  document.addEventListener('submit', async (e) => {
    const form = e.target;
    if (form && form.method.toUpperCase() === 'POST') {
      const actionAttr = form.getAttribute('action');
      if (actionAttr && actionAttr.startsWith('/api/')) {
        // Let standard API post requests happen normally (they redirect anyway)
        return;
      }
      
      e.preventDefault();
      await handleFormSubmit(form, e);
    }
  });

  async function handleFormSubmit(form, event) {
    const btn = form.querySelector('button[type="submit"]');
    
    if (btn) {
      btn.disabled = true;
      btn.style.opacity = '0.7';
    }

    try {
      const isEdit = form.classList.contains('edit-form');
      const isAdd = form.classList.contains('side-form');
      
      let uploadedUrls = [];
      if (isAdd || isEdit) {
        const localFiles = isEdit ? editSelectedFiles : addSelectedFiles;
        if (localFiles.length > 0) {
          const originalText = btn.innerHTML;
          btn.innerHTML = `
            <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" style="display:inline-block; vertical-align:middle; width:16px; height:16px; animation: spin 1s linear infinite; margin-right: 8px;">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" style="opacity: 0.25;"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" style="opacity: 0.75;"></path>
            </svg>
            UPLOADING PROOF...
          `;

          const uploadFormData = new FormData();
          localFiles.forEach(file => {
            uploadFormData.append('files', file);
          });

          const uploadRes = await fetch('/api/upload', {
            method: 'POST',
            body: uploadFormData
          });

          if (!uploadRes.ok) {
            const errorObj = await uploadRes.json();
            throw new Error(errorObj.error || 'Failed to upload documentation');
          }

          uploadedUrls = await uploadRes.json();
          btn.innerHTML = originalText;
        }
      }

      const formData = new FormData(form);
      
      if (isAdd || isEdit) {
        const existingUrls = isEdit ? editExistingUrls : [];
        const finalUrls = [...existingUrls, ...uploadedUrls];
        formData.set('documentationUrls', JSON.stringify(finalUrls));
      }
      
      // If a specific submit button triggered the submission, append its action values
      if (event && event.submitter) {
        const submitter = event.submitter;
        if (submitter.name) {
          formData.append(submitter.name, submitter.value);
        }
      }

      const response = await fetch(window.location.pathname + window.location.search, {
        method: 'POST',
        body: formData
      });

      if (!response.ok) {
        throw new Error('Network response was not ok');
      }

      // Check if we were redirected to a completely different path (e.g., login page)
      const finalUrl = new URL(response.url);
      if (finalUrl.pathname !== window.location.pathname) {
        window.location.href = response.url;
        return;
      }

      const html = await response.text();
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, 'text/html');



      // 2. Swap activity logs list
      const newLogList = doc.querySelector('.log-list');
      const oldLogList = document.querySelector('.log-list');
      if (newLogList && oldLogList) {
        oldLogList.replaceWith(newLogList);
        setupAiTriggers();
      }

      // 3. Swap stats box
      const newStatsBox = doc.querySelector('.stats-box');
      const oldStatsBox = document.querySelector('.stats-box');
      if (newStatsBox && oldStatsBox) {
        oldStatsBox.replaceWith(newStatsBox);
      }

      // 4. Reset manual add form (if this was the one submitted)
      if (form.classList.contains('side-form')) {
        form.reset();
        addSelectedFiles = [];
        const addPreview = document.getElementById('add-preview-grid');
        if (addPreview) addPreview.innerHTML = '';
        setupUploadZone('add-upload-zone', 'add-file-input', 'add-preview-grid', false);

        const dateInput = form.querySelector('input[type="date"]');
        if (dateInput) {
          dateInput.value = new Date().toLocaleDateString('en-CA', { timeZone: 'Asia/Manila' });
        }
        // Reset start and end ampm toggle buttons visually
        const startBtn = form.querySelector('[data-input-name="startAmpm"]');
        if (startBtn) {
          startBtn.classList.remove('active');
          startBtn.textContent = 'AM';
        }
        const endBtn = form.querySelector('[data-input-name="endAmpm"]');
        if (endBtn) {
          endBtn.classList.add('active');
          endBtn.textContent = 'PM';
        }
      }

      // 5. Close modals if they were open
      const editModal = document.getElementById('edit-modal');
      if (editModal) editModal.style.display = 'none';
      const deleteModal = document.getElementById('delete-log-modal');
      if (deleteModal) deleteModal.style.display = 'none';



      // Show toast if success/error parameter is in the redirect URL
      const successMsg = finalUrl.searchParams.get('success');
      const errorMsg = finalUrl.searchParams.get('error');
      if (successMsg) {
        window.showToast(decodeURIComponent(successMsg), 'success');
      } else if (errorMsg) {
        window.showToast(decodeURIComponent(errorMsg), 'error');
      }

    } catch (err) {
      console.error(err);
      window.showToast('An error occurred. Please try again.', 'error');
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.style.opacity = '';
      }
    }
  }

  // Time Masking Logic
  document.addEventListener('input', (e) => {
    if (e.target.classList.contains('time-mask')) {
      let val = e.target.value.replace(/\D/g, '');
      if (val.length > 4) val = val.slice(0, 4);
      
      // Auto-colon only for 4 digits as you type
      if (val.length === 4) {
        e.target.value = val.slice(0, 2) + ':' + val.slice(2);
      } else {
        e.target.value = val;
      }
    }
  });

  function formatTimeInput(target) {
    let val = target.value.replace(/\D/g, '');
    if (!val) return;
    
    const is24hr = !target.closest('.time-12hr-wrapper');
    
    if (val.length === 1) {
      const num = parseInt(val, 10);
      if (num >= 1 && num <= 9) {
        target.value = '0' + val + ':00';
      } else if (num === 0) {
        target.value = is24hr ? '00:00' : '12:00';
      }
    } else if (val.length === 2) {
      const num = parseInt(val, 10);
      const maxHour = is24hr ? 23 : 12;
      if (num >= 1 && num <= maxHour) {
        target.value = val + ':00';
      } else if (num === 0) {
        target.value = is24hr ? '00:00' : '12:00';
      } else {
        const h = parseInt(val[0], 10);
        let m = parseInt(val[1], 10);
        if (m > 5) m = 5;
        target.value = '0' + h + ':' + m + '0';
      }
    } else if (val.length === 3) {
      target.value = '0' + val[0] + ':' + val.slice(1);
    } else if (val.length === 4) {
      target.value = val.slice(0, 2) + ':' + val.slice(2);
    }
  }

  document.addEventListener('change', (e) => {
    if (e.target.classList.contains('time-mask')) {
      formatTimeInput(e.target);
    }
  }, true);

  document.addEventListener('blur', (e) => {
    if (e.target.classList.contains('time-mask')) {
      formatTimeInput(e.target);
    }
  }, true);

  // Handle backspace
  document.addEventListener('keydown', (e) => {
    if (e.target.classList.contains('time-mask') && e.key === 'Backspace') {
      if (e.target.value.includes(':') && e.target.value.length === 5) {
         // Let normal backspace work
      }
    }
  });

  // Handle click toggling on AM/PM buttons
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.ampm-toggle-btn');
    if (btn) {
      e.preventDefault();
      const isPM = btn.classList.contains('active');
      const inputName = btn.dataset.inputName;
      const form = btn.closest('form');
      if (form) {
        const input = form.querySelector(`input[name="${inputName}"]`);
        if (input) {
          if (isPM) {
            btn.classList.remove('active');
            btn.textContent = 'AM';
            input.value = 'AM';
          } else {
            btn.classList.add('active');
            btn.textContent = 'PM';
            input.value = 'PM';
          }
        }
      }
    }
  });

  // AI Summary Logic
  const aiModal = document.getElementById('ai-summary-modal');
  const aiLoading = document.getElementById('ai-summary-loading');
  const aiError = document.getElementById('ai-summary-error');
  const aiErrorText = document.getElementById('ai-summary-error-text');
  const aiResultContainer = document.getElementById('ai-summary-result-container');
  const aiText = document.getElementById('ai-summary-text');
  const btnCopyAi = document.getElementById('btn-copy-ai-summary');

  async function handleAiSummaryClick(e) {
    e.preventDefault();
    const btn = e.currentTarget;
    const type = btn.dataset.type;
    const label = btn.dataset.label;
    let entries = [];
    try {
      entries = JSON.parse(btn.dataset.entries || '[]');
    } catch (err) {
      console.error('Failed to parse entries JSON:', err);
      return;
    }

    if (!aiModal || !aiLoading || !aiError || !aiResultContainer || !aiText || !btnCopyAi) return;

    // Reset and show modal
    aiModal.style.display = 'flex';
    aiLoading.style.display = 'flex';
    aiError.style.display = 'none';
    aiResultContainer.style.display = 'none';
    btnCopyAi.style.display = 'none';

    try {
      const response = await fetch('/api/summarize', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ type, label, entries })
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || 'Failed to generate summary.');
      }

      // Success
      aiLoading.style.display = 'none';
      aiResultContainer.style.display = 'block';
      aiText.value = data.text;
      btnCopyAi.style.display = 'inline-flex';
    } catch (err) {
      // Error
      aiLoading.style.display = 'none';
      aiError.style.display = 'flex';
      aiErrorText.textContent = err.message || 'An unexpected error occurred.';
    }
  }

  // Setup click listeners for all AI Summary trigger buttons
  function setupAiTriggers() {
    document.querySelectorAll('.ai-summary-trigger').forEach(btn => {
      btn.removeEventListener('click', handleAiSummaryClick);
      btn.addEventListener('click', handleAiSummaryClick);
    });
  }

  // Setup immediately
  setupAiTriggers();

  // Copy to clipboard
  if (btnCopyAi && aiText) {
    btnCopyAi.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(aiText.value);
        const originalHTML = btnCopyAi.innerHTML;
        btnCopyAi.innerHTML = `
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;"><polyline points="20 6 9 17 4 12"/></svg>
          Copied!
        `;
        setTimeout(() => {
          btnCopyAi.innerHTML = originalHTML;
        }, 2000);
      } catch (err) {
        window.showToast('Failed to copy text', 'error');
      }
    });
  }
</script>

