                      </div>
                    </div>
                    <p class="input-hint">Use 12-hour format (e.g., 08:00 to 05:00). Click the AM/PM badge next to the field to toggle AM/PM.</p>
                    
                    <div class="input-group">
                      <label>Documentation / Proof (Images)</label>
                      <div class="file-upload-zone" id="add-upload-zone">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="upload-icon"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                        <span>Click to upload or drag images</span>
                        <input type="file" id="add-file-input" multiple accept="image/*" class="hidden-file-input" />
                      </div>
                      <div class="preview-grid mt-8" id="add-preview-grid"></div>
                    </div>

                    <button type="submit" class="btn-outline">Add Entry</button>
                  </form>
                </div>
              </div>
            </div>
          </div>
      </div>

      <!-- Edit Entry Modal -->
      <div id="edit-modal" class="modal-overlay" style="display: none;">
        <div class="modal-content">
          <div class="modal-header">
            <h3>Edit Activity Log</h3>
            <button class="close-btn" onclick="document.getElementById('edit-modal').style.display='none'">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </button>
          </div>
          <form method="POST" class="edit-form">
            <input type="hidden" name="action" value="edit" />
            <input type="hidden" name="id" id="edit-id" />
            <input type="hidden" name="documentationUrls" id="edit-doc-urls" value="[]" />
            
            <div class="form-group">
              <label>Task Description</label>
              <input type="text" name="description" id="edit-desc" required />
