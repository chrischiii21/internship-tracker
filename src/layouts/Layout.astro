---
import Toaster from "../components/Toaster.astro";

interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="InternFlow — Professional Hours & Progress Tracker."
    />
    <title>{title ? `${title} — InternFlow` : "InternFlow"}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      const savedTheme = localStorage.getItem('theme') || 'dark';
      if (savedTheme === 'light') {
        document.documentElement.classList.add('light-mode');
      } else {
        document.documentElement.classList.remove('light-mode');
      }
    </script>
  </head>
  <body>
    <div class="sidebar-overlay" id="global-overlay"></div>
    
    <!-- Full-Screen Loading Overlay -->
    <div id="fullscreen-loading-overlay" class="loading-overlay">
      <div class="premium-loader">
        <div class="spinner-ring"></div>
        <div class="spinner-glow"></div>
      </div>
      <span id="fullscreen-loading-text" class="loading-spinner-text">Processing...</span>
    </div>

    <slot />
    <Toaster />

    <script is:inline>
      document
        .getElementById("global-overlay")
        ?.addEventListener("click", () => {
          document.body.classList.remove("sidebar-open");
        });

      window.showLoadingSpinner = function(text) {
        const overlay = document.getElementById("fullscreen-loading-overlay");
        const textEl = document.getElementById("fullscreen-loading-text");
        if (overlay) {
          if (textEl && text) {
            textEl.textContent = text;
          } else if (textEl) {
            textEl.textContent = "Processing...";
          }
          overlay.classList.add("active");
        }
      };

      window.hideLoadingSpinner = function() {
        const overlay = document.getElementById("fullscreen-loading-overlay");
        if (overlay) {
          overlay.classList.remove("active");
        }
      };
    </script>
  </body>
</html>

<style is:global>
  :root {
    --ntv-bg: #050b16;
    --ntv-orange: #ed6621;
    --ntv-red: #e61e2a;
    --ntv-gradient: linear-gradient(135deg, #ed6621 0%, #e61e2a 100%);
    --text-primary: #ffffff;
    --text-secondary: rgba(255, 255, 255, 0.65);
    --border-subtle: rgba(255, 255, 255, 0.08);
    --card-bg: rgba(13, 20, 33, 0.7);
    --modal-bg: #0d1421;
  }

  :root.light-mode {
    --ntv-bg: #f5f6f8;
    --text-primary: #121826;
    --text-secondary: rgba(18, 24, 38, 0.65);
    --border-subtle: rgba(18, 24, 38, 0.08);
    --card-bg: #ffffff;
    --modal-bg: #ffffff;
  }

  /* Global Light Mode Overrides */
  .light-mode h1,
  .light-mode h2,
  .light-mode h3,
  .light-mode h4,
  .light-mode h5,
  .light-mode h6,
  .light-mode .row-name,
  .light-mode .name,
  .light-mode .stat-value,
  .light-mode .box-title,
  .light-mode .log-title,
  .light-mode .link-status,
  .light-mode .code,
  .light-mode .modal-header h3,
  .light-mode .modal-header h2,
  .light-mode .modal-header-danger h2,
  .light-mode .modal-content h3,
  .light-mode .modal-content h2,
  .light-mode .roster-header h2,
  .light-mode .roster-header a,
  .light-mode .details-modal-grid label,
  .light-mode .edit-form label,
  .light-mode .form-group label,
  .light-mode .settings-card h3,
  .light-mode .setup-card h2,
  .light-mode .setup-card label {
    color: var(--text-primary) !important;
  }

  .light-mode input,
  .light-mode select,
  .light-mode textarea {
    background-color: rgba(0, 0, 0, 0.03) !important;
    border-color: rgba(0, 0, 0, 0.15) !important;
    color: var(--text-primary) !important;
  }
  .light-mode input:focus,
  .light-mode select:focus,
  .light-mode textarea:focus {
    border-color: var(--ntv-orange) !important;
  }

  .light-mode select option {
    background-color: var(--modal-bg) !important;
    color: var(--text-primary) !important;
  }

  .light-mode .modal-content,
  .light-mode .progress-modal-content,
  .light-mode .doc-viewer-modal-content,
  .light-mode .details-modal-content,
  .light-mode .info-modal-content {
    background-color: var(--modal-bg) !important;
    border-color: rgba(0, 0, 0, 0.12) !important;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1) !important;
  }

  .light-mode .btn-cancel,
  .light-mode .cancel-btn {
    background-color: rgba(0, 0, 0, 0.05) !important;
    border-color: rgba(0, 0, 0, 0.12) !important;
    color: var(--text-primary) !important;
  }
  .light-mode .btn-cancel:hover,
  .light-mode .cancel-btn:hover {
    background-color: rgba(0, 0, 0, 0.08) !important;
  }

  .light-mode #sys-header {
    background: rgba(255, 255, 255, 0.85) !important;
    border-bottom-color: rgba(0, 0, 0, 0.08) !important;
  }

  .light-mode #sidebar {
    background: rgba(255, 255, 255, 0.85) !important;
    border-right-color: rgba(0, 0, 0, 0.08) !important;
  }

  .light-mode .nav-item:hover {
    background-color: rgba(0, 0, 0, 0.03) !important;
    color: var(--text-primary) !important;
  }

  .light-mode .theme-toggle-btn {
    background-color: rgba(0, 0, 0, 0.05) !important;
    border-color: rgba(0, 0, 0, 0.12) !important;
    color: var(--text-primary) !important;
  }
  .light-mode .theme-toggle-btn:hover {
    background-color: rgba(0, 0, 0, 0.08) !important;
  }

  .light-mode .copy-invite-btn {
    background-color: rgba(0, 0, 0, 0.05) !important;
    border-color: rgba(0, 0, 0, 0.1) !important;
    color: var(--text-secondary) !important;
  }
  .light-mode .copy-invite-btn:hover {
    background-color: rgba(237, 102, 33, 0.1) !important;
    border-color: rgba(237, 102, 33, 0.3) !important;
    color: var(--ntv-orange) !important;
  }

  .light-mode .sidebar-user {
    background-color: rgba(237, 102, 33, 0.04) !important;
    border-color: rgba(237, 102, 33, 0.1) !important;
  }

  .light-mode .clock-wrapper {
    background-color: rgba(0, 0, 0, 0.04) !important;
  }

  .light-mode .stats-box,
  .light-mode .stat-card,
  .light-mode .section-card,
  .light-mode .main-control,
  .light-mode .history-container,
  .light-mode .tracker-card,
  .light-mode .settings-card {
    background-color: var(--card-bg) !important;
    border-color: var(--border-subtle) !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02) !important;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  html,
  body {
    height: 100%;
  }
  body {
    font-family: "Outfit", "Inter", system-ui, sans-serif;
    background: var(--ntv-bg);
    color: var(--text-primary);
    overflow-x: hidden;
  }
  body.sidebar-open {
    overflow: hidden;
  }

  .sidebar-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    z-index: 900;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  body.sidebar-open .sidebar-overlay {
    opacity: 1;
    pointer-events: auto;
  }

  /* Utilities */
  .content-center {
    max-width: 1000px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }

  .mobile-only {
    display: none;
  }

  @media (max-width: 900px) {
    .mobile-only {
      display: flex;
    }
    
    /* Ensure all main content areas are centered on mobile */
    [id="portal-main"] {
      padding: 24px 16px !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
    }
    
    [id$="-content"], .content-grid, .tracker-layout, .dtr-scroll-wrapper {
      width: 100% !important;
      max-width: 100% !important;
    }
  }

  .loading-overlay {
    position: fixed;
    inset: 0;
    background: rgba(5, 11, 22, 0.82);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.3s;
  }
  .loading-overlay.active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .premium-loader {
    position: relative;
    width: 64px;
    height: 64px;
    margin-bottom: 24px;
  }
  .spinner-ring {
    position: absolute;
    inset: 0;
    border: 3px solid rgba(255, 255, 255, 0.05);
    border-top: 3px solid #ed6621;
    border-right: 3px solid #e61e2a;
    border-radius: 50%;
    animation: layoutSpin 1s cubic-bezier(0.5, 0.1, 0.4, 0.9) infinite;
  }
  .spinner-glow {
    position: absolute;
    inset: -4px;
    border: 3px solid transparent;
    border-top: 3px solid rgba(237, 102, 33, 0.35);
    border-right: 3px solid rgba(230, 30, 42, 0.35);
    border-radius: 50%;
    filter: blur(4px);
    animation: layoutSpin 1s cubic-bezier(0.5, 0.1, 0.4, 0.9) infinite;
  }
  .loading-spinner-text {
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.15em;
    background: linear-gradient(135deg, #fff 0%, rgba(255, 255, 255, 0.7) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 0 20px rgba(255, 255, 255, 0.15);
    text-transform: uppercase;
    animation: textPulse 1.5s ease-in-out infinite;
  }
  @keyframes layoutSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes textPulse {
    0%, 100% { opacity: 0.6; transform: scale(0.98); }
    50% { opacity: 1; transform: scale(1.02); }
  }

  /* Info / How it Works Modals */
  .info-modal-content {
    max-width: 580px !important;
  }
  .modal-subtitle {
    color: var(--text-secondary);
    font-size: 14px;
    margin-bottom: 24px;
    line-height: 1.5;
  }
  .modal-header-info {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }
  .modal-header-info h3 {
    font-size: 20px;
    font-weight: 700;
    color: #fff;
  }
  .info-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(96, 165, 250, 0.15);
    border-radius: 10px;
    color: #60a5fa;
  }
  .guide-steps {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 28px;
  }
  .guide-step {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--ntv-gradient);
    border-radius: 50%;
    color: #fff;
    font-size: 13px;
    font-weight: 800;
    flex-shrink: 0;
  }
  .step-details h4 {
    font-size: 15px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 4px;
  }
  .step-details p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  .modal-actions-single {
    display: flex;
    justify-content: flex-end;
  }
</style>
