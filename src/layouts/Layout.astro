---
import { ClientRouter } from "astro:transitions";
import Toaster from "../components/Toaster.astro";
import Analytics from "@vercel/analytics/astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Internship Portal — Professional Hours & Progress Tracker."
    />
    <title>Internship Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
    <script>
      import { App } from '@capacitor/app';
      
      // Handle Android Hardware Back Button
      App.addListener('backButton', ({ canGoBack }) => {
        if (canGoBack) {
          window.history.back();
        } else {
          App.exitApp();
        }
      });
    </script>
  </head>
  <body>
    <div class="sidebar-overlay" id="global-overlay"></div>
    <slot />
    <Toaster />
    <Analytics />

    <script is:inline>
      document
        .getElementById("global-overlay")
        ?.addEventListener("click", () => {
          document.body.classList.remove("sidebar-open");
        });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --ntv-bg: #050b16;
    --ntv-orange: #ed6621;
    --ntv-red: #e61e2a;
    --ntv-gradient: linear-gradient(135deg, #ed6621 0%, #e61e2a 100%);
    --text-primary: #ffffff;
    --text-secondary: rgba(255, 255, 255, 0.65);
    --border-subtle: rgba(255, 255, 255, 0.08);
    --card-bg: rgba(13, 20, 33, 0.7);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  html,
  body {
    height: 100%;
  }
  body {
    font-family: "Outfit", "Inter", system-ui, sans-serif;
    background: var(--ntv-bg);
    color: var(--text-primary);
    overflow-x: hidden;
  }
  body.sidebar-open {
    overflow: hidden;
  }

  .sidebar-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    z-index: 900;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  body.sidebar-open .sidebar-overlay {
    opacity: 1;
    pointer-events: auto;
  }

  /* Utilities */
  .content-center {
    max-width: 1000px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }

  .mobile-only {
    display: none;
  }

  @media (max-width: 900px) {
    .mobile-only {
      display: flex;
    }

    /* Ensure all main content areas are centered on mobile */
    [id="portal-main"] {
      padding: 24px 16px !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
    }

    [id$="-content"],
    .content-grid,
    .tracker-layout,
    .dtr-scroll-wrapper {
      width: 100% !important;
      max-width: 100% !important;
    }
  }
</style>
